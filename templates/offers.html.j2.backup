// Advanced Filter Engine JavaScript
function toggleFilter(element) {
  const isActive = element.classList.contains("is-active");
  
  // Remove active class from all pills in same filter type
  const filterType = element.dataset.filterType;
  document.querySelectorAll(`[data-filter-type="${filterType}"]`).forEach(pill => {
    pill.classList.remove("is-active");
  });
  
  // Add active class to clicked pill if it wasnt active
  if (!isActive) {
    element.classList.add("is-active");
  }
  
  // Trigger filter change event
  const filterEvent = new CustomEvent("filterChanged", {
    detail: {
      type: filterType,
      value: element.dataset.filterValue,
      element: element
    }
  });
  document.dispatchEvent(filterEvent);
}
