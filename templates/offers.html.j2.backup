{# build/templates/offers.html.j2 #}
{% from "macros.j2" import full_footer, footer_css, wa_svg, fb_svg, ig_svg, theme_vars, theme_toggle, theme_init_script, button_css,
   store_picker_modal, store_picker_js, sticky_mobile_bar, tracking_head, tracking_body, page_hero, hero_resolver, hero_css, google_analytics %}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<!-- Google Analytics -->
{{ google_analytics() }}

<link rel="canonical" href="{{ site_url }}/offers/index.html">
<meta name="description" content="Save on luxury hair styling, coloring, and skin care. View the latest beauty deals at our JP Nagar, Hennur, Devasandra, and Bangalore locations. Book your elite experience for less!">
<title>Exclusive Salon Offers &amp; Deals in Bangalore</title>
<meta property="og:type" content="website">
<meta property="og:site_name" content="Naturals Salon &amp; Spa Bangalore">
<link rel="preconnect" href="https://fonts.googleapis.com">
{{ tracking_head(gtm_id, pixel_id) }}
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
{{ theme_init_script() }}

<script type="application/ld+json">
{
  "@context":"https://schema.org",
  "@type":"CollectionPage",
  "name":"Exclusive Salon Offers & Deals in Bangalore",
  "description":"Save on luxury hair styling, coloring, and skin care. View the latest beauty deals at our JP Nagar, Hennur, Devasandra, and Bangalore locations. Book your elite experience for less!",
  "url":"{{ site_url }}/offers/index.html"
}
</script>

<style>
{{ theme_vars() }}
{{ hero_css() }}
*{margin:0;padding:0;box-sizing:border-box;}html{scroll-behavior:smooth;}
body{font-family:'Jost',sans-serif;background:var(--cream);color:var(--text);}
a{text-decoration:none;color:inherit;}img{display:block;width:100%;object-fit:cover;}


/* FILTER BAR */
.filter-bar{background:var(--filter-bg);padding:0 60px;position:sticky;top:70px;z-index:100;border-bottom:1px solid rgba(255,255,255,0.06);overflow-x:hidden;}
.filter-row{display:flex;align-items:center;gap:10px;padding:8px 0;width:100%;min-width:0;flex-wrap:nowrap;}
.filter-group{display:flex;align-items:center;gap:6px;flex-wrap:nowrap;min-width:0;}
.filter-group.store-group{flex:1 1 auto;min-width:180px;}
.filter-group.sort-group{flex:0 0 auto;min-width:140px;}
.filter-lbl{font-size:9px;letter-spacing:1.5px;text-transform:uppercase;font-weight:600;color:var(--green-soft);white-space:nowrap;margin-right:3px;}
#store-select, #sort-mode{
  appearance:none;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.12);color:rgba(255,255,255,0.7);padding:5px 32px 5px 12px;font-size:10px;letter-spacing:0.5px;text-transform:uppercase;font-family:'Jost',sans-serif;font-weight:500;cursor:pointer;transition:all 0.3s;border-radius:10px;min-width:160px;width:100%;flex-shrink:0;
}
#store-select:hover, #sort-mode:hover{border-color:rgba(255,255,255,0.3);color:#fff;}
#store-select:focus, #sort-mode:focus{outline:none;border-color:var(--gold);color:#fff;}
#store-select.active{background:var(--gold);border-color:var(--gold);color:var(--dark);font-weight:600;}

/* Advanced Filter Engine Styles */
.filter-section{background:#1a1f1c;border-radius:16px;padding:16px;margin-bottom:16px}
.filter-header{font-size:12px;font-weight:600;color:#C9A84C;margin-bottom:6px;display:none}
.filter-engine{margin:20px 0;position:relative}
.filter-pills-container{display:flex;gap:8px;overflow-x:auto}
.filter-pill{display:inline-flex;align-items:center;padding:6px 12px;border-radius:20px;border:none;cursor:pointer;font-size:13px;font-weight:600;white-space:nowrap}
.filter-pill.is-active{background:var(--gold);color:var(--dark);border-color:var(--gold)}
.filter-pill:hover{background:#3a3f3c;border-color:#555;transform:translateY(-1px);box-shadow:0 2px 8px rgba(0,0,0,0.15)}
[data-theme="naturals"] #store-select.active{background:var(--green-mid);border-color:var(--green-mid);color:#fff;}
.f-btn{background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.4);padding:6px 14px;font-size:11px;letter-spacing:1px;text-transform:uppercase;cursor:pointer;transition:all 0.25s;font-family:'Jost',sans-serif;font-weight:500;border-radius:10px;}
.f-btn:hover{border-color:rgba(255,255,255,0.3);color:#fff;}
.f-btn.active{background:var(--gold);border-color:var(--gold);color:var(--dark);font-weight:600;}
[data-theme="naturals"] .f-btn.active{background:var(--green-mid);border-color:var(--green-mid);color:#fff;}

.sort-wrap{margin-left:auto;display:flex;align-items:center;gap:10px;flex-shrink:0;}
.sort-lbl{font-size:10px;letter-spacing:2px;text-transform:uppercase;font-weight:600;color:rgba(255,255,255,0.25);}
.sort-sel-wrap{position:relative;display:flex;align-items:center;}
.sort-sel{appearance:none;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.12);color:rgba(255,255,255,0.7);padding:6px 32px 6px 12px;font-size:11px;letter-spacing:1px;border-radius:10px;cursor:pointer;transition:all 0.2s;}
.sort-sel:hover{border-color:rgba(255,255,255,0.3);color:#fff;}
.sort-sel:focus{outline:none;border-color:var(--gold);color:#fff;}
.sort-sel:disabled{opacity:0.3;cursor:not-allowed;}
.sort-sel-wrap .chev{position:absolute;right:10px;color:rgba(255,255,255,0.3);pointer-events:none;font-size:10px;}

.results-bar{background:var(--cream);padding:14px 60px;border-bottom:1px solid rgba(0,0,0,0.06);font-size:13px;color:var(--text-light);overflow-x:hidden;}

.offers-main{}
.store-group{margin-bottom:52px;}
.store-group-hdr{display:flex;align-items:baseline;gap:16px;margin-bottom:20px;padding-bottom:12px;border-bottom:2px solid rgba(0,0,0,0.06);}
.store-group-name{font-family:'Cormorant Garamond',serif;font-size:30px;font-weight:300;color:var(--text);}
.store-group-count{font-size:11px;color:var(--text-light);letter-spacing:2px;text-transform:uppercase;}

.offers-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;}
@media(max-width:900px){ .offers-grid{grid-template-columns:1fr 1fr;} }
@media(max-width:600px){ .offers-grid{grid-template-columns:1fr;} }

.offer-card{background:#fff;overflow:hidden;transition:box-shadow 0.25s,transform 0.25s;border:1px solid rgba(0,0,0,0.06);min-height:360px;display:flex;flex-direction:column;border-radius:14px;}
.offer-card:hover{box-shadow:0 10px 34px rgba(0,0,0,0.10);transform:translateY(-2px);}

.offer-media{height:200px;position:relative;background:linear-gradient(135deg,var(--dark) 0%,var(--green) 100%);overflow:hidden;}
.offer-media img{width:100%;height:100%;object-fit:cover;transition:transform 0.7s ease;cursor:zoom-in;}
.offer-card:hover .offer-media img{transform:scale(1.04);}

.ribbon{position:absolute;top:14px;left:14px;z-index:2;background:rgba(201,168,76,0.92);color:var(--dark);font-size:9px;letter-spacing:2px;text-transform:uppercase;font-weight:800;padding:7px 10px;border-radius:999px;box-shadow:0 8px 18px rgba(0,0,0,0.18);}
.ribbon.urgent{background:rgba(217,48,37,0.92);color:#fff;}
.ribbon.new{background:rgba(26,115,232,0.92);color:#fff;}

.offer-body{padding:18px 18px 16px;display:flex;flex-direction:column;flex:1;}
.offer-badge{font-size:9px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);font-weight:700;margin-bottom:8px;}
.offer-title{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:400;margin-bottom:8px;color:var(--text);line-height:1.2;}
.offer-details{font-size:12px;color:var(--text-mid);line-height:1.7;font-weight:300;margin-bottom:12px;}
.offer-details.clamp{display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden;}
.offer-more{display:inline-flex;gap:6px;align-items:center;font-size:11px;color:var(--green-mid);cursor:pointer;margin-top:-6px;margin-bottom:12px;}
.offer-more:hover{text-decoration:underline;}

.offer-footer{margin-top:auto;display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;padding-top:12px;border-top:1px solid rgba(0,0,0,0.06);}
.offer-valid{font-size:11px;color:var(--green-soft);font-weight:800;white-space:nowrap;}
.offer-ctas{display:flex;gap:8px;align-items:center;flex-wrap:wrap;}

.offer-icon-btn{
  width:40px;height:40px;border-radius:12px;
  display:inline-flex;align-items:center;justify-content:center;
  border:1px solid rgba(0,0,0,0.10);
  transition:transform 0.2s, box-shadow 0.2s, opacity 0.2s;
  text-decoration:none;
}
.offer-icon-btn:hover{transform:translateY(-1px);box-shadow:0 8px 18px rgba(0,0,0,0.12);}

.offer-icon-book{background:#1A73E8;border-color:rgba(26,115,232,0.45);}
.offer-icon-wa{background:#25D366;border-color:rgba(37,211,102,0.45);}
.offer-icon-call{background:#5F6368;border-color:rgba(95,99,104,0.45);}
.offer-icon-fb{background:#fff;border-color:rgba(24,119,242,0.30);}
.offer-icon-ig{background:#fff;border-color:rgba(225,48,108,0.25);}

.offer-icon-btn svg{width:18px;height:18px;display:block;}
.offer-icon-book svg{fill:#fff;}
.offer-icon-wa svg{fill:#fff;}
.offer-icon-call svg{fill:#fff;}

.no-offers{text-align:center;padding:80px 32px;color:var(--text-light);}
.no-offers h3{font-family:'Cormorant Garamond',serif;font-size:32px;font-weight:300;margin-bottom:10px;}

#img-modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.75);backdrop-filter:blur(6px);z-index:12000;display:none;}
#img-modal{position:fixed;inset:0;z-index:12001;display:none;align-items:center;justify-content:center;padding:18px;}
#img-modal-inner{position:relative;max-width:min(980px, 96vw);max-height:86vh;background:#000;border-radius:14px;overflow:hidden;box-shadow:0 24px 90px rgba(0,0,0,0.55);}
#img-modal-inner img{width:100%;height:100%;max-height:86vh;object-fit:contain;background:#000;}
#img-close{position:absolute;top:10px;right:10px;width:40px;height:40px;border-radius:10px;background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.22);color:#fff;font-size:20px;cursor:pointer;}
#img-close:hover{background:rgba(255,255,255,0.22);}

#img-prev,#img-next{
  position:absolute;top:50%;transform:translateY(-50%);
  width:44px;height:44px;border-radius:12px;
  background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.22);
  color:#fff;font-size:18px;cursor:pointer;
  display:flex;align-items:center;justify-content:center;
}
#img-prev{left:10px;} #img-next{right:10px;}
#img-prev:hover,#img-next:hover{background:rgba(255,255,255,0.22);}

#details-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.6);backdrop-filter:blur(4px);z-index:11000;display:none;}
#details-modal{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);width:92%;max-width:620px;max-height:84vh;overflow:auto;background:var(--cream);z-index:11001;display:none;border-radius:14px;box-shadow:0 24px 80px rgba(0,0,0,0.45);}
[data-theme="naturals"] #details-modal{background:#FAF7FF;}
.dm-head{background:var(--dark);padding:20px 22px;position:sticky;top:0;}
[data-theme="naturals"] .dm-head{background:#1A0533;}
.dm-title{font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:300;color:#fff;line-height:1.1;margin-bottom:4px;}
.dm-meta{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,0.38);}
.dm-close{position:absolute;top:14px;right:14px;width:40px;height:40px;border-radius:10px;background:rgba(255,255,255,0.10);border:1px solid rgba(255,255,255,0.18);color:#fff;font-size:20px;cursor:pointer;}
.dm-close:hover{background:rgba(255,255,255,0.20);}
.dm-body{padding:18px 22px;}
.dm-body p{font-size:13px;color:var(--text-mid);line-height:1.85;font-weight:300;white-space:pre-wrap;}

#scroll-top{position:fixed;bottom:32px;right:32px;z-index:500;width:44px;height:44px;background:var(--dark);border:1px solid rgba(255,255,255,0.15);color:rgba(255,255,255,0.7);font-size:18px;display:flex;align-items:center;justify-content:center;cursor:pointer;opacity:0;pointer-events:none;transform:translateY(12px);transition:opacity 0.3s,transform 0.3s,background 0.2s;}
#scroll-top.visible{opacity:1;pointer-events:auto;transform:translateY(0);}
#scroll-top:hover{background:var(--green);}

</style>
{{ button_css() }}
{{ footer_css() }}
<style>

@media(max-width:900px){
  .page-hero-inner{padding:76px 20px 40px;}
  .filter-bar{padding:0 20px 10px;top:60px;}
  .results-bar{padding:12px 20px;}
  #scroll-top{bottom:20px;right:20px;}
  .filter-row{gap:8px;}
  .filter-group.store-group{min-width:140px;}
  .filter-group.sort-group{min-width:120px;}
  #store-select, #sort-mode{min-width:120px;}
}
@media(max-width:600px){
  .filter-bar{padding:0 16px 10px;}
  .results-bar{padding:12px 16px;}
  .filter-row{gap:6px;flex-wrap:wrap;}
  .filter-group.store-group{flex:1 1 100%;min-width:auto;}
  .filter-group.sort-group{flex:1 1 100%;min-width:auto;}
  #store-select, #sort-mode{min-width:100%;}
}
@media(max-width:480px){
  .filter-bar{padding:0 12px 10px;}
  .results-bar{padding:12px 12px;}
  .filter-row{gap:4px;}
  .filter-group{gap:4px;}
}
</style>
</head>
<body>
{{ tracking_body(gtm_id) }}

{% set base_path = '' %}
{% set active_page = 'offers' %}
{% include "header.j2" %}

{{ page_hero('offers', 'Premium Beauty &amp;<br>Hair Care Offers in Bangalore', 'Save on luxury hair styling, coloring, and skin care. View the latest beauty deals at our JP Nagar, Hennur, Devasandra, and Bangalore locations. Book your elite experience for less!', 'Uncompromising Luxury. Exceptional Value.', 'https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=1800&q=85') }}

<div class="filter-bar">
  <div class="filter-row">
    <div class="filter-group store-group">
      <span class="filter-lbl">Store</span>
      <div class="cat-select-wrap">
        <select id="store-select" onchange="filterOffers(this.value, null)">
          <option value="all">All Stores</option>
          {% for s in stores %}
          <button 
            class="filter-pill filter-pill-solid"
            data-filter-value="{{ s.Store_ID }}"
            data-filter-type="primary"
            onclick="toggleFilter(this)"
          >
            {{ s.store_display_name }}
          </button>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>

<div class="results-bar" id="results-bar">Showing {{ total_offers }} offer{{ 's' if total_offers != 1 else '' }} (All stores)</div>

<!-- DEBUG INFO -->
{% if debug %}
<div style="background: #ff6b6b; color: white; padding: 10px; margin: 10px 0; font-family: monospace; font-size: 12px; border-radius: 5px;">
  <strong>🔍 DEBUG INFO:</strong><br>
  <strong>offers_by_store keys:</strong> {{ offers_by_store.keys() | list | join(', ') }}<br>
  <strong>Total offers (flattened):</strong> {{ offers_all | length }}<br>
  {% for store_id, store_offers in offers_by_store.items() %}
    <strong>Store {{ store_id }}:</strong> {{ store_offers | length }} offers<br>
  {% endfor %}
  <strong>Template total_offers variable:</strong> {{ total_offers }}<br>
</div>
{% endif %}

<main class="offers-main section" id="offers-main">

<section id="view-by-store">
{% for s in stores %}
  {% set store_offers = offers_by_store[s.Store_ID] %}
  {% if store_offers %}
  <div class="store-group" data-store-group="{{ s.Store_ID }}">
    <div class="store-group-hdr">
      <div class="store-group-name">{{ s.store_display_name }}</div>
      <div class="store-group-count">{{ store_offers | length }} offer{{ 's' if store_offers | length != 1 else '' }}</div>
    </div>
    
    <!-- Location-Based SEO Anchor -->
    <div class="location-seo-anchor" style="margin-bottom:20px;padding:16px;background:rgba(255,255,255,0.02);border-radius:8px;border-left:4px solid var(--gold);">
      {% if s.Store_ID == 'Store_N78' %}
        <h3 style="font-size:18px;font-weight:400;color:var(--gold);margin-bottom:8px;">Exclusive Deals in JP Nagar</h3>
        <p style="font-size:14px;color:rgba(255,255,255,0.7);line-height:1.5;">Looking for the best salon deals in South Bangalore? Visit our JP Nagar 5th Phase studio for limited-time offers on hair and skin care.</p>
      {% elif s.Store_ID == 'Store_N77' %}
        <h3 style="font-size:18px;font-weight:400;color:var(--gold);margin-bottom:8px;">North Bangalore's Best Salon Offers</h3>
        <p style="font-size:14px;color:rgba(255,255,255,0.7);line-height:1.5;">Shopping at Elements Mall? Stop by for premium grooming discounts and mall-exclusive beauty packages.</p>
      {% elif s.Store_ID == 'Store_N36' %}
        <h3 style="font-size:18px;font-weight:400;color:var(--gold);margin-bottom:8px;">Grand Opening Offers in Devasandra</h3>
        <p style="font-size:14px;color:rgba(255,255,255,0.7);line-height:1.5;">Celebrate our brand new luxury location near KR Puram with special introductory pricing on all elite services.</p>
      {% elif s.Store_ID == 'Store_N05' %}
        <h3 style="font-size:18px;font-weight:400;color:var(--gold);margin-bottom:8px;">Heritage Luxury Deals in Frazer Town</h3>
        <p style="font-size:14px;color:rgba(255,255,255,0.7);line-height:1.5;">Experience elite styling at special rates in the heart of Bangalore. View our latest Frazer Town boutique offers.</p>
      {% elif s.Store_ID == 'Store_N43' %}
        <h3 style="font-size:18px;font-weight:400;color:var(--gold);margin-bottom:8px;">Premium Offers for Hennur Residents</h3>
        <p style="font-size:14px;color:rgba(255,255,255,0.7);line-height:1.5;">Specialized beauty packages for the Hennur community. Luxury hair and skin care deals right in your neighborhood.</p>
      {% endif %}
    </div>

    <div class="offers-grid">
    {% for offer in store_offers %}
      <article class="offer-card"
        data-store="{{ s.Store_ID }}"
        data-store-name="{{ s.store_display_name }}"
        data-valid="{{ offer.get('Valid_till','') }}"
        data-expiry-iso="{{ offer.get('_expiry_iso','') }}"
        data-valid-from-iso="{{ offer.get('_valid_from_iso','') }}"
        data-image-available="{{ offer.get('has_media','') }}"
        data-image-name="{{ offer.get('media_asset_name','') }}"
      >
        <!-- Offer Schema -->
        <script type="application/ld+json" style="display:none;">
        {
          "@context": "https://schema.org",
          "@type": "Offer",
          "name": "{{ offer.get('content_title','') }}",
          "description": "{{ offer.get('content_body','') }}",
          "provider": {
            "@type": "HairSalon",
            "name": "Naturals Salon & Spa {{ s.store_display_name }}",
            "address": {
              "@type": "PostalAddress",
              "streetAddress": "{{ s.Address_Full }}",
              "addressLocality": "Bangalore",
              "addressRegion": "Karnataka",
              "postalCode": "{{ s.Pincode }}",
              "addressCountry": "IN"
            }
          },
          "areaServed": "{{ s.local_neighborhood }}",
          "availabilityEnds": "{{ offer.get('_expiry_iso','') }}",
          "validFrom": "{{ offer.get('_valid_from_iso','') }}",
          "url": "{{ site_url }}/offers/index.html#{{ s.Store_ID }}",
          "potentialAction": [
            {
              "@type": "ReserveAction",
              "target": "{{ s.Appointment_URL }}",
              "name": "Book Now"
            },
            {
              "@type": "CommunicateAction", 
              "target": "https://wa.me/{{ s.phone_whatsapp }}",
              "name": "Claim on WhatsApp"
            }
          ]
        }
        </script>
        <div class="offer-media">
          <div class="ribbon" style="display:none;"></div>

          {% if is_yes(offer.get('has_media','')) and offer.get('media_asset_name','') %}
            <img class="offer-img"
                 data-img-base="/campaigns/offer/03_published/{{ offer.get('media_asset_name','') }}"
                 alt="{{ offer.get('content_title','Offer') }}"
                 loading="lazy">
          {% else %}
            <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;padding:18px;text-align:center;">
              <div style="color:#fff;">
                <div style="font-size:11px;letter-spacing:3px;text-transform:uppercase;opacity:0.7;margin-bottom:10px;">Special Offer</div>
                <div style="font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:300;line-height:1.05;margin-bottom:10px;">{{ offer.get('content_title','') }}</div>
                <div style="font-size:12px;opacity:0.65;line-height:1.6;">{{ offer.get('content_body','') }}</div>
              </div>
            </div>
          {% endif %}
        </div>

        <div class="offer-body">
          <div class="offer-badge">{{ s.store_display_name }}</div>
          <div class="offer-title">{{ offer.get('content_title','') }}</div>

          {% set details = offer.get('content_body','') %}
          <div class="offer-details clamp">{{ details }}</div>
          {% if details and details|length > 80 %}
            <div class="offer-more" onclick="openDetailsModal(this)" role="button" tabindex="0">Read more <span>→</span></div>
          {% else %}
            <div style="height:24px;"></div>
          {% endif %}
          
          <!-- Local Neighborhood Text -->
          {% if s.local_neighborhood %}
            <div class="offer-local-text" style="font-size:12px;color:var(--green-soft);margin-bottom:12px;font-style:italic;">
              Valid only at Naturals Elite {{ s.local_neighborhood }}{% if s.nearby_landmarks %}, near {{ s.nearby_landmarks }}{% endif %}.
            </div>
          {% endif %}

          <div class="offer-footer">
            <span class="offer-valid">Valid till {{ offer.get('Valid_till','') }}</span>
            <div class="offer-ctas">
              <a class="offer-icon-btn offer-icon-book" href="{{ s.Appointment_URL }}" target="_blank" rel="noopener"
                 aria-label="Book Now - {{ s.store_display_name }}" title="Book Now ({{ s.store_display_name }})">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 2a1 1 0 0 1 1 1v1h8V3a1 1 0 1 1 2 0v1h1.5A2.5 2.5 0 0 1 22 6.5v14A2.5 2.5 0 0 1 19.5 23h-15A2.5 2.5 0 0 1 2 20.5v-14A2.5 2.5 0 0 1 4.5 4H6V3a1 1 0 0 1 1-1zm13 8H4v10.5c0 .276.224.5.5.5h15a.5.5 0 0 0 .5-.5V10zM6 6H4.5a.5.5 0 0 0-.5.5V8h16V6.5a.5.5 0 0 0-.5-.5H18v1a1 1 0 1 1-2 0V6H8v1a1 1 0 1 1-2 0V6z"/></svg>
              </a>
              <a class="offer-icon-btn offer-icon-wa" href="https://wa.me/{{ s.phone_whatsapp }}" target="_blank" rel="noopener"
                 aria-label="Claim on WhatsApp - {{ s.store_display_name }}" title="Claim on WhatsApp ({{ s.store_display_name }})">
                {{ wa_svg(18) }}
              </a>
              <a class="offer-icon-btn offer-icon-call" href="tel:{{ s.Phone_Tel }}"
                 aria-label="Call ({{ s.store_display_name }})" title="Call ({{ s.store_display_name }})">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 0 1 1 1V21a1 1 0 0 1-1 1C10.85 22 2 13.15 2 2a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.46.57 3.58a1 1 0 0 1-.24 1.01l-2.2 2.2z"/></svg>
              </a>

              {# ✅ FB + IG per offer, from same store; open in new tab #}
              {% if s.get('Facebook_URL') and s.Facebook_URL not in ('', 'https://facebook.com/', 'https://facebook.com') %}
              <a class="offer-icon-btn offer-icon-fb" href="{{ s.Facebook_URL }}" target="_blank" rel="noopener"
                 aria-label="{{ s.store_display_name }} on Facebook" title="Facebook ({{ s.store_display_name }})">
                {{ fb_svg(18) }}
              </a>
              {% endif %}

              {% if s.get('Instagram_URL') and s.Instagram_URL not in ('', 'https://instagram.com/', 'https://instagram.com') %}
              <a class="offer-icon-btn offer-icon-ig" href="{{ s.Instagram_URL }}" target="_blank" rel="noopener"
                 aria-label="{{ s.store_display_name }} on Instagram" title="Instagram ({{ s.store_display_name }})">
                {{ ig_svg(18) }}
              </a>
              {% endif %}
            </div>
          </div>
        </div>
      </article>
    {% endfor %}
    </div>
  </div>
  {% endif %}
{% endfor %}
</section>

<section id="view-by-offer" style="display:block;">
  <div class="offers-grid" id="offers-grid-all">
    {% for offer in offers_all %}
      <article class="offer-card"
        data-store="{{ offer.get('Store_ID','') }}"
        data-store-name="{{ offer.get('_store_name','') }}"
        data-valid="{{ offer.get('Valid_till','') }}"
        data-expiry-iso="{{ offer.get('_expiry_iso','') }}"
        data-valid-from-iso="{{ offer.get('_valid_from_iso','') }}"
        data-image-available="{{ offer.get('has_media','') }}"
        data-image-name="{{ offer.get('media_asset_name','') }}"
      >
        <div class="offer-media">
          <div class="ribbon" style="display:none;"></div>

          {% if is_yes(offer.get('has_media','')) and offer.get('media_asset_name','') %}
            <img class="offer-img"
                 data-img-base="/campaigns/offer/03_published/{{ offer.get('media_asset_name','') }}"
                 alt="{{ offer.get('content_title','Offer') }}"
                 loading="lazy">
          {% else %}
            <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;padding:18px;text-align:center;">
              <div style="color:#fff;">
                <div style="font-size:11px;letter-spacing:3px;text-transform:uppercase;opacity:0.7;margin-bottom:10px;">Special Offer</div>
                <div style="font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:300;line-height:1.05;margin-bottom:10px;">{{ offer.get('content_title','') }}</div>
                <div style="font-size:12px;opacity:0.65;line-height:1.6;">{{ offer.get('content_body','') }}</div>
              </div>
            </div>
          {% endif %}
        </div>

        <div class="offer-body">
          <div class="offer-badge">{{ offer.get('_store_name','') }}</div>
          <div class="offer-title">{{ offer.get('content_title','') }}</div>

          {% set details = offer.get('content_body','') %}
          <div class="offer-details clamp">{{ details }}</div>
          {% if details and details|length > 80 %}
            <div class="offer-more" onclick="openDetailsModal(this)" role="button" tabindex="0">Read more <span>→</span></div>
          {% else %}
            <div style="height:24px;"></div>
          {% endif %}

          <div class="offer-footer">
            <span class="offer-valid">Valid till {{ offer.get('Valid_till','') }}</span>
            <div class="offer-ctas">
              <a class="offer-icon-btn offer-icon-book" href="{{ offer.get('_store_appointment','') }}" target="_blank" rel="noopener"
                 aria-label="Book appointment ({{ offer.get('_store_name','') }})" title="Book ({{ offer.get('_store_name','') }})">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 2a1 1 0 0 1 1 1v1h8V3a1 1 0 1 1 2 0v1h1.5A2.5 2.5 0 0 1 22 6.5v14A2.5 2.5 0 0 1 19.5 23h-15A2.5 2.5 0 0 1 2 20.5v-14A2.5 2.5 0 0 1 4.5 4H6V3a1 1 0 0 1 1-1zm13 8H4v10.5c0 .276.224.5.5.5h15a.5.5 0 0 0 .5-.5V10zM6 6H4.5a.5.5 0 0 0-.5.5V8h16V6.5a.5.5 0 0 0-.5-.5H18v1a1 1 0 1 1-2 0V6H8v1a1 1 0 1 1-2 0V6z"/></svg>
              </a>
              <a class="offer-icon-btn offer-icon-wa" href="https://wa.me/{{ offer.get('_store_wa','') }}" target="_blank" rel="noopener"
                 aria-label="WhatsApp ({{ offer.get('_store_name','') }})" title="WhatsApp ({{ offer.get('_store_name','') }})">
                {{ wa_svg(18) }}
              </a>
              <a class="offer-icon-btn offer-icon-call" href="tel:{{ offer.get('_store_call','') }}"
                 aria-label="Call ({{ offer.get('_store_name','') }})" title="Call ({{ offer.get('_store_name','') }})">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 0 1 1 1V21a1 1 0 0 1-1 1C10.85 22 2 13.15 2 2a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.46.57 3.58a1 1 0 0 1-.24 1.01l-2.2 2.2z"/></svg>
              </a>

              {% set fb = offer.get('_store_fb','') %}
              {% set ig = offer.get('_store_ig','') %}
              {% if fb and fb not in ('https://facebook.com/','https://facebook.com') %}
              <a class="offer-icon-btn offer-icon-fb" href="{{ fb }}" target="_blank" rel="noopener"
                 aria-label="{{ offer.get('_store_name','') }} on Facebook" title="Facebook ({{ offer.get('_store_name','') }})">
                {{ fb_svg(18) }}
              </a>
              {% endif %}
              {% if ig and ig not in ('https://instagram.com/','https://instagram.com') %}
              <a class="offer-icon-btn offer-icon-ig" href="{{ ig }}" target="_blank" rel="noopener"
                 aria-label="{{ offer.get('_store_name','') }} on Instagram" title="Instagram ({{ offer.get('_store_name','') }})">
                {{ ig_svg(18) }}
              </a>
              {% endif %}
            </div>
          </div>
        </div>
      </article>
    {% endfor %}
  </div>
</section>

<div class="no-offers" id="no-offers" style="display:none;">
  <h3>No active offers</h3>
  <p>Check back soon — new deals are added regularly.</p>
</div>

</main>

<button id="scroll-top" onclick="window.scrollTo({top:0,behavior:'smooth'})" title="Back to top">&#8593;</button>

<div id="img-modal-overlay" onclick="closeImgModal()"></div>
<div id="img-modal" role="dialog" aria-modal="true" aria-label="Offer image">
  <div id="img-modal-inner">
    <button id="img-close" onclick="closeImgModal()" aria-label="Close">×</button>
    <button id="img-prev" onclick="prevImg()" aria-label="Previous">‹</button>
    <button id="img-next" onclick="nextImg()" aria-label="Next">›</button>
    <img id="img-modal-src" alt="Offer image">
  </div>
</div>

<div id="details-overlay" onclick="closeDetailsModal()"></div>
<div id="details-modal" role="dialog" aria-modal="true" aria-label="Offer details">
  <div class="dm-head">
    <div class="dm-title" id="dm-title"></div>
    <div class="dm-meta" id="dm-meta"></div>
    <button class="dm-close" onclick="closeDetailsModal()" aria-label="Close">×</button>
  </div>
  <div class="dm-body">
    <p id="dm-body"></p>
  </div>
</div>

