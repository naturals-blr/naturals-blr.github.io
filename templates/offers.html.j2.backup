<script>
/* Image resolution (.jpg → .jpeg → .png) */
(function(){
  var EXT=['.jpg','.jpeg','.png'];
  function hasExt(path){ return /\.[a-zA-Z0-9]{2,5}(\?.*)?$/.test(path||''); }

  function attach(){
    document.querySelectorAll('img.offer-img').forEach(function(img){
      var base=img.getAttribute('data-img-base')||'';
      if(!base) return;

      if(hasExt(base)){
        img.src=base;
        return;
      }
      var i=0;
      img.src=base + EXT[i];
      img.onerror=function(){
        i++;
        if(i<EXT.length) img.src=base + EXT[i];
        else img.style.display='none';
      };
    });
  }
  (document.readyState==='loading') ? document.addEventListener('DOMContentLoaded', attach) : attach();
})();
</script>

<script>
/* Ribbons: urgent (<7 days) / NEW (<7 days since Valid_From) */
(function(){
  var now = "{{ now_ist_iso }}" ? new Date("{{ now_ist_iso }}") : new Date();
  function daysBetween(a,b){ return Math.floor((b.getTime()-a.getTime())/86400000); }
  var NEW_DAYS=7;

  document.querySelectorAll('.offer-card').forEach(function(card){
    var rib = card.querySelector('.ribbon');
    if(!rib) return;

    var expIso = card.getAttribute('data-expiry-iso')||'';
    var vfIso  = card.getAttribute('data-valid-from-iso')||'';

    var urgentDays=null;
    if(expIso){ urgentDays = daysBetween(now, new Date(expIso)); }

    var isUrgent = (urgentDays!==null && urgentDays>=0 && urgentDays<7);
    var isNew=false;
    if(vfIso){
      var age = daysBetween(new Date(vfIso), now);
      isNew = (age>=0 && age<NEW_DAYS);
    }

    if(isUrgent){
      rib.style.display='inline-flex';
      rib.className='ribbon urgent';
      rib.textContent='Ends in '+urgentDays+' day'+(urgentDays===1?'':'s');
    } else if(isNew){
      rib.style.display='inline-flex';
      rib.className='ribbon new';
      rib.textContent='NEW';
    }
  });
})();
</script>

<script>
/* Filter + Sort UI rules */
var currentStore='all';
var sortSel=document.getElementById('sort-mode');

function updateResultsBar(count, storeLabel){
  var bar=document.getElementById('results-bar');
  var label=storeLabel || (currentStore==='all' ? 'All stores' : 'Selected store');
  bar.textContent='Showing '+count+' offer'+(count===1?'':'s')+' ('+label+')';
}

function updateNoOffersMessage() {
    // More robust check for visible offer cards
    const visibleCards = document.querySelectorAll('.offer-card:not([style*="display: none"], [style*="display:none"])');
    const noOffersElement = document.getElementById('no-offers');
    
    if (visibleCards.length === 0) {
      noOffersElement.classList.remove('hidden');
    } else {
      noOffersElement.classList.add('hidden');
    }
    
    updateResultsBar(visibleCards.length, 'All stores');
  }

  var viewStore=document.getElementById('view-by-store');
  var viewOffer=document.getElementById('view-by-offer');

  if(sortSel){
    sortSel.addEventListener('change', function(){
      if(currentStore!=='all') return;
      filterOffers('all');
    });
  }

function filterOffers(storeId, btn){
  currentStore=storeId;
  var storeSel = document.getElementById('store-select');
  if (storeSel) {
    storeSel.value = storeId;
    storeSel.classList.toggle('active', storeId !== 'all');
  }

  var viewStore=document.getElementById('view-by-store');
  var viewOffer=document.getElementById('view-by-offer');

  if(storeId==='all'){
    if(sortSel) sortSel.disabled=false;
    var mode = sortSel ? sortSel.value : 'store';
    if(mode==='offer'){
      viewStore.style.display='none';
      viewOffer.style.display='';
      var allCards=viewOffer.querySelectorAll('.offer-card');
      updateResultsBar(allCards.length,'All stores');
      document.getElementById('no-offers').style.display=(allCards.length?'none':'');
    }else{
      viewOffer.style.display='none';
      viewStore.style.display='';
      var groups=viewStore.querySelectorAll('.store-group');
      var total=0;
      groups.forEach(function(g){g.style.display=''; total += g.querySelectorAll('.offer-card').length;});
      updateResultsBar(total,'All stores');
      document.getElementById('no-offers').style.display=(total?'none':'');
    }
    // rebuild filtered gallery set
    rebuildGallerySet();
    return;
  }

  if(sortSel){ sortSel.value='store'; sortSel.disabled=true; }
  viewOffer.style.display='none';
  viewStore.style.display='';

  var visibleCount=0;
  var visibleStoreName=null;
  viewStore.querySelectorAll('.store-group').forEach(function(g){
    var show=(g.dataset.storeGroup===storeId);
    g.style.display=show?'':'none';
    if(show){
      visibleCount += g.querySelectorAll('.offer-card').length;
      var nm=g.querySelector('.store-group-name');
      visibleStoreName = nm ? nm.textContent : null;
    }
  });

  document.getElementById('no-offers').style.display=(visibleCount?'none':'');
  updateResultsBar(visibleCount, visibleStoreName || 'Selected store');

  // rebuild filtered gallery set
  rebuildGallerySet();
}

if(sortSel){
  sortSel.addEventListener('change', function(){
    if(currentStore!=='all') return;
    filterOffers('all');
  });
}
</script>

<script>
/* Details Modal */
function openDetailsModal(el){
  var card=el.closest('.offer-card'); if(!card) return;
  var title=(card.querySelector('.offer-title')||{}).textContent || 'Offer';
  var store=card.getAttribute('data-store-name')||'';
  var valid=card.getAttribute('data-valid')||'';
  var details=(card.querySelector('.offer-details')||{}).textContent || '';
  document.getElementById('dm-title').textContent=title;
  document.getElementById('dm-meta').textContent=(store?store+' • ':'')+(valid?('Valid till '+valid):'');
  document.getElementById('dm-body').textContent=details;
  document.getElementById('details-overlay').style.display='block';
  document.getElementById('details-modal').style.display='block';
  document.body.style.overflow='hidden';
}
function closeDetailsModal(){
  document.getElementById('details-overlay').style.display='none';
  document.getElementById('details-modal').style.display='none';
  document.body.style.overflow='';
}
</script>

<script>
/* Image Modal — gallery uses FILTERED set (your decision) */
var gallerySrcs = [];
var galleryIndex = 0;

function rebuildGallerySet(){
  gallerySrcs = [];
  // collect visible offer images only
  document.querySelectorAll('img.offer-img').forEach(function(img){
    // visible card?
    var card = img.closest('.offer-card');
    if(!card) return;

    // card visible if all ancestors displayed
    var p = card;
    while(p){
      if(p.style && p.style.display === 'none') return;
      p = p.parentElement;
    }
    if(img.src) gallerySrcs.push(img.src);
  });
}

function openImgModal(src){
  rebuildGallerySet();
  if(!src) return;
  galleryIndex = Math.max(0, gallerySrcs.indexOf(src));
  document.getElementById('img-modal-src').src = src;
  document.getElementById('img-modal-overlay').style.display='block';
  document.getElementById('img-modal').style.display='flex';
  document.body.style.overflow='hidden';
}
function closeImgModal(){
  document.getElementById('img-modal-overlay').style.display='none';
  document.getElementById('img-modal').style.display='none';
  document.getElementById('img-modal-src').src='';
  document.body.style.overflow='';
}
function nextImg(){
  if(!gallerySrcs.length) return;
  galleryIndex = (galleryIndex + 1) % gallerySrcs.length;
  document.getElementById('img-modal-src').src = gallerySrcs[galleryIndex];
}
function prevImg(){
  if(!gallerySrcs.length) return;
  galleryIndex = (galleryIndex - 1 + gallerySrcs.length) % gallerySrcs.length;
  document.getElementById('img-modal-src').src = gallerySrcs[galleryIndex];
}

document.addEventListener('DOMContentLoaded', function(){
  // hook clicks
  document.querySelectorAll('img.offer-img').forEach(function(img){
    img.addEventListener('click', function(){ openImgModal(img.src); });
  });

  // swipe
  var startX=null;
  var inner=document.getElementById('img-modal-inner');
  if(inner){
    inner.addEventListener('touchstart', function(e){ startX=e.touches[0].clientX; }, {passive:true});
    inner.addEventListener('touchend', function(e){
      if(startX===null) return;
      var dx=e.changedTouches[0].clientX - startX;
      startX=null;
      if(Math.abs(dx)<40) return;
      if(dx<0) nextImg(); else prevImg();
    }, {passive:true});
  }
});

document.addEventListener('keydown',function(e){
  if(e.key==='Escape'){ closeImgModal(); closeDetailsModal(); }
  if(document.getElementById('img-modal').style.display==='flex'){
    if(e.key==='ArrowRight') nextImg();
    if(e.key==='ArrowLeft') prevImg();
  }
});
</script>

<script>
/* Scroll-to-top */
var scrollBtn=document.getElementById('scroll-top');
window.addEventListener('scroll',function(){
  if(scrollBtn) scrollBtn.classList.toggle('visible', window.scrollY>320);
},{passive:true});
</script>

<script>
/* Initialize */
filterOffers('all', document.querySelector('.f-btn[data-store="all"]'));
</script>

