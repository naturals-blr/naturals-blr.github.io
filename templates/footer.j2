{# templates/footer.j2 #}
{# Matches macros.j2 full_footer output exactly.
   Uses padding-based gutters (60px → 20px mobile) to align with all page types:
   - Home page (no max-width container, uses section padding)
   - Store pages (page-wrap: padding 56px 60px)
   - Careers pages (container: padding 40px 60px)
   No max-width on inner divs — footer fills full width like the macros.j2 version.
#}

{% set nav_base = website_base_url if (website_base_url is defined and website_base_url) else base_path %}

{# Resolve stores — prefer all_stores, fall back to stores #}
{% set _stores = all_stores if (all_stores is defined and all_stores)
                 else (stores if (stores is defined and stores) else []) %}

{# Derive careers city slug #}
{% set _city = '' %}
{% if careers_city_name is defined and careers_city_name %}
  {% set _city = careers_city_name %}
{% elif _stores %}
  {% if   _stores[0].Address_City   is defined and _stores[0].Address_City   %}{% set _city = _stores[0].Address_City   %}
  {% elif _stores[0].address_city   is defined and _stores[0].address_city   %}{% set _city = _stores[0].address_city   %}
  {% elif _stores[0].city           is defined and _stores[0].city           %}{% set _city = _stores[0].city           %}
  {% endif %}
{% endif %}
{% set careers_city_slug = (_city | lower | replace(' ', '-')) if _city else 'bangalore' %}

<footer>
  <div class="ft-top">

    <div class="ft-brand-col">
      <div class="ft-brand"><span id="staffTriggerBrand" style="cursor: pointer; position: relative;" title="Staff Portal - Click 5 times for access">N</span>aturals <span>Salon &amp; Spa</span></div>
      <div class="ft-tagline">India's most trusted salon network.<br>Premium beauty services across Bangalore.</div>
    </div>

    <div class="ft-col">
      <div class="ft-col-title">Explore</div>
      <ul>
        <li><a href="{{ nav_base }}/services/">Services &amp; Pricing</a></li>
        <li><a href="{{ nav_base }}/offers/">Offers</a></li>
        <li><a href="{{ nav_base }}/careers/{{ city_slug }}/">Join our Team</a></li>
        <li><a href="{{ nav_base }}/contact/">Contact Us</a></li>
        <li><a href="{{ nav_base }}/about/">About Us</a></li>
      </ul>
    </div>

    <div class="ft-col">
      <div class="ft-col-title">Locations</div>
      <ul>
        {#
          Uses new slug-based URL structure for consistency.
          Resolves display name from store_display_name → display_name → brand_store_name.
        #}
        {% if _stores %}
          {% for s in _stores %}
            {% set city = s.address_city|lower|replace(' ', '-') if s.address_city else 'bangalore' %}
            {% set slug = s.slug|lower if s.slug else (s.store_display_name|lower|replace(' ', '-')) %}
            {% set _name = s.store_display_name if (s.store_display_name is defined and s.store_display_name)
                           else (s.display_name   if (s.display_name   is defined and s.display_name)
                           else (s.brand_store_name if (s.brand_store_name is defined and s.brand_store_name) else '')) %}
            {% if _name %}
            <li><a href="{{ nav_base }}/stores/{{ city }}/{{ slug }}/">{{ _name }}</a></li>
            {% endif %}
          {% endfor %}
        {% endif %}
      </ul>
    </div>

    <div class="ft-col">
      <div class="ft-col-title">Policies</div>
      <ul>
        <li><a href="{{ nav_base }}/booking-policy/">Booking Policy</a></li>
        <li><a href="{{ nav_base }}/cancellation-policy/">Cancellation Policy</a></li>
        <li><a href="https://naturals.in" target="_blank" rel="noopener">Naturals India &#8599;</a></li>
      </ul>
    </div>

  </div>{# /.ft-top #}

  <div class="ft-bottom">
    <div class="ft-copy">&copy; 2026 Naturals Salon &amp; Spa, Bangalore. All rights reserved.</div>
    <div class="ft-url">naturals-blr.github.io</div>
  </div>
</footer>

<style>
/* ── Footer shell: full viewport width, always dark ─────────────── */
footer {
  background: #080f0b;
  width: 100%;
  margin: 0;
  padding: 40px 0;
  display: block;
}
[data-theme="naturals"] footer { background: #0D0120; }

/* Fix 2: Apply Full-Width CSS - ensure footer stretches full viewport */
.footer-section {
  width: 100% !important;
  margin: 0 !important;
  padding: 40px 0 !important;
  background-color: #080f0b !important;
}

/* ── ft-top: 4-col grid, padding mirrors page gutters (60px) ────── */
.ft-top {
  padding: 60px 60px 40px;
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 48px;
  border-bottom: 1px solid rgba(255,255,255,0.07);
  /* No max-width — fills full footer width like all other page sections */
}

/* ── Brand column ───────────────────────────────────────────────── */
.ft-brand-col {
  display: flex;
  flex-direction: column;
}
.ft-brand {
  font-family: 'Cormorant Garamond', serif;
  font-size: 28px;
  color: #fff;
  font-weight: 300;
  margin-bottom: 10px;
}
.ft-brand span { color: var(--gold); font-style: italic; }
.ft-tagline {
  font-size: 12px;
  color: rgba(255,255,255,0.28);
  font-weight: 300;
  line-height: 1.7;
}

/* ── Nav columns ────────────────────────────────────────────────── */
.ft-col { display: flex; flex-direction: column; }
.ft-col-title {
  font-size: 9px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--gold);
  font-weight: 600;
  margin-bottom: 16px;
}
.ft-col ul {
  list-style: none;
  padding: 0; margin: 0;
  display: flex;
  flex-direction: column;
  gap: 9px;
}
.ft-col li { margin: 0; }
.ft-col ul a {
  font-size: 12px;
  color: rgba(255,255,255,0.32);
  font-weight: 300;
  text-decoration: none;
  transition: color 0.3s;
  /* Truncate long store names gracefully */
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 160px;
}
.ft-col ul a:hover { color: rgba(255,255,255,0.72); }

/* ── Bottom bar: same 60px gutter as ft-top ─────────────────────── */
.ft-bottom {
  padding: 18px 60px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 8px;
}
.ft-copy { font-size: 11px; color: rgba(255,255,255,0.16); }
.ft-url  { font-size: 11px; color: rgba(255,255,255,0.18); letter-spacing: 1px; }

/* ── Responsive ─────────────────────────────────────────────────── */
@media (max-width: 960px) {
  .ft-top {
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    padding: 36px 20px 24px;
  }
  .ft-bottom {
    padding: 14px 20px;
    flex-direction: column;
    text-align: center;
  }
}
@media (max-width: 600px) {
  .ft-top {
    grid-template-columns: 1fr;
    padding: 28px 16px 20px;
  }
  .ft-col ul a { max-width: 100%; }
}
</style>

<!-- Staff Trigger for Admin Access -->
<div id="staffTrigger" style="position: fixed; bottom: 10px; right: 10px; width: 24px; height: 24px; opacity: 0.2; z-index: 9999; cursor: pointer;">
  ⚙️
</div>

<script>
  (function() {
    let tapCount = 0;
    let lastTap = 0;
    const triggers = [
      document.getElementById('staffTrigger'),
      document.getElementById('staffTriggerBrand')
    ].filter(Boolean); // Remove null elements

    function handleTriggerClick() {
      const now = new Date().getTime();

      // Reset if delay too long
      if (now - lastTap > 2000) {
        tapCount = 0;
      }

      tapCount++;
      lastTap = now;

      if (tapCount >= 5) {
        window.location.href = "/intranet"; // change dynamically if needed
      }
    }

    // Add click listeners to all trigger elements
    triggers.forEach(trigger => {
      trigger.addEventListener('click', handleTriggerClick);
    });
  })();
</script>
