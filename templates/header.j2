{# templates/header.j2 #}
{% from "macros.j2" import hamburger_nav, store_picker_modal, store_picker_js with context %}

<header id="site-header">
  <div class="hdr-inner">

    {% set _base = website_base_url if website_base_url is defined and website_base_url else base_path %}
    <a href="{{ _base }}/" class="hdr-logo" aria-label="Naturals Salon & Spa — Home">
      <img src="{{ _base }}/images/logo/naturals_header_logo.png"
           alt="Naturals Salon & Spa"
           width="200" height="68"
           loading="lazy"
           onerror="this.style.display='none'">
    </a>

    {{ hamburger_nav(base_path, active_page, (all_stores if all_stores is defined else (stores if stores is defined else []))) }}

  </div>
</header>

{# Include store picker modal and JavaScript for all pages #}
{% if all_stores is defined or stores is defined %}
  {% set _stores = all_stores if all_stores is defined else (stores if stores is defined else []) %}
  {{ store_picker_modal(_stores, base_path) }}
  {{ store_picker_js() }}
{% endif %}

<style>
#site-header{
  position:fixed;
  top:0;
  left:0;
  right:0;
  height:78px;
  background:var(--nav-bg); /* ALWAYS dark */
  z-index:9999;
  box-shadow:0 1px 0 rgba(255,255,255,0.07);
  overflow:hidden;
}

.hdr-inner{
  height:78px;
  padding:0 32px;
  display:flex;
  align-items:center;
  justify-content:space-between;
  max-width:1380px;
  margin:0 auto;
  width:100%;
  min-width:0;
}

.hdr-logo{display:flex;align-items:center;gap:10px;flex-shrink:0;}
.hdr-logo img{
  height:68px !important;
  width:auto !important;
  max-height:68px;
  filter:brightness(0) invert(1);
}
@media(max-width:768px){
  #site-header, .hdr-inner{height:58px;}
  .hdr-inner{padding:0 16px;}
  .hdr-logo img{height:48px !important; max-height:48px;}
}

/* Hamburger (new look) */
#hamburger.hamburger-btn{
  position:relative;
  z-index:10002;
  width:46px;
  height:42px;
  border-radius:10px;
  border:1px solid rgba(255,255,255,0.16);
  background:rgba(255,255,255,0.08);
  cursor:pointer;
  transition:background 0.25s ease, transform 0.2s ease, border-color 0.25s ease;
  display:flex;
  align-items:center;
  justify-content:center;
}
#hamburger:hover{
  background:rgba(255,255,255,0.16);
  border-color:rgba(201,168,76,0.55);
  transform:translateY(-1px);
}
.hamburger-lines{display:flex;flex-direction:column;gap:5px;}
.hamburger-lines span{
  width:20px;height:2px;border-radius:2px;background:#fff;display:block;opacity:0.9;
}

/* Drawer */
.mobile-drawer{
  position:fixed;top:0;right:0;height:100vh;width:min(340px, 88vw);
  background:var(--dark);
  transform:translateX(110%);
  transition:transform 0.28s ease;
  z-index:10001;
  box-shadow:-24px 0 80px rgba(0,0,0,0.45);
  border-left:1px solid rgba(255,255,255,0.08);
}
.mobile-drawer.open{transform:translateX(0);}
.md-top{display:flex;align-items:center;justify-content:space-between;padding:18px 18px;border-bottom:1px solid rgba(255,255,255,0.08);}
.md-home{color:#fff;font-size:12px;letter-spacing:2px;text-transform:uppercase;opacity:0.85;}
.md-close{width:40px;height:40px;border-radius:10px;border:1px solid rgba(255,255,255,0.14);background:rgba(255,255,255,0.08);color:#fff;font-size:20px;cursor:pointer;}
.md-close:hover{background:rgba(255,255,255,0.16);}
.md-nav{padding:14px 10px;display:flex;flex-direction:column;gap:6px;}
.md-link{
  padding:12px 12px;border-radius:10px;
  color:rgba(255,255,255,0.78);
  font-size:12px;letter-spacing:1.5px;text-transform:uppercase;
  border:1px solid rgba(255,255,255,0.06);
  background:rgba(255,255,255,0.03);
}
.md-link:hover{border-color:rgba(201,168,76,0.35);color:var(--gold);}
.md-link.is-active{border-color:rgba(201,168,76,0.65);color:var(--gold);}

body{
  padding-top:78px;
  overflow-x:hidden;
}
@media(max-width:768px){
  body{padding-top:58px;}
}
</style>