{# ══════════════════════════════════════════════
# macros/seo.j2
# SEO and structured data macros for Next.js
# ══════════════════════════════════════════════════

{# Generate JSON-LD structured data for HairSalon pages #}
{% macro json_ld_schema(page_data) %}
{% if page_data.page_type == 'store' %}
{% set social_links = [] %}
{% if page_data.facebook_url %}{% set _ = social_links.append(page_data.facebook_url) %}{% endif %}
{% if page_data.instagram_url %}{% set _ = social_links.append(page_data.instagram_url) %}{% endif %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "{{ page_data.schema_type | default('HairSalon') }}",
  "name": "{{ page_data.seo_title | default(page_data.brand_store_name) }}",
  "description": "{{ page_data.meta_description | default(page_data.h1_heading) | default('') }}",
  "url": "{{ website_base_url }}/{{ page_data.url_slug or page_data.slug or 'stores/' + (page_data.slug | default('')) }}",
  "image": "{{ website_base_url }}/images/stores/{{ page_data.slug }}/cover.jpg",
  "telephone": "+{{ page_data.phone_mobile }}",
  "priceRange": "{{ page_data.price_range }}",
  "branchOf": {
    "@type": "Brand",
    "name": "Naturals Salon & Spa"
  },
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "{{ page_data.address_full }}",
    "addressLocality": "{{ page_data.address_city }}",
    "addressRegion": "{{ page_data.address_state }}",
    "postalCode": "{{ page_data.address_pincode }}",
    "addressCountry": "IN"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": {{ page_data.schema_latitude }},
    "longitude": {{ page_data.schema_longitude }}
  },
  "areaServed": {{ page_data.nearby_landmarks.split(',') | map('trim') | list | tojson if page_data.nearby_landmarks else [] }},
  "hasMenu": "{{ website_base_url }}/services/",
  "sameAs": [
    "https://www.facebook.com/NaturalsSalon/",
    "https://www.instagram.com/naturalssalon/"
  ],
  "openingHours": [
    "Mo-Fr {{ page_data.mon_fri_hours | replace(' AM – ', '-') | replace(' PM – ', '-') | replace(' AM', ':00') | replace(' PM', ':00') | replace('-8:00:00', '-20:00') | replace('-9:00:00', '-21:00') | replace('-7:00:00', '-19:00') | replace('-6:00:00', '-18:00') | replace('-5:00:00', '-17:00') | replace('-4:00:00', '-16:00') | replace('-3:00:00', '-15:00') | replace('-2:00:00', '-14:00') | replace('-1:00:00', '-13:00') | replace('-12:00:00', '-12:00') }}",
    "Sa {{ page_data.saturday_hours | replace(' AM – ', '-') | replace(' PM – ', '-') | replace(' AM', ':00') | replace(' PM', ':00') | replace('-8:00:00', '-20:00') | replace('-9:00:00', '-21:00') | replace('-7:00:00', '-19:00') | replace('-6:00:00', '-18:00') | replace('-5:00:00', '-17:00') | replace('-4:00:00', '-16:00') | replace('-3:00:00', '-15:00') | replace('-2:00:00', '-14:00') | replace('-1:00:00', '-13:00') | replace('-12:00:00', '-12:00') }}",
    "Su {{ page_data.sunday_hours | replace(' AM – ', '-') | replace(' PM – ', '-') | replace(' AM', ':00') | replace(' PM', ':00') | replace('-8:00:00', '-20:00') | replace('-9:00:00', '-21:00') | replace('-7:00:00', '-19:00') | replace('-6:00:00', '-18:00') | replace('-5:00:00', '-17:00') | replace('-4:00:00', '-16:00') | replace('-3:00:00', '-15:00') | replace('-2:00:00', '-14:00') | replace('-1:00:00', '-13:00') | replace('-12:00:00', '-12:00') }}"
  ]
}
</script>
{% endif %}
{% endmacro %}

{# Generate Open Graph meta tags with asset management #}
{% macro open_graph_tags(page_data) %}
{% set og_image_path = page_data.og_image or '/images/og/og-default.jpg' %}
<meta property="og:title" content="{{ page_data.seo_title }}">
<meta property="og:description" content="{{ page_data.meta_description }}">
<meta property="og:image" content="{{ website_base_url }}{{ og_image_path }}">
<meta property="og:url" content="{{ website_base_url }}/{{ page_data.url_slug or page_data.slug or 'stores/' + (page_data.slug | default('')) }}">
<meta property="og:type" content="{{ 'place' if page_data.page_type == 'store' else 'website' }}">
<meta property="og:site_name" content="Naturals Salon & Spa Bangalore">
{% endmacro %}

{# Generate canonical URL with clean paths #}
{% macro canonical_url(page_data) %}
{% set clean_url = page_data.url_slug or page_data.slug or 'stores/' + (page_data.slug | default('')) %}
{% if clean_url.endswith('/index.html') %}
  {% set clean_url = clean_url.replace('/index.html', '/') %}
{% endif %}
<link rel="canonical" href="{{ website_base_url }}/{{ clean_url }}">
{% endmacro %}

{# Enhanced SEO meta tags with store priority #}
{% macro seo_meta_tags(page_data) %}
<title>{{ page_data.seo_title }}</title>
<meta name="description" content="{{ page_data.meta_description }}">
{% if page_data.local_neighborhood %}
<meta name="geo.placename" content="{{ page_data.local_neighborhood }}">
{% endif %}
{% if page_data.nearby_landmarks %}
<meta name="geo.position" content="{{ page_data.nearby_landmarks }}">
{% endif %}
{% endmacro %}
