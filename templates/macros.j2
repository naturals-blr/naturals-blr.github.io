{# ── STICKY MOBILE CTA BAR ── #}
{% macro sticky_mobile_bar(page_type='other', store=None) %}
<div id="sticky-bar" data-page-type="{{ page_type }}">
  <button class="sb-btn" id="sb-book" aria-label="Book appointment" title="Book">{{ calendar_svg(20) }}</button>
  <button class="sb-btn" id="sb-wa" aria-label="WhatsApp us" title="WhatsApp">{{ wa_svg(20) }}</button>
  <button class="sb-btn" id="sb-call" aria-label="Call us" title="Call">{{ call_svg(20) }}</button>
  <button class="sb-btn" id="sb-maps" aria-label="Get directions" title="Directions">{{ maps_svg(20) }}</button>
</div>
<style>
#sticky-bar{
  display:none;position:fixed;bottom:0;left:0;right:0;
  height:76px;z-index:9999;
  background:rgba(8,15,11,0.94);backdrop-filter:blur(12px);
  border-top:1px solid rgba(255,255,255,0.08);
  grid-template-columns:repeat(4,1fr);
  gap:10px;padding:12px 14px;
  transform:translateY(100%);
  transition:transform 0.45s cubic-bezier(0.165, 0.84, 0.44, 1);
}
#sticky-bar.is-visible{transform:translateY(0);}
[data-theme="naturals"] #sticky-bar{background:rgba(21,5,44,0.94);}
@media(max-width:992px){ #sticky-bar{display:grid;} }

.sb-btn{
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;
  font-family:'Jost',sans-serif;font-size:9px;letter-spacing:1px;text-transform:uppercase;font-weight:700;
  border:none;cursor:pointer;transition:all 0.2s;text-decoration:none;
  height:100%;border-radius:12px;padding:0 4px;color:#fff;
  box-shadow:0 4px 10px rgba(0,0,0,0.18);
}
.sb-btn svg{width:16px;height:16px;}
.sb-btn svg path{fill:#fff !important;}
#sb-book{background:#1A73E8;border:1px solid rgba(255,255,255,0.1);}
#sb-wa{background:#25D366;border:1px solid rgba(255,255,255,0.1);}
#sb-call{background:#5F6368;border:1px solid rgba(255,255,255,0.1);}
#sb-maps{background:#A82424;border:1px solid rgba(255,255,255,0.1);}
.sb-btn:active{filter:brightness(0.9);transform:scale(0.96);}
</style>

<script>
(function(){
  function performAction(sd, action){
    if(!sd) return;
    if(action==='book' && sd.book) window.open(sd.book,'_blank');
    if(action==='wa'   && sd.wa)   window.open('https://wa.me/' + sd.wa,'_blank');
    if(action==='call' && sd.call) window.location.href='tel:' + sd.call;
    if(action==='maps' && sd.maps) window.open(sd.maps,'_blank');
  }

  window._naturalsPendingAction = null;
  window._naturalsPerformPendingAction = function(sd){
    if(!window._naturalsPendingAction) return;
    var act = window._naturalsPendingAction;
    window._naturalsPendingAction = null;
    performAction(sd, act);
  };

  var bookBtn=document.getElementById('sb-book');
  var waBtn=document.getElementById('sb-wa');
  var callBtn=document.getElementById('sb-call');
  var mapsBtn=document.getElementById('sb-maps');

  {% if (page_type == 'store' or page_type == 'offers') and store %}
  var SD = {id:'{{ store.store_id_short }}',name:'{{ store.store_display_name }}',book:'{{ store.appointment_url }}',wa:'+{{ store.phone_whatsapp }}',call:'+{{ store.phone_mobile }}',maps:'{{ store.google_maps_url }}'};
  localStorage.setItem('naturals-store', JSON.stringify(SD));
  bookBtn && bookBtn.addEventListener('click', function(){ performAction(SD,'book'); });
  waBtn   && waBtn.addEventListener('click',   function(){ performAction(SD,'wa'); });
  callBtn && callBtn.addEventListener('click', function(){ performAction(SD,'call'); });
  mapsBtn && mapsBtn.addEventListener('click', function(){ performAction(SD,'maps'); });
  {% else %}
  function openPickerFor(action){
    window._naturalsPendingAction = action;
    if(typeof openStorePicker==='function') openStorePicker();
  }
  bookBtn && bookBtn.addEventListener('click', function(){ openPickerFor('book'); });
  waBtn   && waBtn.addEventListener('click',   function(){ openPickerFor('wa'); });
  callBtn && callBtn.addEventListener('click', function(){ openPickerFor('call'); });
  mapsBtn && mapsBtn.addEventListener('click', function(){ openPickerFor('maps'); });
  {% endif %}

  /* Visibility Toggle logic */
  var bar = document.getElementById('sticky-bar');
  if(bar && 'IntersectionObserver' in window){
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if(!entry.isIntersecting) bar.classList.add('is-visible');
        else bar.classList.remove('is-visible');
      });
    }, { threshold: 0 });

    var target = document.querySelector('.hero-btns, .hero-cta-wrap, .page-hero-inner');
    var isHomeOrStore = bar.getAttribute('data-page-type') === 'homepage' || bar.getAttribute('data-page-type') === 'store' || bar.getAttribute('data-page-type') === 'offers';

    if(target && isHomeOrStore){
      observer.observe(target);
    } else {
      bar.classList.add('is-visible'); /* Show on load for other pages */
    }
  } else if (bar) {
    bar.classList.add('is-visible'); /* Legacy fallback */
  }
})();
</script>
{% endmacro %}

{% macro store_picker_js() %}
<script>
function openStorePicker(){
  document.getElementById('store-modal-overlay').style.display='block';
  document.getElementById('store-modal').style.display='block';
  document.body.style.overflow='hidden';
}
function closeStorePicker(){
  document.getElementById('store-modal-overlay').style.display='none';
  document.getElementById('store-modal').style.display='none';
  document.body.style.overflow='';
}

/* Ensure sticky buttons use selected store on non-store pages */
window._applyStickyStore = function(sd){
  try{
    if(!sd) return;
    var bar=document.getElementById('sticky-bar');
    if(bar && bar.getAttribute('data-page-type') !== 'store'){
      /* On non-store pages, we always want to prompt.
         So we don't bind the sticky bar buttons to the selected store. */
      return;
    }
    var bookBtn=document.getElementById('sb-book');
    var waBtn=document.getElementById('sb-wa');
    var callBtn=document.getElementById('sb-call');
    var mapsBtn=document.getElementById('sb-maps');

    function clearAndBind(btn, fn){
      if(!btn) return;
      var clone = btn.cloneNode(true);
      btn.parentNode.replaceChild(clone, btn);
      clone.addEventListener('click', fn);
    }

    clearAndBind(bookBtn, function(){ if(sd.book) window.open(sd.book,'_blank'); });
    clearAndBind(waBtn,   function(){ if(sd.wa) window.open('https://wa.me/' + sd.wa,'_blank'); });
    clearAndBind(callBtn, function(){ if(sd.call) window.location.href='tel:' + sd.call; });
    clearAndBind(mapsBtn, function(){ if(sd.maps) window.open(sd.maps,'_blank'); });
  }catch(e){}
};

function selectStore(id,name,book,wa,call,maps,pageUrl){
  var sd={id:id,name:name,book:book,wa:wa,call:call,maps:maps,pageUrl:pageUrl};
  localStorage.setItem('naturals-store',JSON.stringify(sd));
  closeStorePicker();
  if(typeof window._applyStickyStore==='function') window._applyStickyStore(sd);
  
  // Handle pending booking action
  var actionPerformed = false;
  if(typeof window._naturalsPendingAction==='string' && window._naturalsPendingAction==='book' && book){
    window.open(book,'_blank');
    window._naturalsPendingAction=null;
    actionPerformed = true;
  } else if(typeof window._naturalsPendingAction==='string' && window._naturalsPendingAction==='wa' && wa){
    window.open('https://wa.me/'+wa,'_blank');
    window._naturalsPendingAction=null;
    actionPerformed = true;
  } else if(typeof window._naturalsPendingAction==='string' && window._naturalsPendingAction==='call' && call){
    window.location.href='tel:'+call;
    window._naturalsPendingAction=null;
    actionPerformed = true;
  } else if(typeof window._naturalsPendingAction==='string' && window._naturalsPendingAction==='maps' && maps){
    window.open(maps,'_blank');
    window._naturalsPendingAction=null;
    actionPerformed = true;
  } else if(typeof window._naturalsPerformPendingAction==='function' && window._naturalsPendingAction){
    window._naturalsPerformPendingAction(sd);
    actionPerformed = true;
  }
  
  // Only navigate if no action was performed and we have a pageUrl
  if(!actionPerformed && pageUrl) {
    window.location.href = pageUrl;
  }
}

/* Used by homepage store tiles (Book/Chat/Call/Directions) to keep your flow */
function storePickerThen(id,name,book,wa,call,maps,pageUrl,action){
  var sd={id:id,name:name,book:book,wa:wa,call:call,maps:maps,pageUrl:pageUrl};
  localStorage.setItem('naturals-store',JSON.stringify(sd));
  closeStorePicker();
  if(action==='book' && book) window.open(book,'_blank');
  if(action==='wa' && wa) window.open('https://wa.me/'+wa,'_blank');
  if(action==='call' && call) window.location.href='tel:'+call;
  if(action==='maps' && maps) window.open(maps,'_blank');
}

/* Set active state for store pages */
function setActiveStoreState(){
  try{
    var currentPath = window.location.pathname;
    var storeLinks = document.querySelectorAll('.drawer-store-link');
    
    storeLinks.forEach(function(link){
      var href = link.getAttribute('href');
      if(href && currentPath.includes(href.replace(/^\//, ''))){
        link.classList.add('active');
      } else {
        link.classList.remove('active');
      }
    });
  }catch(e){}
}

/* Run on page load and when drawer opens */
document.addEventListener('DOMContentLoaded', setActiveStoreState);

/* Also run when hamburger is clicked (drawer opens) */
var hamburger = document.getElementById('hamburger');
if(hamburger){
  hamburger.addEventListener('click', function(){
    setTimeout(setActiveStoreState, 100); // Small delay for drawer animation
    setTimeout(updateThemeSwatches, 50); // Update theme swatches when drawer opens
  });
}

/* Theme toggle functionality - Global State Management */
function setTheme(themeName){
  // Apply to document for immediate effect
  document.documentElement.setAttribute('data-theme', themeName);
  document.body.setAttribute('data-theme', themeName);
  
  // Persist in localStorage for global state
  localStorage.setItem('naturals-theme', themeName);
  
  // Update visual state
  updateThemeSwatches();
}

function updateThemeSwatches(){
  try{
    var currentTheme = document.body.getAttribute('data-theme') || 'luxury';
    var swatches = document.querySelectorAll('.theme-swatch');
    
    swatches.forEach(function(swatch){
      swatch.classList.remove('active');
      if(swatch.getAttribute('data-theme') === currentTheme){
        swatch.classList.add('active');
      }
    });
  }catch(e){}
}

/* Set default theme to Luxury for new visitors - Global State */
(function(){
  var savedTheme = localStorage.getItem('naturals-theme');
  if(!savedTheme){
    savedTheme = 'luxury'; // Default to Luxury theme for premium identity
    localStorage.setItem('naturals-theme', savedTheme);
  }
  
  // Apply to both documentElement and body for global consistency
  if(savedTheme){
    document.documentElement.setAttribute('data-theme', savedTheme);
    document.body.setAttribute('data-theme', savedTheme);
  }
  
  // Update visual state when DOM is ready
  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', updateThemeSwatches);
  } else {
    updateThemeSwatches();
  }
})();

document.addEventListener('keydown',function(e){ if(e.key==='Escape') closeStorePicker(); });
document.addEventListener('DOMContentLoaded',function(){
  try{
    var saved=JSON.parse(localStorage.getItem('naturals-store'));
    if(saved && saved.name){
      var ind=document.getElementById('store-indicator');
      var nm=document.getElementById('si-name');
      if(ind && nm){ nm.textContent=saved.name; ind.style.display='flex'; }
      if(typeof window._applyStickyStore==='function') window._applyStickyStore(saved);
    }
  }catch(e){}
});
</script>
{% endmacro %}

