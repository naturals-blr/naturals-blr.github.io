{# build/templates/macros.j2 — complete macros (merged + extended, no feature removals) #}

{% macro theme_vars() %}
:root{
  --dark:#111714;--green:#1B4332;--green-mid:#2D6A4F;--green-soft:#52B788;
  --cream:#F8F4EE;--gold:#C9A84C;--gold-pale:#EDD9A3;
  --text:#1A1A1A;--text-mid:#555;--text-light:#999;
  --hero-tint:rgba(17,23,20,0.88);--hero-tint2:rgba(17,23,20,0.45);
  --filter-bg:#111714;--card-hover-border:#C9A84C;
  --nav-bg:rgba(17,23,20,0.97);
}
[data-theme="naturals"]{
  --dark:#1A0533;--green:#2596BE;--green-mid:#7B2FBE;--green-soft:#B678F0;
  --cream:#FAF7FF;--gold:#C9A84C;--gold-pale:#EDD9A3;
  --text:#1A1A1A;--text-mid:#4A4458;--text-light:#8B7FA8;
  --hero-tint:rgba(26,5,51,0.87);--hero-tint2:rgba(58,10,100,0.45);
  --filter-bg:#1A0533;--card-hover-border:#7B2FBE;
  --nav-bg:rgba(26,5,51,0.97);
}

/* GLOBAL MINIMUM TYPOGRAPHY & SPACING RULES */
html{scroll-behavior:smooth;}
body{font-size:16px;line-height:1.6;}
h1, .h1{font-family:'Cormorant Garamond',serif;font-size:clamp(48px,5vw,60px);font-weight:300;line-height:1.05;}
h2, .h2{font-family:'Cormorant Garamond',serif;font-size:clamp(32px,4vw,40px);font-weight:300;line-height:1.15;}
h3, .h3{font-family:'Cormorant Garamond',serif;font-size:clamp(20px,2.5vw,24px);font-weight:400;line-height:1.25;}
.lbl{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);font-weight:600;margin-bottom:12px;display:flex;align-items:center;gap:12px;}
.lbl::before{content:'';width:18px;height:1px;background:var(--gold);}

/* COMPONENT CLASSES (8px System) */
.section{padding:80px 60px;}
@media(max-width:768px){.section{padding:48px 20px;}}
.container{max-width:1200px;margin:0 auto;width:100%;}
.card{background:#fff;border-radius:14px;border:1px solid rgba(0,0,0,0.06);overflow:hidden;transition:transform 0.3s,box-shadow 0.3s;}
.card:hover{transform:translateY(-4px);box-shadow:0 12px 36px rgba(0,0,0,0.08);border-color:var(--card-hover-border);}

/* ACCESSIBILITY */
:focus-visible{outline:2px solid var(--gold);outline-offset:4px;border-radius:4px;}

{% endmacro %}

