{% macro global_mobile_css() %}
@media(max-width:992px){
  body{padding-bottom:62px;} /* space for sticky bar */
}
{% endmacro %}

{% macro btn_book(href, text='Book', extra_class='') %}
<a class="btn-book {{ extra_class }}" href="{{ href }}" target="_blank" rel="noopener">{{ text }}</a>
{% endmacro %}

{% macro btn_wa(wa_number, text='WhatsApp', extra_class='') %}
<a class="btn-wa {{ extra_class }}" href="https://wa.me/+{{ wa_number | replace('+', '') | replace(' ', '') }}" target="_blank" rel="noopener">{{ wa_svg(18) }} {{ text }}</a>
{% endmacro %}

{% macro btn_call(tel_number, text='Call', extra_class='') %}
<a class="btn-call {{ extra_class }}" href="tel:+{{ tel_number | replace('+', '') | replace(' ', '') }}">{{ call_svg(18) }} {{ text }}</a>
{% endmacro %}

{% macro btn_maps(maps_url, text='Directions', extra_class='') %}
<a class="btn-maps {{ extra_class }}" href="{{ maps_url }}" target="_blank" rel="noopener">{{ maps_svg(18) }} {{ text }}</a>
{% endmacro %}

{% macro format_phone(phone_number) %}
  {% if phone_number and phone_number != '' %}
    {% set phone = phone_number|string %}
    {% if phone|length == 12 and phone.startswith('91') %}
      +91 {{ phone[2:6] }} {{ phone[6:10] }}
    {% elif phone|length == 10 %}
      +91 {{ phone[:5] }} {{ phone[5:] }}
    {% elif phone|length == 11 and phone.startswith('0') %}
      +91 {{ phone[1:6] }} {{ phone[6:] }}
    {% else %}
      {{ phone }}
    {% endif %}
  {% else %}
    No phone
  {% endif %}
{% endmacro %}

{% macro social_icons(store, size=18) %}
<div class="soc-row">
  {% if store.get('instagram_url') and store.instagram_url not in ('', 'https://instagram.com/', 'https://instagram.com') %}
    <a class="soc-btn soc-ig" href="{{ store.instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram"><span aria-hidden="true">{{ ig_svg(size) }}</span></a>
  {% endif %}
  {% if store.get('facebook_url') and store.facebook_url not in ('', 'https://facebook.com/', 'https://facebook.com') %}
    <a class="soc-btn soc-fb" href="{{ store.facebook_url }}" target="_blank" rel="noopener" aria-label="Facebook"><span aria-hidden="true">{{ fb_svg(size) }}</span></a>
  {% endif %}
</div>
<style>
.soc-row{display:flex;gap:8px;align-items:center;}
.soc-btn{width:40px;height:40px;border-radius:10px;display:inline-flex;align-items:center;justify-content:center;border:1px solid rgba(0,0,0,0.10);background:#fff;transition:transform 0.2s, box-shadow 0.2s;}
.soc-btn:hover{transform:translateY(-1px);box-shadow:0 10px 22px rgba(0,0,0,0.10);}
.soc-ig:hover{border-color:rgba(225,48,108,0.35);}
.soc-fb:hover{border-color:rgba(24,119,242,0.35);}
</style>
{% endmacro %}

{# ── HAMBURGER NAV (refactored for 5-store rebranding) ── #}
{% macro hamburger_nav(base_path, active_page, all_stores=None) %}
<button id="hamburger" aria-label="Menu" aria-expanded="false" aria-controls="drawer">
  <span class="hb-line"></span>
  <span class="hb-line"></span>
  <span class="hb-line"></span>
</button>

<div id="drawer-overlay" aria-hidden="true"></div>

<nav id="drawer" aria-label="Site menu">
<div class="drawer-head">
  <div class="drawer-brand">Naturals <span>Salon &amp; Spa</span></div>
  <button class="drawer-x" aria-label="Close menu">×</button>
</div>

{# ── THEME TOGGLE (COLOR SWATCHES) ── #}
<div class="drawer-theme-section">
  <div class="drawer-theme-label">CHOOSE THEME</div>
  <div class="drawer-theme-swatches">
    <button class="theme-swatch theme-luxury" onclick="setTheme('luxury')" aria-label="Switch to Luxury theme" data-theme="luxury">
      <span class="swatch-circle"></span>
    </button>
    <button class="theme-swatch theme-naturals" onclick="setTheme('naturals')" aria-label="Switch to Naturals theme" data-theme="naturals">
      <span class="swatch-circle"></span>
    </button>
  </div>
</div>

  {# Prefer absolute navigation so nested pages don't break links. #}
  {% set nav_base = website_base_url if website_base_url is defined and website_base_url else base_path %}

  {# Derive careers city slug from stores data (single-city setup). #}
  {% set _stores = all_stores if all_stores is not none else (stores if stores is defined else []) %}
  {% set _city = '' %}
  {% if careers_city_name is defined and careers_city_name %}
    {% set _city = careers_city_name %}
  {% elif _stores and _stores[0] is defined %}
    {% if _stores[0].address_city is defined and _stores[0].address_city %}
      {% set _city = _stores[0].address_city %}
    {% elif _stores[0].city is defined and _stores[0].city %}
      {% set _city = _stores[0].city %}
    {% elif _stores[0].address is defined and _stores[0].address.city is defined and _stores[0].address.city %}
      {% set _city = _stores[0].address.city %}
    {% endif %}
  {% endif %}

  {# ── PRIMARY NAVIGATION ── #}
  <div class="drawer-section">
    <a class="drawer-link {% if active_page=='home' %}is-active{% endif %}" href="{{ nav_base }}/" aria-label="Naturals Salon & Spa — Home">HOME</a>
    <a class="drawer-link {% if active_page=='services' %}is-active{% endif %}" href="{{ nav_base }}/services/" aria-label="View all salon services">SERVICES</a>
    <a class="drawer-link {% if active_page=='offers' %}is-active{% endif %}" href="{{ nav_base }}/offers/" aria-label="View current salon offers and promotions">OFFERS</a>
    
    {# ── OUR STORES (ALWAYS VISIBLE) ── #}
    <div class="drawer-stores-section">
      <div class="drawer-stores-header">
        <span class="drawer-stores-title">OUR STORES</span>
      </div>
      
      <div class="drawer-stores-list">
        {% if _stores %}
          {% for s in _stores %}
            {% set city = s.address_city|lower|replace(' ', '-') if s.address_city else 'bangalore' %}
            {% set slug = s.slug|lower if s.slug else (s.store_display_name|lower|replace(' ', '-')) %}
            <a class="drawer-store-link" href="{{ website_base_url }}/stores/{{ city }}/{{ slug }}/" aria-label="Visit Naturals Salon {{ s.store_display_name }}">
              <span class="drawer-store-name">{{ s.store_display_name }}</span>
            </a>
          {% endfor %}
        {% endif %}
      </div>
    </div>
    
    <a class="drawer-link {% if active_page=='careers' %}is-active{% endif %}" href="{{ nav_base }}/careers/{{ city_slug }}/" aria-label="Join our team and view career opportunities">Join our Team</a>
    <a class="drawer-link {% if active_page=='about' %}is-active{% endif %}" href="{{ nav_base }}/about/" aria-label="Learn about Naturals Salon & Spa">ABOUT</a>
  </div>

  {# ── BOOK APPOINTMENT CTA ── #}
  <div class="drawer-cta-section">
    <button class="drawer-cta-btn" onclick="window._naturalsPendingAction='book'; openStorePicker();" aria-label="Select store and book appointment">
      BOOK APPOINTMENT
    </button>
  </div>
</nav>

<style>
