<script>
(function(){
  function applyStoreModalScrollRule(){
    var modal = document.getElementById('store-modal');
    var cards = document.getElementById('spm-cards');
    if(!modal || !cards) return;
    var n = parseInt(modal.getAttribute('data-store-count') || '0', 10);
    cards.classList.toggle('spm-scroll', n > 6); /* ✅ scroll only if >6 */
  }
  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', applyStoreModalScrollRule);
  } else {
    applyStoreModalScrollRule();
  }
})();
</script>
