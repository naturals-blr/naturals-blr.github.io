{% from "macros.j2" import theme_vars, theme_init_script, button_css, footer_css, google_analytics %}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <!-- Google Analytics -->
    {{ google_analytics() }}
    
    <title>Naturals Staff Portal - Intranet</title>
    <meta name="description" content="Staff portal for Naturals Salon & Spa team members">
    <meta name="robots" content="noindex, nofollow">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    {{ theme_init_script() }}
    {{ button_css() }}
    {{ footer_css() }}
    
    <style>
        :root{ --dark:#111714;--green:#1B4332;--green-mid:#2D6A4F;--green-soft:#52B788; --cream:#F8F4EE;--gold:#C9A84C;--gold-pale:#EDD9A3; --text:#1A1A1A;--text-mid:#555;--text-light:#999; --hero-tint:rgba(17,23,20,0.88);--hero-tint2:rgba(17,23,20,0.45); --filter-bg:#111714;--card-hover-border:#C9A84C; --nav-bg:rgba(17,23,20,0.97); } [data-theme="naturals"]{ --dark:#1A0533;--green:#2596BE;--green-mid:#7B2FBE;--green-soft:#B678F0; --cream:#FAF7FF;--gold:#C9A84C;--gold-pale:#EDD9A3; --text:#1A1A1A;--text-mid:#4A4458;--text-light:#8B7FA8; --hero-tint:rgba(26,5,51,0.87);--hero-tint2:rgba(58,10,100,0.45); --filter-bg:#1A0533;--card-hover-border:#7B2FBE; --nav-bg:rgba(26,5,51,0.97); }
        
        /* ── Intranet Layout ── */
        body {
            background: var(--dark);
            color: #fff;
            font-family: 'Jost', sans-serif;
            margin: 0;
            padding: 0;
            min-height: 100vh;
        }
        [data-theme="naturals"] body {
            background: #0D0120;
        }
        
        .intranet-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 20px;
        }
        
        /* ── Header ── */
        .intranet-header {
            text-align: center;
            margin-bottom: 60px;
        }
        
        .intranet-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(32px, 5vw, 48px);
            font-weight: 300;
            color: #fff;
            margin-bottom: 8px;
        }
        
        .intranet-title em {
            font-style: italic;
            color: var(--gold);
        }
        
        .intranet-subtitle {
            font-size: 14px;
            color: rgba(255,255,255,0.6);
            letter-spacing: 1px;
            text-transform: uppercase;
        }
        
        /* ── Tiles Grid ── */
        .tiles-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 24px;
            margin-bottom: 60px;
        }
        
        .tile {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 16px;
            padding: 32px;
            text-decoration: none;
            color: #fff;
            transition: all 0.3s ease;
            display: block;
            position: relative;
            overflow: hidden;
        }
        
        .tile:hover {
            background: rgba(255,255,255,0.08);
            border-color: rgba(255,255,255,0.2);
            transform: translateY(-4px);
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
        }
        
        .tile-icon {
            font-size: 48px;
            margin-bottom: 16px;
            display: block;
        }
        
        .tile-title {
            font-size: 20px;
            font-weight: 600;
            margin-bottom: 8px;
            color: #fff;
        }
        
        .tile-description {
            font-size: 14px;
            color: rgba(255,255,255,0.7);
            line-height: 1.6;
        }
        
        .tile-arrow {
            position: absolute;
            bottom: 24px;
            right: 24px;
            font-size: 20px;
            color: var(--gold);
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        
        .tile:hover .tile-arrow {
            opacity: 1;
        }
        
        /* ── User Info ── */
        .user-info {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 12px;
            padding: 20px;
            text-align: center;
            margin-bottom: 40px;
        }
        
        .user-welcome {
            font-size: 16px;
            color: rgba(255,255,255,0.8);
            margin-bottom: 8px;
        }
        
        .user-role {
            font-size: 12px;
            color: var(--gold);
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        
        /* ── Responsive ── */
        @media (max-width: 768px) {
            .intranet-container {
                padding: 20px 16px;
            }
            
            .tiles-grid {
                grid-template-columns: 1fr;
                gap: 16px;
            }
            
            .tile {
                padding: 24px;
            }
        }
        
        /* ── Staff Name Personalization ── */
        .change-name-container {
            margin-top: 12px;
        }
        
        .change-name-btn {
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 20px;
            color: rgba(255,255,255,0.7);
            font-size: 12px;
            padding: 6px 12px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-family: 'Jost', sans-serif;
        }
        
        .change-name-btn:hover {
            background: rgba(255,255,255,0.2);
            color: #fff;
            border-color: rgba(255,255,255,0.3);
        }
        
        .name-modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.8);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 10000;
        }
        
        .name-modal-content {
            background: var(--dark);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 16px;
            padding: 32px;
            text-align: center;
            max-width: 400px;
            width: 90%;
        }
        
        .name-modal-title {
            font-size: 24px;
            margin-bottom: 16px;
            color: #fff;
        }
        
        .name-modal-subtitle {
            font-size: 14px;
            color: rgba(255,255,255,0.7);
            margin-bottom: 24px;
            line-height: 1.5;
        }
        
        .name-input {
            width: 100%;
            padding: 12px 16px;
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.3);
            border-radius: 8px;
            color: #fff;
            font-size: 16px;
            font-family: 'Jost', sans-serif;
            margin-bottom: 20px;
        }
        
        .name-input:focus {
            outline: none;
            border-color: var(--gold);
            background: rgba(255,255,255,0.15);
        }
        
        .name-submit-btn {
            background: var(--gold);
            color: var(--dark);
            border: none;
            border-radius: 8px;
            padding: 12px 24px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            font-family: 'Jost', sans-serif;
        }
        
        .name-submit-btn:hover {
            background: #B8943A;
            transform: translateY(-2px);
        }
    </style>
</head>
<body>
    <div class="intranet-container">
        <header class="intranet-header">
            <h1 class="intranet-title">Naturals <em>Staff Portal</em></h1>
            <p class="intranet-subtitle">Team Resources & Tools</p>
        </header>
        
        <div class="user-info">
            <div class="user-welcome">
                <span id="staffGreeting">Welcome 👋</span>
            </div>
            <div class="user-role">The Naturals Professional Team</div>
            <div class="change-name-container">
                <button onclick="resetStaffName()" class="change-name-btn">Change Name</button>
            </div>
        </div>
        
        <main class="tiles-grid">
            <a href="qrcode/" class="tile">
                <span class="tile-icon">📱</span>
                <h2 class="tile-title">Store QR Library</h2>
                <p class="tile-description">View and share the correct QR codes for customer check-ins, social follows, and instant review links.</p>
                <span class="tile-arrow">→</span>
            </a>
                      
            <a href="training/" class="tile">
                <span class="tile-icon">📺</span>
                <h2 class="tile-title">Stylist Training Hub</h2>
                <p class="tile-description">Access curated video tutorials on advanced hair trends, tool handling, and professional service standards for all 5 store locations.</p>
                <span class="tile-arrow">→</span>
            </a>

        </main>
    </div>
    
    <!-- Staff Name Modal -->
    <div id="nameModal" class="name-modal">
        <div class="name-modal-content">
            <h3 class="name-modal-title">👋 Welcome!</h3>
            <p class="name-modal-subtitle">
                Please enter your name (this stays on your device only)<br>
                This helps personalize the screen while you assist guests.
            </p>
            <input type="text" id="nameInput" class="name-input" placeholder="Enter your name" maxlength="50">
            <button onclick="saveStaffName()" class="name-submit-btn">Continue</button>
        </div>
    </div>
    
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const staffName = localStorage.getItem("staff_name");

            if (!staffName) {
                askStaffName();
            } else {
                greetStaff(staffName);
            }
        });

        function askStaffName() {
            const modal = document.getElementById("nameModal");
            const input = document.getElementById("nameInput");
            
            modal.style.display = "flex";
            input.focus();
            
            // Handle Enter key
            input.addEventListener("keypress", function(e) {
                if (e.key === "Enter") {
                    saveStaffName();
                }
            });
        }

        function saveStaffName() {
            const input = document.getElementById("nameInput");
            const name = input.value.trim();
            
            if (name && name.length > 0) {
                localStorage.setItem("staff_name", name);
                document.getElementById("nameModal").style.display = "none";
                greetStaff(name);
            } else {
                input.focus();
                input.style.borderColor = "#ff6b6b";
                setTimeout(() => {
                    input.style.borderColor = "rgba(255,255,255,0.3)";
                }, 2000);
            }
        }

        function greetStaff(name) {
            const el = document.getElementById("staffGreeting");
            if (el) {
                el.innerText = `Hi ${name} 👋`;
            }
        }

        function resetStaffName() {
            if (confirm("Are you sure you want to change your name?")) {
                localStorage.removeItem("staff_name");
                location.reload();
            }
        }
    </script>
</body>

{% include 'footer.j2' %}
</html>
