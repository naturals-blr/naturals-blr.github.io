    margin-bottom: 24px;
  }
  
  .qr-preview-column {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
  }
  
  .qr-grid {
    grid-template-columns: 1fr;
    max-width: 400px;
    width: 100%;
  }
  
  .qr-card img {
    max-height: 35vh; /* Keep 35vh constraint for one-screen */
  }
  
  .filter-header {
    display: block; /* Show labels on desktop */
    font-size: 14px;
    margin-bottom: 12px;
  }
  
  .filter-engine {
    margin-bottom: 16px; /* Compact spacing */
  }
  
  .filter-engine[data-filter-id="qr-selector"] {
    margin-top: 4px; /* Maintain 4px gap */
  }
  
  .filter-pills-container {
    flex-wrap: wrap;
    justify-content: flex-start;
  }
  
