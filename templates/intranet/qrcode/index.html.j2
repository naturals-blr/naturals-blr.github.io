  color: #bbb;
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s ease;
  flex-shrink: 0;
  min-width: fit-content;
}

.filter-pill:hover {
  background: #3a3f3c;
  border-color: #555;
  transform: translateY(-1px);
}

.filter-pill.is-active {
  background: #C9A84C;
  color: #111;
  border-color: #C9A84C;
  font-weight: 600;
  box-shadow: 0 2px 8px rgba(201, 168, 76, 0.3);
}

/* ── Filter Section Headers ── */
