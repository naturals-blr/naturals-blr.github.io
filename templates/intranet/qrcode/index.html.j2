function getGoogleIcon(){
 return `<svg class="btn-icon" viewBox="0 0 24 24" width="24" height="24">
   <path fill="#FFFFFF" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
   <path fill="#FFFFFF" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
   <path fill="#FFFFFF" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
   <path fill="#FFFFFF" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
 </svg>`;
}

function render(){
  const grid = document.getElementById("qrGrid");
  grid.innerHTML = "";
  
  // Only render if we have both a store and platform selected
  if (!currentStore || !currentPlatform) return;
  
  console.log('Switching to:', currentStore, currentPlatform);
  
  stores.forEach(store => {
    // Match both lowercase and original store_id_short
    const storeMatch = store.store_id_short === currentStore || 
                     store.store_id_short.toLowerCase() === currentStore ||
                     `store_${store.store_id_short}`.toLowerCase() === currentStore;
    
    // Only show QR codes for the selected store
    if (!storeMatch) return;
    
    // Only show QR codes for the selected platform
    qrTypes.forEach(p => {
      if (p !== currentPlatform) return;
      
      // Use the correct store_id_short for image paths
      const img = `/images/qrcodes/${store.store_id_short}_${p.charAt(0).toUpperCase()+p.slice(1)}${p==='google'?'Review':''}.png`;
      console.log('QR Image path:', img);
      
      grid.innerHTML += `
      <div class="qr-card">
       <img src="${img}" onerror="this.src='/images/qrcodes/placeholder.png'; console.log('QR image not found:', '${img}');">
       <div class="qr-card-title">${p==="google"?"⭐ Google Review":p.toUpperCase()}</div>
       <div class="qr-card-subtitle">${store.store_display_name}</div>
       <div class="qr-actions">
         <button class="btn btn-show" onclick="showQR('${img}','${store.store_id_short}','${p}')">SHOW QR</button>
         <button class="btn btn-${p==='facebook'?'fb':p==='instagram'?'ig':'google'} btn-open"
           onclick="openLink('${getURL(store,p)}','${store.store_id_short}','${p}')">
           ${p==='facebook'?getFacebookIcon():p==='instagram'?getInstagramIcon():getGoogleIcon()}
           OPEN
         </button>
       </div>
      </div>`;
    });
  });
}

// Add updateQRDisplay alias
function updateQRDisplay() {
  render();
}

function showQR(img, store, platform) {
  document.getElementById("qrImg").src = img;
  document.getElementById("qrOverlay").style.display = "flex";
  
  // Add history state for mobile back-button handling
  history.pushState({modalOpen: true}, "", "#qr-modal");
  
  trackEvent("show_qr", store, platform);
}

function closeQR() {
  document.getElementById("qrOverlay").style.display = "none";
  
  // Handle back button - if modal is open, go back to previous state
  if (window.location.hash === "#qr-modal") {
    history.back();
  }
}

// Mobile back-button logic
window.addEventListener('popstate', function(event) {
  // Check if we're coming back from the modal state
  if (event.state && event.state.modalOpen) {
    // Close the modal
    document.getElementById("qrOverlay").style.display = "none";
  }
});

// Add click event to QR image for full-screen view
document.addEventListener('DOMContentLoaded', function() {
  // Add click handler to QR images
  document.addEventListener('click', function(e) {
    if (e.target.matches('.qr-card img')) {
      const img = e.target.src;
      const card = e.target.closest('.qr-card');
      const store = card.querySelector('.qr-card-subtitle').textContent;
      const platform = card.querySelector('.qr-card-title').textContent.includes('Google') ? 'google' : 
                      card.querySelector('.qr-card-title').textContent.includes('Instagram') ? 'instagram' : 'facebook';
      
      showQR(img, store, platform);
    }
  });
});

