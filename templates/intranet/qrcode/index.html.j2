// ── Handle escape key for modal ──
document.addEventListener('keydown', function(event) {
  if (event.key === 'Escape') {
    const overlay = document.getElementById("qrOverlay");
    if (overlay.style.display === "flex") {
      closeQR();
    }
  }
});

function openLink(url,store,platform){
 window.open(url,"_blank");
 trackEvent("open_platform",store,platform);
}

/* 🔹 CLIENT-SIDE TRACKING (Google Apps Script ready) */
function trackEvent(event,store,platform){
 fetch("https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec",{
  method:"POST",
  body:JSON.stringify({
   event: event,
   store: store, 
   platform: platform,
   page:location.pathname,
   ts:new Date().toISOString()
  })
 }).catch(err=>console.error(err));
}

// ── Initialize on Page Load ──
document.addEventListener('DOMContentLoaded', () => {
  // Add click handlers to all filter pills
  document.querySelectorAll('.filter-pill').forEach(pill => {
    pill.addEventListener('click', () => {
      handleSelection(pill, pill.dataset.type);
    });
  });
  
  // Initialize filters on page load
  initializeFilters();
});

// Personalize back link with staff name
const staffName = localStorage.getItem("staff_name");
if (staffName) {
  const backLink = document.getElementById("backLink");
  if (backLink) {
    backLink.textContent = `← Back to ${staffName}'s Home`;
  }
  
  const reviewMessage = document.getElementById("reviewMessage");
  if (reviewMessage) {
    reviewMessage.textContent = `"${staffName}, it's Review Time! Show the Google QR code to capture your 5-star finish."`;
  }
}

render();
