<body>
<div class="qr-container">

<a href="../" class="back-link" id="backLink">
    ← Back to Staff Portal
</a>

<header style="text-align:center;margin-bottom:16px">
  <h1 class="qr-title">QR Code <em>Gallery</em></h1>
  <p style="opacity:.6;margin-bottom:8px" id="reviewMessage">"Staff Name, it's Review Time! Show the Google QR code to capture your 5-star finish."</p>
</header>

<div class="qr-main-content">
  <!-- Controls Column (Left) -->
  <div class="qr-controls-column">
    <!-- Store Filters (Primary) -->
    <div class="filter-header">Store</div>
    {{ filter_engine('Primary', stores_data, filter_id='store-selector') }}

    <!-- QR Type Filters (Secondary) -->
    <div class="filter-header">Type</div>
    {{ filter_engine('Secondary', qr_types_data, filter_id='qr-selector') }}
  </div>

  <!-- Preview Column (Right) -->
  <div class="qr-preview-column">
    <div id="qrGrid" class="qr-grid"></div>
  </div>
</div>

</div>

<!-- FULLSCREEN QR -->
<div id="qrOverlay" class="overlay" onclick="closeQR()">
  <span class="close">✕</span>
  <img id="qrImg">
</div>

<script>
const stores = {{ stores | tojson }};
const qrTypes = ["facebook","instagram","google"];

// Initialize with defaults
let currentStore = localStorage.getItem('qr_pref_store') || 'N78';  // JP Nagar store ID
let currentPlatform = localStorage.getItem('qr_pref_platform') || 'google';

// Force the QR display to show on page load
document.addEventListener('DOMContentLoaded', function() {
  // Initialize filters first
  initializeFilters();
  
  // Force QR display update
  updateQRDisplay();
});

// ── Persistent State Management ──
function loadSavedPreferences() {
  const savedStore = localStorage.getItem('qr_pref_store');
  const savedPlatform = localStorage.getItem('qr_pref_platform');
  
  // Default to JP Nagar (first store) and Google Review if no saved state
  currentStore = savedStore || 'n78';  // JP Nagar store ID
  currentPlatform = savedPlatform || 'google';
  
  return { savedStore, savedPlatform };
}

// ── Dynamic Reordering Logic ──
function handleSelection(element, type) {
  // 1. Update UI classes
  const siblings = element.parentElement.querySelectorAll('.filter-pill');
  siblings.forEach(s => s.classList.remove('is-active'));
  element.classList.add('is-active');

  // 2. Persist to LocalStorage
  localStorage.setItem(`qr_pref_${type}`, element.dataset.id);

  // 3. Scroll selected pill into view (keep original order)
  const parent = element.parentElement;
  const scrollLeft = element.offsetLeft - (parent.offsetWidth / 2) + (element.offsetWidth / 2);
  parent.scrollTo({ left: scrollLeft, behavior: 'smooth' });

  // 4. Update current filters
  if (type === 'store') {
    currentStore = element.dataset.id;
  } else if (type === 'platform') {
    currentPlatform = element.dataset.id;
  }

  // 5. Trigger QR Update
  render();
}

// ── Initialize Filters with Saved Preferences ──
function initializeFilters() {
  const { savedStore, savedPlatform } = loadSavedPreferences();
  
  // Set active states based on saved preferences using Filter Engine
  const storePills = document.querySelectorAll('[data-filter-type="primary"]');
  const platformPills = document.querySelectorAll('[data-filter-type="secondary"]');
  
  // Store filters - use saved preference or default to JP Nagar
  let storeSelected = false;
  if (savedStore) {
    storePills.forEach(pill => {
      if (pill.dataset.filterValue === savedStore) {
        pill.classList.add('is-active');
        currentStore = savedStore;
        storeSelected = true;
      }
    });
  }
  
  // If no saved store or store not found, select JP Nagar (n78)
  if (!storeSelected) {
    const jpNagarPill = document.querySelector('[data-filter-type="primary"][data-filter-value="n78"]');
    if (jpNagarPill) {
      jpNagarPill.classList.add('is-active');
      currentStore = 'n78';
    } else if (storePills.length > 0) {
      // Fallback to first store if JP Nagar not found
      storePills[0].classList.add('is-active');
      currentStore = storePills[0].dataset.filterValue;
    }
  }
  
  // Platform filters - use saved preference or default to Google Review
  let platformSelected = false;
  if (savedPlatform) {
    platformPills.forEach(pill => {
      if (pill.dataset.filterValue === savedPlatform) {
        pill.classList.add('is-active');
        currentPlatform = savedPlatform;
        platformSelected = true;
      }
    });
  }
  
  // If no saved platform or platform not found, select Google Review
  if (!platformSelected) {
    const googlePill = document.querySelector('[data-filter-type="secondary"][data-filter-value="google"]');
    if (googlePill) {
      googlePill.classList.add('is-active');
      currentPlatform = 'google';
    } else if (platformPills.length > 0) {
      // Fallback to first platform if Google not found
      platformPills[0].classList.add('is-active');
      currentPlatform = platformPills[0].dataset.filterValue;
    }
  }
  
  // Update QR display with initial selection
  updateQRDisplay();
}

// ── Event Listeners for Filter Engine ──
document.addEventListener('DOMContentLoaded', () => {
  // Listen for filter changes from the Filter Engine
  document.addEventListener('filterChanged', function(e) {
    const filterType = e.detail.type;
    const filterValue = e.detail.value;
    const element = e.detail.element;
    
    console.log('Filter changed:', filterType, filterValue);
    
    if (filterType === 'primary') {
      // Store filter changed
      currentStore = filterValue;
      localStorage.setItem('qr_pref_store', filterValue);
    } else if (filterType === 'secondary') {
      // QR type filter changed
      currentPlatform = filterValue;
      localStorage.setItem('qr_pref_platform', filterValue);
    }
    
    console.log('Switching to:', currentStore, currentPlatform);
    
    // Smart scroll positioning - ensure selected pill is fully visible
    if (element) {
      const container = element.closest('.filter-pills-container') || element.closest('.filter-engine');
      if (container) {
        const containerRect = container.getBoundingClientRect();
        const elementRect = element.getBoundingClientRect();
        
        // Check if element is partially off-screen
        const elementLeft = elementRect.left - containerRect.left;
        const elementRight = elementRect.right - containerRect.left;
        
        if (elementLeft < 0) {
          // Element is off-screen to the left
          container.scrollLeft += elementLeft - 8;
        } else if (elementRight > containerRect.width) {
          // Element is off-screen to the right
          container.scrollLeft += elementRight - containerRect.width + 8;
        }
      }
    }
    
    // Update QR display
    updateQRDisplay();
  });
  
  // Initialize filters on page load
  initializeFilters();
  
  // Initial trigger to ensure page isn't blank on startup
  setTimeout(() => {
    document.dispatchEvent(new CustomEvent('filterChanged', { 
      detail: { type: 'primary', value: currentStore } 
    }));
    document.dispatchEvent(new CustomEvent('filterChanged', { 
      detail: { type: 'secondary', value: currentPlatform } 
    }));
  }, 100);
});

// ── Helper Functions ──
function getURL(store, platform) {
  if (platform === "facebook") return store.facebook_url || store.facebook_url;
  if (platform === "instagram") return store.instagram_url || store.instagram_url;
  if (platform === "google") return store.google_review_link;
}

