<style>
body { background:#111714; color:#fff; font-family:Jost,sans-serif; margin:0; }
.qr-container{max-width:1200px;margin:auto;padding:20px 20px}
.qr-title{font-family:"Cormorant Garamond";font-size:36px;margin-bottom:8px}
.qr-title em{color:#C9A84C}
.filter-section{background:#1a1f1c;border-radius:16px;padding:16px;margin-bottom:16px}

/* Ensure Filter Engine is visible */
.filter-engine {
  display: block !important;
  visibility: visible !important;
  opacity: 1 !important;
}

/* QR Page Specific Filter Styling */
.filter-engine[data-filter-id="store-selector"] .filter-pill {
  /* Primary filters - faint gold when inactive */
  background: rgba(212, 175, 55, 0.1);
  color: rgba(255, 255, 255, 0.8);
  border: 1px solid rgba(212, 175, 55, 0.2);
}

.filter-engine[data-filter-id="store-selector"] .filter-pill.is-active {
  /* Primary filters - solid gold when active */
  background: var(--gold, #D4AF37);
  color: var(--dark, #1a1a1a);
  border-color: var(--gold, #D4AF37);
}

.filter-engine[data-filter-id="qr-selector"] .filter-pill {
  /* Secondary filters - outline style */
  background: transparent;
  border: 1px solid var(--gold, #D4AF37);
  color: rgba(255, 255, 255, 0.7);
}

.filter-engine[data-filter-id="qr-selector"] .filter-pill.is-active {
  /* Secondary filters - solid when active */
  background: var(--gold, #D4AF37);
  color: var(--dark, #1a1a1a);
  border-color: var(--gold, #D4AF37);
}

/* Mobile Row Compaction */
.filter-engine {
  white-space: nowrap;
  overflow-x: auto;
  display: flex;
  gap: 8px;
  /* Hidden scrollbars across all browsers */
  -ms-overflow-style: none;  /* IE and Edge */
  scrollbar-width: none;     /* Firefox */
}

.filter-engine::-webkit-scrollbar {
  display: none;  /* Chrome, Safari and Opera */
}

.filter-pills-container {
  white-space: nowrap;
  overflow-x: auto;
  display: flex;
  gap: 8px;
  padding: 4px 0;
  /* Hidden scrollbars across all browsers */
  -ms-overflow-style: none;  /* IE and Edge */
  scrollbar-width: none;     /* Firefox */
}

.filter-pills-container::-webkit-scrollbar {
  display: none;  /* Chrome, Safari and Opera */
}

/* Visual spacing between filter rows */
.filter-engine[data-filter-id="qr-selector"] {
  margin-top: 4px;
}

/* QR Image scaling for one-screen UI */
.qr-card img {
  width: 180px;
  height: 180px;
  object-fit: contain;
  max-height: 35vh;
}

.qr-grid{display:grid;grid-template-columns:1fr;gap:24px}
.qr-card{background:#1a1f1c;border-radius:16px;padding:20px;text-align:center}
.qr-card-title{font-weight:600;margin-top:12px}
.qr-card-subtitle{color:#C9A84C;font-size:12px;text-transform:uppercase}
.qr-actions{display:flex;gap:10px;margin-top:16px;flex-direction:row}
.btn{flex:1;padding:10px;border-radius:6px;border:none;cursor:pointer;font-size:12px;font-weight:600}

.filter-header {
