{% from "macros.j2" import theme_vars, theme_init_script, button_css, footer_css, google_analytics, favicon_tags %}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {{ favicon_tags() }}

    <!-- Google Analytics -->
    {{ google_analytics() }}

    {% if is_filled %}
    <title>{{ job.job_title }} – Position Filled | Naturals Salon {{ store.display_name }}, Bangalore</title>
    <meta name="robots" content="noindex, follow">
    {% else %}
    <title>{{ seo_title | default('Job Opening: ' + job.job_title + ' at Naturals ' + store.display_name + ' | Bangalore') }}</title>
    <meta name="robots" content="index, follow">
    {% endif %}

    <meta name="description" content="{{ meta_description | default('Hiring ' + job.job_title + ' at Naturals Salon, ' + store.display_name + ', Bangalore. Apply directly via phone — no portal needed.') }}">
    <link rel="canonical" href="{{ canonical_url | default(website_base_url + '/careers/' + city_slug + '/' + store.slug + '/' + job.job_slug + '/') }}">
    <meta property="og:title" content="{{ seo_title | default(job.job_title + ' Job in ' + store.display_name + ', Bangalore | Naturals Salon') }}">
    <meta property="og:description" content="Hiring {{ job.job_title }} at Naturals Salon {{ store.display_name }}, Bangalore. Apply directly via phone.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ website_base_url }}/careers/{{ city_slug }}/{{ store.slug }}/{{ job.job_slug }}/">
    <meta property="og:image" content="{{ website_base_url }}{{ og_image | default('/images/stores/' + store.slug + '/cover.jpg') }}">
    <meta name="whatsapp-msg" content="{{ whatsapp_msg | default('') }}">
    <script type="application/ld+json">{"@context":"https://schema.org","@type":"{{ schema_type | default('JobPosting') }}","name":"{{ job.job_title }}","url":"{{ website_base_url }}/careers/{{ city_slug }}/{{ store.slug }}/{{ job.job_slug }}/"}</script>

    {% if not is_filled %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "JobPosting",
      "title": "{{ job.job_title }}",
      "description": "Join our 5-star team in {{ store.display_name }}. {{ job.job_summary | striptags | replace('"', '\\"') | replace('\n', ' ') }}",
      "datePosted": "{{ job.date_posted if job.date_posted else '2026-03-23' }}",
      "validThrough": "{{ job.valid_through if job.valid_through else '2026-06-30' }}T00:00",
      "employmentType": "{{ job.employment_type | upper | replace(' ', '_') | replace('-', '_') if job.employment_type else 'FULL_TIME' }}",
      "directApply": true,
      "hiringOrganization": {
        "@type": "Organization",
        "name": "Naturals Salon & Spa {{ store.display_name }}",
        "sameAs": "{{ website_base_url }}/",
        "logo": "{{ website_base_url }}/images/logo.jpg"
      },
      "jobLocation": {
        "@type": "Place",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "{{ store.address_line_1 | default(store.street_address) | replace('"', '\\"') }}",
          "addressLocality": "{{ store.display_name }}",
          "addressRegion": "Karnataka",
          "postalCode": "{{ store.address_pincode | default(store.postal_code) }}",
          "addressCountry": "IN"
        }{% if store.latitude and store.longitude %},
        "geo": { "@type": "GeoCoordinates", "latitude": {{ store.latitude }}, "longitude": {{ store.longitude }} }
        {% endif %}
      }{% if job.salary_min or job.salary_max %},
      "baseSalary": {
        "@type": "MonetaryAmount", "currency": "INR",
        "value": { "@type": "QuantitativeValue",
          {% if job.salary_min %}"minValue": {{ job.salary_min }},{% endif %}
          {% if job.salary_max %}"maxValue": {{ job.salary_max }},{% endif %}
          "unitText": "MONTH" }
      }{% endif %},
      "industry": "Beauty & Personal Care",
      "occupationalCategory": "Salon & Spa Professional"
    }
    </script>
    {% endif %}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
    {{ theme_init_script() }}
    {{ button_css() }}
    {{ footer_css() }}
    <style>
        {{ theme_vars() }}

        html, body { margin: 0; padding: 0; }
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Jost', sans-serif; background: var(--cream); color: var(--text); overflow-x: hidden; }
        a { text-decoration: none; color: inherit; }
        img { display: block; max-width: 100%; }

        /* ── HAMBURGER FIX ── */
        #hamburger, #hamburger.hamburger-btn, button#hamburger {
            display: flex !important; visibility: visible !important; opacity: 1 !important;
        }

        /* ── Hero ── */
        .careers-hero {
            position: relative; width: 100%; min-height: 300px;
            display: flex; align-items: flex-end; overflow: hidden;
        }
        .careers-hero-bg { position: absolute; inset: 0; background: var(--dark); }
        .careers-hero-bg img { width: 100%; height: 100%; object-fit: cover; display: block; }
        .careers-hero-ov { position: absolute; inset: 0; background: linear-gradient(135deg, var(--hero-tint) 0%, var(--hero-tint2) 60%, rgba(0,0,0,0.12) 100%); }
        .careers-hero-inner {
            position: relative; z-index: 2; padding: 36px 60px;
            max-width: 1200px; width: 100%; margin: 0 auto; color: #fff;
        }
        .careers-hero-inner h1 {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(26px,4vw,48px); font-weight: 300;
            color: #fff; line-height: 1.1; margin: 8px 0 10px;
        }
        .careers-hero-inner h1 em { font-style: italic; color: var(--gold); }
        .hero-sub { font-size: 13px; color: rgba(255,255,255,0.65); }
        {% if is_filled %}
        .filled-ribbon { display: inline-block; background: rgba(220,50,50,0.85); color: #fff; font-size: 11px; letter-spacing: 1.5px; text-transform: uppercase; padding: 4px 14px; border-radius: 20px; margin-bottom: 14px; }
        {% endif %}

        /* ── Breadcrumb + Share bar ── */
        .meta-bar {
            max-width: 900px; margin: 0 auto;
            padding: 14px 20px 0;
            display: flex; align-items: center; justify-content: space-between;
            flex-wrap: wrap; gap: 10px;
        }
        .breadcrumbs {
            font-size: 11px; color: var(--text-light);
            display: flex; flex-wrap: wrap; gap: 6px; align-items: center;
        }
        .breadcrumbs a { color: var(--text-mid); transition: color 0.2s; }
        .breadcrumbs a:hover { color: var(--gold); }
        .breadcrumbs .sep { opacity: 0.4; }
        .breadcrumbs .current { color: var(--text); font-weight: 500; }
        .share-save {
            display: flex; gap: 8px; align-items: center; flex-shrink: 0;
        }
        .share-btn, .save-btn {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 6px 14px; border-radius: 20px; font-size: 11px;
            font-family: 'Jost', sans-serif; font-weight: 600;
            letter-spacing: 0.5px; cursor: pointer; transition: all 0.2s;
            border: 1px solid rgba(0,0,0,0.12); background: #fff;
            color: var(--text-mid);
        }
        .share-btn:hover { border-color: var(--gold); color: var(--gold); }
        .save-btn:hover  { border-color: var(--green-mid); color: var(--green-mid); }
        .share-btn.copied { border-color: var(--green-soft); color: var(--green-soft); }

        /* ── Page wrap ── */
        .page-wrap { max-width: 900px; margin: 0 auto; padding: 16px 20px 100px; }

        /* ── Filled banner ── */
        .filled-banner { background: #7f1d1d; border-radius: 12px; padding: 20px 24px; margin-bottom: 24px; display: flex; align-items: flex-start; gap: 14px; }
        .filled-banner .fb-icon { font-size: 1.5rem; flex-shrink: 0; }
        .filled-banner h2 { font-family: 'Cormorant Garamond', serif; font-size: 22px; color: #fff; margin-bottom: 6px; }
        .filled-banner p { font-size: 13px; color: rgba(255,255,255,0.75); line-height: 1.7; margin-bottom: 14px; }

        /* ── WHY WORK HERE ── */
        .why-work-here {
            background: var(--dark); border-radius: 16px;
            padding: 32px; margin-bottom: 24px;
            border: 1px solid rgba(255,255,255,0.06);
        }
        [data-theme="naturals"] .why-work-here { background: #1A0533; }
        .why-work-here .ww-title {
            font-family: 'Cormorant Garamond', serif; font-size: 22px;
            color: var(--gold); margin-bottom: 20px; font-weight: 400;
        }
        .ww-grid {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(160px,1fr)); gap: 14px;
        }
        .ww-item {
            background: rgba(255,255,255,0.06); border-radius: 10px;
            padding: 16px; border: 1px solid rgba(255,255,255,0.08);
            display: flex; flex-direction: column; gap: 8px;
        }
        .ww-icon { font-size: 1.6rem; }
        .ww-label { font-size: 12px; font-weight: 600; color: #fff; line-height: 1.3; }
        .ww-desc { font-size: 11px; color: rgba(255,255,255,0.5); line-height: 1.5; }

        /* ── Section cards ── */
        .job-detail { display: flex; flex-direction: column; gap: 20px; }
        .section-card {
            background: #fff; border-radius: 14px; padding: 32px;
            border: 1px solid rgba(0,0,0,0.06); box-shadow: 0 4px 16px rgba(0,0,0,0.04);
        }
        .section-card h2 {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(20px,2.5vw,26px); font-weight: 400; color: var(--text);
            margin-bottom: 20px; padding-bottom: 14px; border-bottom: 1px solid rgba(0,0,0,0.07);
        }

        /* ── Overview grid ── */
        .overview-grid { display: grid; grid-template-columns: repeat(auto-fit,minmax(160px,1fr)); gap: 12px; }
        .overview-item {
            display: flex; gap: 10px; align-items: flex-start;
            background: var(--cream); border-radius: 10px; padding: 14px 16px;
            border: 1px solid rgba(0,0,0,0.05);
        }
        .overview-item .oi-icon { font-size: 1.3rem; flex-shrink: 0; }
        .overview-item .oi-label { font-size: 10px; text-transform: uppercase; letter-spacing: 1.5px; color: var(--text-light); font-weight: 600; margin-bottom: 4px; }
        .overview-item .oi-value { font-size: 14px; font-weight: 500; color: var(--text); }

        /* ── Content lists ── */
        .summary-content p { font-size: 14px; line-height: 1.85; color: var(--text-mid); }
        .content-list { padding-left: 20px; }
        .content-list li { font-size: 14px; margin-bottom: 8px; line-height: 1.7; color: var(--text-mid); }

        /* ── Salary ── */
        .salary-benefits-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; }
        .sub-heading { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 400; color: var(--text); margin-bottom: 14px; }
        .salary-range { display: flex; align-items: baseline; gap: 6px; flex-wrap: wrap; }
        .salary-range .s-currency { font-size: 16px; color: var(--text-light); }
        .salary-range .s-amount { font-family: 'Cormorant Garamond', serif; font-size: 36px; font-weight: 300; color: var(--gold); }
        .salary-range .s-period { font-size: 12px; color: var(--text-light); }
        .salary-disclosure { font-size: 13px; color: var(--text-mid); font-style: italic; }
        .benefits-list { display: flex; flex-direction: column; gap: 10px; }
        .benefit-row { display: flex; gap: 12px; align-items: flex-start; padding: 10px 14px; background: var(--cream); border-radius: 8px; border: 1px solid rgba(0,0,0,0.05); }
        .benefit-row .br-icon { font-size: 1.1rem; flex-shrink: 0; }
        .benefit-row .br-label { font-size: 10px; text-transform: uppercase; letter-spacing: 1px; color: var(--text-light); margin-bottom: 2px; }
        .benefit-row .br-value { font-size: 13px; font-weight: 500; color: var(--text); }

        /* ── Interview ── */
        .interview-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
        .interview-item { background: var(--cream); border-radius: 10px; padding: 16px 18px; border: 1px solid rgba(0,0,0,0.05); }
        .interview-item .ii-label { font-size: 10px; text-transform: uppercase; letter-spacing: 1.5px; color: var(--gold); font-weight: 600; margin-bottom: 6px; }
        .interview-item .ii-value { font-size: 15px; font-weight: 500; color: var(--text); }

        /* ── HOW TO APPLY ── */
        .apply-intro-text {
            font-size: 14px; color: var(--text-mid); line-height: 1.8; margin-bottom: 24px;
        }
        /* Primary CTA row — Call + WhatsApp side by side */
        .apply-primary-cta {
            display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 20px;
        }
        .apply-primary-cta .btn-call,
        .apply-primary-cta .btn-wa {
            flex: 1;
            min-width: 140px;
            justify-content: center;
            display: inline-flex;
            text-align: center;
        }

        /* Self-contained apply buttons — not dependent on button_css() macro */
        .apply-btn {
            display: inline-flex; align-items: center; justify-content: center;
            gap: 8px; flex: 1; min-width: 140px;
            padding: 14px 20px; min-height: 48px;
            border-radius: 6px; border: none; cursor: pointer;
            font-family: 'Jost', sans-serif; font-size: 11px;
            font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase;
            text-decoration: none; transition: all 0.25s; white-space: nowrap;
        }
        .apply-btn-call {
            background: #5F6368; color: #fff;
        }
        .apply-btn-call:hover { background: #474c52; transform: translateY(-1px); }
        .apply-btn-wa {
            background: #25D366; color: #fff;
        }
        .apply-btn-wa:hover { background: #1da851; transform: translateY(-1px); }
        /* Email button — full width, less dominant than phone */
        .apply-email-btn {
            display: flex; align-items: center; justify-content: center; gap: 8px;
            width: 100%; padding: 12px 20px; border-radius: 6px;
            background: #fff; border: 1.5px solid rgba(0,0,0,0.14);
            color: var(--text); font-family: 'Jost', sans-serif;
            font-size: 11px; font-weight: 600; letter-spacing: 1.5px;
            text-transform: uppercase; text-decoration: none;
            transition: all 0.25s; margin-bottom: 20px;
        }
        .apply-email-btn:hover { border-color: var(--gold); color: var(--gold); }
        /* Secondary phone — small, less prominent */
        .apply-secondary-phone {
            display: flex; align-items: center; gap: 8px;
            font-size: 12px; color: var(--text-mid); padding: 10px 0;
            border-top: 1px solid rgba(0,0,0,0.07);
        }
        .apply-secondary-phone a { color: var(--green-mid); font-weight: 600; }
        .apply-secondary-phone a:hover { color: var(--gold); }
        /* Visit salon box */
        .visit-box {
            background: var(--cream); border-radius: 10px; padding: 18px 20px;
            border: 1px solid rgba(0,0,0,0.06); margin-top: 24px;
        }
        .visit-box-title { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 400; color: var(--text); margin-bottom: 10px; }
        .visit-box p { font-size: 13px; line-height: 1.75; color: var(--text-mid); margin-bottom: 4px; }
        .visit-box strong { color: var(--text); }
        .maps-btn { display: inline-flex; align-items: center; gap: 6px; margin-top: 12px; color: var(--gold); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; font-weight: 600; transition: color 0.2s; }
        .maps-btn:hover { color: var(--green); }



        /* ── Sticky CTA — Call + WhatsApp ── */
        .sticky-cta {
            display: none; position: fixed; bottom: 0; left: 0; right: 0;
            z-index: 9000; padding: 10px 16px;
            background: var(--dark); border-top: 1px solid rgba(255,255,255,0.08);
        }
        [data-theme="naturals"] .sticky-cta { background: #1A0533; }
        .sticky-cta-inner { display: flex; gap: 10px; }
        .sticky-cta-inner .apply-btn {
            flex: 1;
            font-size: 11px !important;
            padding: 12px 10px !important;
            min-height: 44px !important;
            letter-spacing: 1px !important;
        }
        @media (max-width: 992px) { .sticky-cta { display: block; } }

        @media (max-width: 768px) {
            .careers-hero-inner { padding: 28px 20px; }
            .meta-bar { padding: 12px 16px 0; }
            .page-wrap { padding: 12px 16px 100px; }
            .section-card { padding: 22px 18px; }
            .salary-benefits-grid, .interview-grid { grid-template-columns: 1fr; }
            .ww-grid { grid-template-columns: 1fr 1fr; }
            .share-save { width: 100%; }
        }
        @media (max-width: 480px) {
            .ww-grid { grid-template-columns: 1fr; }
            .apply-primary-cta { flex-direction: column; }
            .apply-primary-cta .apply-btn { flex: none; width: 100%; }
        }
    </style>
</head>
<body>
    {% include 'header.j2' %}

    {# ── Hero — no back link, just job title + store ── #}
    <section class="careers-hero">
        <div class="careers-hero-bg">
            <img id="hero-img"
                 src="{{ website_base_url }}/images/careers/store-{{ store.slug }}.jpg"
                 alt="{{ job.job_title }} at Naturals Salon {{ store.display_name }}, {{ store.display_name }}, Bangalore"
                 loading="eager">
        </div>
        <div class="careers-hero-ov"></div>
        <div class="careers-hero-inner">
            {% if is_filled %}<div class="filled-ribbon">Position Filled</div>{% endif %}
            <div class="lbl">Join Our Team · {{ store.display_name }}</div>
            <h1>{{ h1_heading | default('<em>' + job.job_title + '</em> at Naturals Salon &amp; Spa, ' + store.display_name) }}</h1>
            <p class="hero-sub">{{ store.display_name }} · {{ store.display_name }}, Bangalore</p>
        </div>
    </section>

    {# ── Breadcrumbs + Share/Save ── #}
    <div class="meta-bar">
        <nav class="breadcrumbs" aria-label="Breadcrumb">
            <a href="{{ website_base_url }}/">Home</a><span class="sep">›</span>
            <a href="{{ website_base_url }}/careers/{{ city_slug }}/">Join Our Team</a><span class="sep">›</span>
            <a href="{{ website_base_url }}/careers/{{ city_slug }}/">Bangalore</a><span class="sep">›</span>
            <a href="{{ website_base_url }}/careers/{{ city_slug }}/{{ store.slug }}/">{{ store.display_name }}</a><span class="sep">›</span>
            <span class="current">{{ job.job_title }}</span>
        </nav>
        <div class="share-save">
            <button class="share-btn" id="share-btn" onclick="shareJob()" title="Share this job">
                🔗 Share
            </button>
            <button class="save-btn" id="save-btn" onclick="saveJob()" title="Save job">
                🔖 Save
            </button>
        </div>
    </div>

    <div class="page-wrap">

        {% if is_filled %}
        <div class="filled-banner">
            <div class="fb-icon">🔒</div>
            <div>
                <h2>This Position Has Been Filled</h2>
                <p>We're no longer accepting applications for this role at {{ store.display_name }}. But we're always growing — explore other open positions in Bangalore.</p>
                <a href="{{ website_base_url }}/careers/{{ city_slug }}/" class="btn-primary">View All Bangalore Jobs</a>
            </div>
        </div>
        {% endif %}

        {# ── WHY WORK HERE — shown only for active jobs ── #}
        {% if not is_filled %}
        <div class="why-work-here">
            <div class="ww-title">✨ Why Join Naturals Salon &amp; Spa?</div>
            <div class="ww-grid">
                <div class="ww-item">
                    <div class="ww-icon">🎓</div>
                    <div class="ww-label">Free Training</div>
                    <div class="ww-desc">Ongoing skill development & certification programs</div>
                </div>
                <div class="ww-item">
                    <div class="ww-icon">💰</div>
                    <div class="ww-label">Competitive Pay</div>
                    <div class="ww-desc">Salary + performance incentives + tips</div>
                </div>
                <div class="ww-item">
                    <div class="ww-icon">📈</div>
                    <div class="ww-label">Career Growth</div>
                    <div class="ww-desc">Clear path to senior & management roles</div>
                </div>
                <div class="ww-item">
                    <div class="ww-icon">🤝</div>
                    <div class="ww-label">Great Team</div>
                    <div class="ww-desc">Supportive colleagues & experienced mentors</div>
                </div>
                <div class="ww-item">
                    <div class="ww-icon">🏆</div>
                    <div class="ww-label">Trusted Brand</div>
                    <div class="ww-desc">India's fastest growing salon chain — 25+ years</div>
                </div>
                <div class="ww-item">
                    <div class="ww-icon">📍</div>
                    <div class="ww-label">{{ store.display_name }}</div>
                    <div class="ww-desc">Convenient location with good transport access</div>
                </div>
            </div>
        </div>
        {% endif %}

        <main class="job-detail">

            {# 1. About This Role #}
            <section class="section-card">
                <h2>About This Role</h2>
                <div class="summary-content"><p>{{ job.job_summary | safe }}</p></div>
            </section>

            {# 2. Job Overview #}
            <section class="section-card">
                <h2>Job Overview</h2>
                <div class="overview-grid">
                    {% if job.experience_min_years or job.experience_max_years %}
                    <div class="overview-item"><div class="oi-icon">📋</div><div><div class="oi-label">Experience</div><div class="oi-value">{% if job.experience_min_years and job.experience_max_years %}{{ job.experience_min_years }}–{{ job.experience_max_years }} yrs{% elif job.experience_min_years %}{{ job.experience_min_years }}+ yrs{% else %}Up to {{ job.experience_max_years }} yrs{% endif %}</div></div></div>
                    {% endif %}
                    {% if job.vacancies %}<div class="overview-item"><div class="oi-icon">👥</div><div><div class="oi-label">Vacancies</div><div class="oi-value">{{ job.vacancies }} position(s)</div></div></div>{% endif %}
                    {% if job.employment_type %}<div class="overview-item"><div class="oi-icon">💼</div><div><div class="oi-label">Employment Type</div><div class="oi-value">{{ job.employment_type }}</div></div></div>{% endif %}
                    {% if job.gender_preference %}<div class="overview-item"><div class="oi-icon">👤</div><div><div class="oi-label">Gender Preference</div><div class="oi-value">{{ job.gender_preference }}</div></div></div>{% endif %}
                    {% if job.languages_required %}<div class="overview-item"><div class="oi-icon">🌍</div><div><div class="oi-label">Languages</div><div class="oi-value">{{ job.languages_required }}</div></div></div>{% endif %}
                    {% if job.weekly_off %}<div class="overview-item"><div class="oi-icon">📅</div><div><div class="oi-label">Weekly Off</div><div class="oi-value">{{ job.weekly_off }}</div></div></div>{% endif %}
                </div>
            </section>

            {# 3. Responsibilities #}
            {% if job.responsibilities %}
            <section class="section-card">
                <h2>Responsibilities</h2>
                <ul class="content-list">{% for item in job.responsibilities.split('\n') %}{% if item.strip() %}<li>{{ item.strip() }}</li>{% endif %}{% endfor %}</ul>
            </section>
            {% endif %}

            {# 4. Requirements & Eligibility #}
            {% if job.requirements %}
            <section class="section-card">
                <h2>Requirements &amp; Eligibility</h2>
                <ul class="content-list">{% for item in job.requirements.split('\n') %}{% if item.strip() %}<li>{{ item.strip() }}</li>{% endif %}{% endfor %}</ul>
            </section>
            {% endif %}

            {# 5. Salary & Benefits #}
            <section class="section-card">
                <h2>Salary &amp; Benefits</h2>
                <div class="salary-benefits-grid">
                    <div>
                        <div class="sub-heading">Compensation</div>
                        {% if job.salary_min or job.salary_max %}
                        <div class="salary-range">
                            <span class="s-currency">₹</span>
                            {% if job.salary_min and job.salary_max %}<span class="s-amount">{{ job.salary_min }}–{{ job.salary_max }}</span>
                            {% elif job.salary_min %}<span class="s-amount">{{ job.salary_min }}+</span>
                            {% else %}<span class="s-amount">Up to {{ job.salary_max }}</span>{% endif %}
                            <span class="s-period">/ month</span>
                        </div>
                        {% else %}<p class="salary-disclosure">Competitive salary based on experience and qualifications.</p>{% endif %}
                    </div>
                    <div>
                        <div class="sub-heading">Perks &amp; Benefits</div>
                        <div class="benefits-list">
                            {% if job.accommodation and job.accommodation|lower not in ('no','none','') %}<div class="benefit-row"><div class="br-icon">🏠</div><div><div class="br-label">Accommodation</div><div class="br-value">{{ job.accommodation }}</div></div></div>{% endif %}
                            {% if job.food_provided and job.food_provided|lower not in ('no','none','') %}<div class="benefit-row"><div class="br-icon">🍽</div><div><div class="br-label">Food</div><div class="br-value">{{ job.food_provided }}</div></div></div>{% endif %}
                            {% if job.incentives %}<div class="benefit-row"><div class="br-icon">🎁</div><div><div class="br-label">Incentives</div><div class="br-value">{{ job.incentives }}</div></div></div>{% endif %}
                            {% if job.other_benefits %}<div class="benefit-row"><div class="br-icon">✨</div><div><div class="br-label">Additional</div><div class="br-value">{{ job.other_benefits | safe }}</div></div></div>{% endif %}
                        </div>
                    </div>
                </div>
            </section>

            {# 6. Interview Information #}
            {% if job.interview_days or job.interview_timings %}
            <section class="section-card">
                <h2>Interview Information</h2>
                <div class="interview-grid">
                    {% if job.interview_days %}<div class="interview-item"><div class="ii-label">Interview Days</div><div class="ii-value">{{ job.interview_days }}</div></div>{% endif %}
                    {% if job.interview_timings %}<div class="interview-item"><div class="ii-label">Interview Timings</div><div class="ii-value">{{ job.interview_timings }}</div></div>{% endif %}
                </div>
            </section>
            {% endif %}

            {# 7. How to Apply #}
            {% if not is_filled %}
            <section class="section-card">
                <h2>How to Apply</h2>
                <p class="apply-intro-text">
                    Ready to join Naturals Salon &amp; Spa in {{ store.display_name }}, Bangalore?
                    Apply directly — no job portal or resume upload required.
                    Just call or WhatsApp our hiring team to get started today.
                </p>

                {# Collect contact details from careers job data #}
                {% set phone1 = job.contact_phone_1 if job.contact_phone_1 else '' %}
                {% set phone2 = job.contact_phone_2 if job.contact_phone_2 else '' %}
                {% set email  = job.contact_email   if job.contact_email   else '' %}

                {# Primary: Call + WhatsApp using phone_1 #}
                {% if phone1 %}
                <div class="apply-primary-cta">
                    <a href="tel:{{ phone1 }}" class="apply-btn apply-btn-call">
                        📞 Call to Apply
                    </a>
                    <a href="https://wa.me/{{ phone1.replace(' ', '').replace('-', '') }}" target="_blank" rel="noopener" class="apply-btn apply-btn-wa">
                        💬 WhatsApp Us
                    </a>
                </div>
                {% endif %}

                {# Email — prominent button if available #}
                {% if email %}
                <a href="mailto:{{ email }}" class="apply-email-btn">
                    📧 Email Us — {{ email }}
                </a>
                {% endif %}

                {# Secondary phone — small, less prominent #}
                {% if phone2 and phone2 != phone1 %}
                <div class="apply-secondary-phone">
                    <span>Also available:</span>
                    <a href="tel:{{ phone2 }}">📞 {{ phone2 }}</a>
                </div>
                {% endif %}

                {# Visit salon box #}
                <div class="visit-box">
                    <div class="visit-box-title">🏪 Visit the Salon</div>
                    <p><strong>{{ store.name or store.display_name }}</strong></p>
                    <p>{{ store.display_name }}, Bangalore</p>
                    {% if store.street_address %}<p style="margin-top:6px;font-size:12px;color:var(--text-light);">{{ store.street_address }}</p>{% endif %}
                    {% if store.mon_fri_hours %}<p style="margin-top:6px;font-size:12px;">🕐 {{ store.mon_fri_hours }}</p>{% endif %}
                    {% if store.google_maps_url %}<a href="{{ store.google_maps_url }}" target="_blank" rel="noopener" class="maps-btn">📌 Get Directions →</a>{% endif %}
                </div>
            </section>

            {% else %}
            {# Filled job CTA #}
            <section class="section-card" style="text-align:center;padding:40px;">
                <h2 style="border:none;padding:0;margin-bottom:12px;">Explore Other Openings</h2>
                <p style="font-size:14px;color:var(--text-mid);margin-bottom:24px;">This role has been filled, but we have other exciting positions across Bangalore.</p>
                <a href="{{ website_base_url }}/careers/{{ city_slug }}/" class="btn-primary">View All Bangalore Jobs</a>
            </section>
            {% endif %}



        </main>
    </div>

    {# footer.j2 — no changes #}
    {% include 'footer.j2' %}

    {# Sticky CTA — Call + WhatsApp in site standard style #}
    {% if not is_filled %}
    {% set _phone = job.contact_phone_1 if job.contact_phone_1 else '' %}
    {% if _phone %}
    <div class="sticky-cta" aria-label="Apply for this job">
        <div class="sticky-cta-inner">
            <a href="tel:{{ _phone }}" class="apply-btn apply-btn-call">📞 Call to Apply</a>
            <a href="https://wa.me/{{ _phone.replace(' ', '').replace('-', '') }}" target="_blank" rel="noopener" class="apply-btn apply-btn-wa">💬 WhatsApp</a>
        </div>
    </div>
    {% endif %}
    {% endif %}

    <script>
    (function(){
        /* Hero image fallback */
        var img = document.getElementById('hero-img');
        if (img) {
            var fallback = '{{ website_base_url }}/images/careers/default.jpg';
            var tried = false;
            img.onerror = function(){
                if (!tried) { tried = true; img.src = fallback; }
                else { img.style.display = 'none'; }
            };
        }

        /* Share job — copies URL to clipboard */
        window.shareJob = function(){
            var url = window.location.href;
            if (navigator.clipboard) {
                navigator.clipboard.writeText(url).then(function(){
                    var btn = document.getElementById('share-btn');
                    if (btn) {
                        btn.textContent = '✅ Copied!';
                        btn.classList.add('copied');
                        setTimeout(function(){ btn.textContent = '🔗 Share'; btn.classList.remove('copied'); }, 2000);
                    }
                });
            } else {
                /* Fallback for older browsers */
                var ta = document.createElement('textarea');
                ta.value = url;
                document.body.appendChild(ta);
                ta.select();
                document.execCommand('copy');
                document.body.removeChild(ta);
                var btn = document.getElementById('share-btn');
                if (btn) { btn.textContent = '✅ Copied!'; setTimeout(function(){ btn.textContent = '🔗 Share'; }, 2000); }
            }
        };

        /* Save job — placeholder (stores in localStorage) */
        window.saveJob = function(){
            var key = 'saved_job_{{ job.job_id }}';
            var btn = document.getElementById('save-btn');
            if (!btn) return;
            var saved = localStorage.getItem(key);
            if (saved) {
                localStorage.removeItem(key);
                btn.textContent = '🔖 Save';
            } else {
                localStorage.setItem(key, JSON.stringify({
                    title: '{{ job.job_title }}',
                    store: '{{ store.display_name }}',
                    url: window.location.href,
                    saved_at: new Date().toISOString()
                }));
                btn.textContent = '✅ Saved';
            }
        };

        /* Restore save state on load */
        (function(){
            var key = 'saved_job_{{ job.job_id }}';
            if (localStorage.getItem(key)) {
                var btn = document.getElementById('save-btn');
                if (btn) btn.textContent = '✅ Saved';
            }
        })();
    })();
    </script>
</body>
</html>
