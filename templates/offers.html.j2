{# build/templates/offers.html.j2 #}
{% from "macros.j2" import full_footer, footer_css, wa_svg, fb_svg, ig_svg, theme_vars, theme_toggle, theme_init_script, button_css,
   store_picker_modal, store_picker_js, sticky_mobile_bar, tracking_head, tracking_body, page_hero, hero_resolver, hero_css, google_analytics, favicon_tags %}
{% from "action_buttons.j2" import action_buttons_css, action_buttons_js %}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
{{ favicon_tags() }}

{{ google_analytics() }}

<link rel="canonical" href="{{ canonical_url | default(site_url + '/offers/') }}">
<meta name="description" content="{{ meta_description | default('Save on luxury hair styling, coloring, and skin care. View the latest beauty deals at our JP Nagar, Hennur, Devasandra, and Bangalore locations.') }}">
<title>{{ seo_title | default('Exclusive Salon Offers &amp; Deals in Bangalore') }}</title>
<meta property="og:type" content="website">
<meta property="og:title" content="{{ seo_title | default('Exclusive Salon Offers &amp; Deals in Bangalore') }}">
<meta property="og:description" content="{{ meta_description | default('') }}">
<meta property="og:image" content="{{ website_base_url }}{{ og_image | default('/images/og/og-offers.jpg') }}">
<meta property="og:url" content="{{ canonical_url | default(website_base_url + '/offers/') }}">
<meta property="og:site_name" content="Naturals Salon &amp; Spa Bangalore">
<meta name="whatsapp-msg" content="{{ whatsapp_msg | default('') }}">
<link rel="preconnect" href="https://fonts.googleapis.com">
{{ tracking_head(gtm_id, pixel_id) }}
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
{{ theme_init_script() }}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "{{ schema_type | default('CollectionPage') }}",
  "name": "{{ seo_title | default('Naturals Elite Bangalore - All Store Offers') }}",
  "description": "{{ meta_description | default('Explore exclusive beauty and hair care deals across our ' + stores | length | string + ' elite locations in Bangalore. Find the best offers near you.') }}",
  "url": "{{ canonical_url | default(website_base_url + '/offers/') }}",
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": {{ stores | length }},
    "itemListElement": [
      {% for s in stores %}
      {% set store_slug = s.store_display_name | lower | replace(' ', '-') | replace('&', 'and') %}
      {
        "@type": "ListItem",
        "position": {{ loop.index }},
        "name": "{{ s.store_display_name }} Offers",
        "url": "{{ website_base_url }}/stores/bangalore/{{ store_slug }}/offers/"
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "{{ website_base_url }}"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Offers",
        "item": "{{ website_base_url }}/offers/"
      }
    ]
  }
}
</script>

<style>
{{ theme_vars() }}
{{ hero_css() }}
*{margin:0;padding:0;box-sizing:border-box;}html{scroll-behavior:smooth;}
body{font-family:'Jost',sans-serif;background:var(--cream);color:var(--text);}
a{text-decoration:none;color:inherit;}img{display:block;width:100%;object-fit:cover;}

/* ── Filter Bar ── */
.filter-bar{background:var(--filter-bg);padding:15px 60px;position:sticky;top:70px;z-index:100;border-bottom:1px solid rgba(255,255,255,0.06);min-height:60px;}
.filter-row{display:flex;align-items:center;gap:15px;width:100%;flex-wrap:wrap;}
.filter-group.store-group{display:flex;flex-wrap:wrap;gap:8px;flex:1;}
.filter-lbl{font-size:9px;letter-spacing:1.5px;text-transform:uppercase;font-weight:600;color:var(--green-soft);white-space:nowrap;margin-right:3px;}
.f-btn{background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.4);padding:6px 14px;font-size:11px;letter-spacing:1px;text-transform:uppercase;cursor:pointer;transition:all 0.25s;font-family:'Jost',sans-serif;font-weight:500;border-radius:10px;}
.f-btn:hover{border-color:rgba(255,255,255,0.3);color:#fff;}
.f-btn.active{background:var(--gold);border-color:var(--gold);color:var(--dark);font-weight:600;}
[data-theme="naturals"] .f-btn.active{background:var(--green-mid);border-color:var(--green-mid);color:#fff;}

/* ── Results bar ── */
.results-bar{background:var(--cream);padding:14px 60px;border-bottom:1px solid rgba(0,0,0,0.06);font-size:13px;color:var(--text-light);}

/* ── Offers layout ── */
.offers-main{padding:40px 60px;}
.offers-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
@media(max-width:900px){.offers-grid{grid-template-columns:1fr 1fr;}}
@media(max-width:600px){.offers-grid{grid-template-columns:1fr;}}

/* ── Card ── */
.offer-card{background:#fff;overflow:hidden;transition:box-shadow 0.25s,transform 0.25s;border:1px solid rgba(0,0,0,0.06);min-height:360px;display:flex;flex-direction:column;border-radius:14px;}
.offer-card:hover{box-shadow:0 10px 34px rgba(0,0,0,0.10);transform:translateY(-2px);}
.offer-media{height:200px;position:relative;background:linear-gradient(135deg,var(--dark) 0%,var(--green) 100%);overflow:hidden;}
.offer-media img{width:100%;height:100%;object-fit:cover;transition:transform 0.7s ease;cursor:zoom-in;}
.offer-card:hover .offer-media img{transform:scale(1.04);}
.ribbon{position:absolute;top:14px;left:14px;z-index:2;background:rgba(201,168,76,0.92);color:var(--dark);font-size:9px;letter-spacing:2px;text-transform:uppercase;font-weight:800;padding:7px 10px;border-radius:999px;box-shadow:0 8px 18px rgba(0,0,0,0.18);}
.ribbon.urgent{background:rgba(217,48,37,0.92);color:#fff;}
.ribbon.new{background:rgba(26,115,232,0.92);color:#fff;}
.offer-body{padding:18px 18px 16px;display:flex;flex-direction:column;flex:1;}
.offer-badge{font-size:9px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);font-weight:700;margin-bottom:8px;}
.offer-title{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:400;margin-bottom:8px;color:var(--text);line-height:1.2;}
.offer-details{font-size:12px;color:var(--text-mid);line-height:1.7;font-weight:300;margin-bottom:12px;}
.offer-details.clamp{display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden;}
.offer-more{display:inline-flex;gap:6px;align-items:center;font-size:11px;color:var(--green-mid);cursor:pointer;margin-top:-6px;margin-bottom:12px;}
.offer-more:hover{text-decoration:underline;}
.offer-footer{margin-top:auto;display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;padding-top:12px;border-top:1px solid rgba(0,0,0,0.06);}
.offer-valid{font-size:11px;color:var(--green-soft);font-weight:800;white-space:nowrap;}
.offer-ctas{display:flex;gap:8px;align-items:center;flex-wrap:wrap;}
.offer-icon-btn{width:40px;height:40px;border-radius:12px;display:inline-flex;align-items:center;justify-content:center;border:1px solid rgba(0,0,0,0.10);transition:transform 0.2s,box-shadow 0.2s;text-decoration:none;}
.offer-icon-btn:hover{transform:translateY(-1px);box-shadow:0 8px 18px rgba(0,0,0,0.12);}
.offer-icon-book{background:#1A73E8;border-color:rgba(26,115,232,0.45);}
.offer-icon-wa{background:#25D366;border-color:rgba(37,211,102,0.45);}
.offer-icon-call{background:#5F6368;border-color:rgba(95,99,104,0.45);}
.offer-icon-btn svg{width:18px;height:18px;display:block;}
.offer-icon-book svg,.offer-icon-wa svg,.offer-icon-call svg{fill:#fff;}
.offer-icon-download svg,.offer-icon-share svg{fill:var(--text);}

/* ── No offers ── */
.no-offers{text-align:center;padding:80px 32px;color:var(--text-light);}
.no-offers h3{font-family:'Cormorant Garamond',serif;font-size:32px;font-weight:300;margin-bottom:10px;}

/* ── Image Modal ── */
#img-modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.75);backdrop-filter:blur(6px);z-index:12000;display:none;}
#img-modal{position:fixed;inset:0;z-index:12001;display:none;align-items:center;justify-content:center;padding:18px;}
#img-modal-inner{position:relative;max-width:min(980px,96vw);max-height:86vh;background:#000;border-radius:14px;overflow:hidden;}
#img-modal-inner img{width:100%;height:100%;max-height:86vh;object-fit:contain;background:#000;}
#img-close{position:absolute;top:10px;right:10px;width:40px;height:40px;border-radius:10px;background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.22);color:#fff;font-size:20px;cursor:pointer;}
#img-prev,#img-next{position:absolute;top:50%;transform:translateY(-50%);width:44px;height:44px;border-radius:12px;background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.22);color:#fff;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;}
#img-prev{left:10px;}#img-next{right:10px;}
#img-prev:hover,#img-next:hover{background:rgba(255,255,255,0.22);}

/* ── Details Modal ── */
#details-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.6);backdrop-filter:blur(4px);z-index:11000;display:none;}
#details-modal{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);width:92%;max-width:620px;max-height:84vh;overflow:auto;background:var(--cream);z-index:11001;display:none;border-radius:14px;box-shadow:0 24px 80px rgba(0,0,0,0.45);}
.dm-head{background:var(--dark);padding:20px 22px;position:sticky;top:0;}
.dm-title{font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:300;color:#fff;line-height:1.1;margin-bottom:4px;}
.dm-meta{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,0.38);}
.dm-close{position:absolute;top:14px;right:14px;width:40px;height:40px;border-radius:10px;background:rgba(255,255,255,0.10);border:1px solid rgba(255,255,255,0.18);color:#fff;font-size:20px;cursor:pointer;}
.dm-body{padding:18px 22px;}
.dm-body p{font-size:13px;color:var(--text-mid);line-height:1.85;font-weight:300;white-space:pre-wrap;}

/* ── Scroll top ── */
#scroll-top{position:fixed;bottom:32px;right:32px;z-index:500;width:44px;height:44px;background:var(--dark);border:1px solid rgba(255,255,255,0.15);color:rgba(255,255,255,0.7);font-size:18px;display:flex;align-items:center;justify-content:center;cursor:pointer;opacity:0;pointer-events:none;transform:translateY(12px);transition:opacity 0.3s,transform 0.3s;}
#scroll-top.visible{opacity:1;pointer-events:auto;transform:translateY(0);}
#scroll-top:hover{background:var(--green);}

/* ── Mobile ── */
@media(max-width:900px){.filter-bar{padding:15px 20px;top:60px;}.offers-main{padding:30px 20px;}.results-bar{padding:14px 20px;}}
@media(max-width:600px){.filter-bar{padding:10px 12px;}.filter-row{flex-direction:column;align-items:flex-start;}.offers-main{padding:20px 12px;}.results-bar{padding:12px;}}
</style>
{{ button_css() }}
{{ action_buttons_css() }}
{{ footer_css() }}
</head>
<body>
{{ tracking_body(gtm_id) }}

{% set base_path = '' %}
{% set active_page = 'offers' %}
{% include "header.j2" %}

{{ page_hero('offers', h1_heading | default('Premium Beauty &amp;<br>Hair Care Offers in Bangalore'), meta_description | default('Save on luxury hair styling, coloring, and skin care. View the latest beauty deals at our JP Nagar, Hennur, Devasandra, and Bangalore locations.'), 'Uncompromising Luxury. Exceptional Value.', 'https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=1800&q=85') }}

<!-- ══ STORE OFFERS TILES ══ -->
<style>
.store-offers-section{padding:40px 60px;background:var(--cream);}
.store-offers-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:24px;}
.store-offer-tile{background:#fff;border:1px solid rgba(0,0,0,0.06);border-radius:14px;padding:28px;transition:box-shadow 0.25s,transform 0.25s;display:flex;flex-direction:column;}
.store-offer-tile:hover{box-shadow:0 10px 34px rgba(0,0,0,0.10);transform:translateY(-2px);}
.store-tile-name{font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:400;color:var(--text);margin-bottom:8px;}
.store-tile-landmarks{font-size:12px;color:var(--text-mid);margin-bottom:16px;line-height:1.5;}
.store-tile-btn{display:inline-block;background:var(--gold);color:var(--dark);padding:10px 20px;font-size:12px;font-weight:600;text-decoration:none;border-radius:10px;transition:opacity 0.2s;margin-top:12px;align-self:flex-start;}
.store-tile-btn:hover{opacity:0.9;}
.store-tile-subtext{font-size:11px;color:var(--text-mid);margin-top:8px;font-style:italic;line-height:1.4;}
@media(max-width:900px){.store-offers-section{padding:30px 20px;}.store-offers-grid{grid-template-columns:1fr 1fr;}}
@media(max-width:600px){.store-offers-grid{grid-template-columns:1fr;}}
</style>

<section class="store-offers-section">
  <h2 style="font-family:'Cormorant Garamond',serif;font-size:32px;font-weight:300;color:var(--text);margin-bottom:8px;">Store-Specific Offers</h2>
  <p style="font-size:14px;color:var(--text-mid);margin-bottom:24px;">View exclusive deals available at each Naturals location</p>
  <div class="store-offers-grid">
    {% for s in stores %}
    {% set store_slug = s.store_display_name | lower | replace(' ', '-') | replace('&', 'and') %}
    {% set landmarks = s.nearby_landmarks | default('') %}
    {% set landmarks_list = landmarks.split(',') if landmarks else [] %}
    {% set first_3_landmarks = landmarks_list[:3] | join(', ') %}
    <div class="store-offer-tile">
      <div class="store-tile-name">{{ s.store_display_name }}</div>
      <div class="store-tile-landmarks">Near: {{ first_3_landmarks | default('Bangalore') }}</div>
      <a href="/stores/bangalore/{{ store_slug }}/offers/" class="store-tile-btn">View Exclusive {{ s.store_display_name }} Deals</a>
      <div class="store-tile-subtext">Premium beauty transformations, starting at special local rates.</div>
    </div>
    {% endfor %}
  </div>
</section>

{{ store_picker_modal(stores, base_path) }}
{{ store_picker_js() }}
{{ sticky_mobile_bar('other') }}
{% include 'footer.j2' %}
{{ theme_toggle() }}

</body>
</html>
