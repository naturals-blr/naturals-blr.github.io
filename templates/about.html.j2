{% from "macros.j2" import full_footer, footer_css, wa_svg, theme_vars, theme_toggle, theme_init_script, button_css, btn_book, btn_wa, btn_call, btn_maps, store_indicator, store_picker_modal, sticky_mobile_bar, store_picker_js, hamburger_nav, tracking_head, tracking_body, stores_json, fb_svg, ig_svg, social_icons, social_icons_css, page_hero, hero_resolver, hero_css, google_analytics, favicon_tags %}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
{{ favicon_tags() }}

<!-- Google Analytics -->
{{ google_analytics() }}

<title>{{ seo_title | default('About Us | Women-Owned Salon | Naturals Salon &amp; Spa Bangalore') }}</title>
<meta name="description" content="{{ meta_description | default('Women-Owned. Women-Led. Naturals Salon &amp; Spa Bangalore — highly rated across ' + stores|length|string + ' prime locations.') }}">
<link rel="canonical" href="{{ canonical_url | default('https://naturals-blr.github.io/about/') }}">
<meta property="og:type" content="website">
<meta property="og:title" content="{{ seo_title | default('About Naturals Salon &amp; Spa Bangalore') }}">
<meta property="og:description" content="{{ meta_description | default('Women-owned, women-led salon trusted across Bangalore.') }}">
<meta property="og:image" content="{{ website_base_url }}{{ og_image | default('/images/og/og-about.jpg') }}">
<meta property="og:url" content="{{ canonical_url | default(website_base_url + '/about/') }}">
<meta property="og:site_name" content="Naturals Salon &amp; Spa Bangalore">
<meta name="whatsapp-msg" content="{{ whatsapp_msg | default('') }}">
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"{{ schema_type | default('AboutPage') }}","name":"{{ seo_title | default('') }}","url":"{{ canonical_url | default(website_base_url) }}"}
</script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
{{ theme_init_script() }}
{{ tracking_head(gtm_id, pixel_id) }}
<style>
{{ theme_vars() }}
{{ hero_css() }}

*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Jost',sans-serif;background:var(--cream);color:var(--text);overflow-x:hidden;}
a{text-decoration:none;color:inherit;}

.hero-badges{display:flex;gap:10px;flex-wrap:wrap;margin-top:28px;}
.hero-badge{border:1px solid rgba(201,168,76,0.4);padding:7px 16px;font-size:9px;letter-spacing:2.5px;text-transform:uppercase;color:var(--gold);font-weight:600;}

/* MAIN WRAP */
.about-wrap{max-width:900px;margin:0 auto;padding:64px 60px;}

/* SECTIONS */
.about-section{margin-bottom:52px;}
.about-section h2{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:300;margin-bottom:16px;color:var(--text);}
.about-section h2 em{font-style:italic;color:var(--green-mid);}
.about-section p{font-size:14px;color:var(--text-mid);line-height:1.9;font-weight:300;margin-bottom:12px;}

/* HIGHLIGHT BOX */
.about-highlight{background:#fff;border-left:3px solid var(--gold);padding:22px 28px;margin:24px 0;}
.about-highlight p{margin:0;font-size:14px;color:var(--text);font-weight:400;line-height:1.8;}

/* CHECK LIST */
.about-checklist{list-style:none;display:flex;flex-direction:column;gap:10px;margin:16px 0;}
.about-checklist li{display:flex;align-items:flex-start;gap:12px;font-size:14px;color:var(--text-mid);font-weight:300;line-height:1.7;}
.about-checklist li::before{content:"¹4";color:var(--gold);font-size:13px;flex-shrink:0;margin-top:2px;}

/* LOCATIONS GRID */
.locations-grid{display:grid;grid-template-columns:1fr 1fr;gap:3px;margin-top:20px;}
.loc-card{background:#fff;padding:22px 24px;border-top:2px solid transparent;transition:border-color 0.3s;text-decoration:none;display:block;}
.loc-card:hover{border-top-color:var(--gold);}
.loc-num{font-family:'Cormorant Garamond',serif;font-size:32px;color:rgba(0,0,0,0.07);font-weight:300;line-height:1;margin-bottom:8px;}
.loc-name{font-family:'Cormorant Garamond',serif;font-size:18px;color:var(--text);font-weight:400;margin-bottom:4px;}
.loc-area{font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);margin-bottom:10px;}
.loc-link{font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-light);transition:color 0.2s;}
.loc-card:hover .loc-link{color:var(--green-mid);}

/* RATINGS STRIP */
.ratings-strip{background:var(--dark);padding:52px 60px;margin:0 -60px 52px;}
[data-theme="naturals"] .ratings-strip{background:#12032a;}
.ratings-inner{max-width:780px;margin:0 auto;}
.ratings-strip .lbl{color:rgba(255,255,255,0.35);}
.ratings-strip .lbl::before{background:rgba(255,255,255,0.25);}
.ratings-strip h2{font-family:'Cormorant Garamond',serif;font-size:clamp(24px,3vw,36px);font-weight:300;color:#fff;margin-bottom:12px;}
.ratings-strip h2 em{font-style:italic;color:var(--gold);}
.ratings-strip p{font-size:14px;color:rgba(255,255,255,0.45);font-weight:300;line-height:1.9;margin-bottom:12px;}
.ratings-points{display:grid;grid-template-columns:repeat(5,1fr);gap:3px;margin-top:28px;}
.rp-cell{background:rgba(255,255,255,0.05);padding:20px 16px;text-align:center;border-top:2px solid transparent;transition:border-color 0.3s;}
.rp-cell:hover{border-top-color:var(--gold);}
.rp-icon{font-size:22px;margin-bottom:8px;}
.rp-label{font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,0.45);line-height:1.5;}

/* PROCESS STEPS */
.process-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:3px;margin-top:24px;}
.process-step{background:#fff;padding:24px 20px;border-bottom:2px solid transparent;transition:border-color 0.3s;text-align:center;}
.process-step:hover{border-bottom-color:var(--gold);}
.ps-num{font-family:'Cormorant Garamond',serif;font-size:40px;color:rgba(0,0,0,0.07);font-weight:300;line-height:1;margin-bottom:8px;}
.ps-title{font-size:11px;letter-spacing:1.5px;text-transform:uppercase;color:var(--green-mid);font-weight:600;margin-bottom:6px;}
.ps-desc{font-size:12px;color:var(--text-mid);line-height:1.7;font-weight:300;}

/* TRAINING GRID */
.training-grid{display:grid;grid-template-columns:1fr 1fr;gap:3px;margin-top:20px;}
.tg-card{background:#fff;padding:24px 24px;border-left:2px solid transparent;transition:border-color 0.3s;}
.tg-card:hover{border-left-color:var(--gold);}
.tg-icon{font-size:22px;margin-bottom:10px;}
.tg-title{font-family:'Cormorant Garamond',serif;font-size:18px;font-weight:400;color:var(--text);margin-bottom:6px;}
.tg-desc{font-size:13px;color:var(--text-mid);line-height:1.75;font-weight:300;}

/* PROMISE BAND */
.promise-band{background:var(--green);padding:60px 60px;margin:0 -60px;}
.promise-inner{max-width:780px;margin:0 auto;}
.promise-band .lbl{color:rgba(255,255,255,0.4);}
.promise-band .lbl::before{background:rgba(255,255,255,0.3);}
.promise-band h2{font-family:'Cormorant Garamond',serif;font-size:clamp(28px,3.5vw,42px);font-weight:300;color:#fff;margin-bottom:16px;}
.promise-band h2 em{font-style:italic;color:var(--gold-pale);}
.promise-band p{font-size:14px;color:rgba(255,255,255,0.6);font-weight:300;line-height:1.9;margin-bottom:8px;}
.promise-checklist{list-style:none;display:flex;flex-direction:column;gap:10px;margin:20px 0 32px;}
.promise-checklist li{display:flex;align-items:flex-start;gap:12px;font-size:14px;color:rgba(255,255,255,0.72);font-weight:300;line-height:1.7;}
.promise-checklist li::before{content:"¹4";color:var(--gold-pale);font-size:13px;flex-shrink:0;margin-top:2px;}
.promise-tagline{font-family:'Cormorant Garamond',serif;font-size:18px;font-style:italic;color:rgba(255,255,255,0.5);line-height:1.6;border-top:1px solid rgba(255,255,255,0.15);padding-top:24px;margin-top:8px;}
.promise-btns{display:flex;gap:12px;flex-wrap:wrap;margin-top:28px;}
.btn-primary{background:#fff;color:var(--green);padding:13px 28px;font-size:10px;letter-spacing:2px;text-transform:uppercase;font-weight:700;border-radius:6px;transition:all 0.3s;}
.btn-primary:hover{background:var(--gold);color:var(--dark);}
.btn-ghost{border:1px solid rgba(255,255,255,0.4);color:#fff;padding:13px 28px;font-size:10px;letter-spacing:2px;text-transform:uppercase;font-weight:600;border-radius:6px;transition:all 0.3s;}
.btn-ghost:hover{background:rgba(255,255,255,0.1);}

</style>
{{ button_css() }}
{{ footer_css() }}
<style>

/* RESPONSIVE */
@media(max-width:960px){
  .page-hero-inner{padding:48px 20px 44px;}
  .about-wrap{padding:48px 20px;}
  .ratings-strip{padding:40px 20px;margin:0 -20px 48px;}
  .promise-band{padding:48px 20px;margin:0 -20px;}
  .locations-grid{grid-template-columns:1fr;}
  .ratings-points{grid-template-columns:1fr 1fr 1fr;}
  .process-grid{grid-template-columns:1fr 1fr;}
  .training-grid{grid-template-columns:1fr;}
}
@media(max-width:640px){
  .ratings-points{grid-template-columns:1fr 1fr;}
  .hero-badges{flex-direction:column;gap:8px;}
  .promise-btns{flex-direction:column;}
  .btn-primary,.btn-ghost{text-align:center;}
  img{max-width:100%;height:auto;}
  body{padding-bottom:62px;}
}
</style>
</head>
<body>
{{ tracking_body(gtm_id) }}

{% set base_path = '/' %}
{% set active_page = 'about' %}
{% include "header.j2" %}

<!-- HERO -->
{{ page_hero('about', h1_heading | default('Women-Owned.<br>Women-Led.<br><em>Trusted</em> Across Bangalore.'), meta_description | default('Naturals Salon & Spa is proud to be a women-owned and women-led salon network in Bangalore, committed to delivering premium beauty and grooming services with care, professionalism, and consistency.'), 'Our Story', 'https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=1800&q=85') }}

<!-- MAIN CONTENT -->
<div class="about-wrap">

  <!-- WHO WE ARE -->
  <div class="about-section">
    <div class="lbl">Who We Are</div>
    <h2>Powered by <em>skilled women</em> professionals</h2>
    <p>Our salons are powered by skilled women professionals who are trained, certified, and passionate about helping every guest look and feel confident. From your first consultation to your final look, you are in expert hands — guided by a team that genuinely cares about you.</p>
    <div class="about-highlight">
      <p>&#9792;&nbsp; At Naturals Salon &amp; Spa Bangalore, being women-owned is not just a statement. It is our culture, our commitment, and the reason every guest leaves feeling valued and beautiful.</p>
    </div>
  </div>

  <!-- LOCATIONS -->
  <div class="about-section">
    <div class="lbl">Serving All of Bangalore</div>
    <h2>Present across <em>prime locations</em> in Bangalore</h2>
    <p>We are proudly present in {{ stores|length }} prime locations across Bangalore — because we believe every part of this city deserves a trusted, premium salon experience close to home.</p>
    <div class="locations-grid">
      {% for s in stores %}
      <a href="/stores/{{ s.address_city|lower|replace(' ', '-') if s.address_city else 'bangalore' }}/{{ s.slug|lower if s.slug else (s.store_display_name|lower|replace(' ', '-')) }}/" class="loc-card">
        <div class="loc-num">0{{ loop.index }}</div>
        <div class="loc-name">{{ s.store_display_name }}</div>
        <div class="loc-area">{{ s.store_display_name }} &middot; {{ s.Pincode }}</div>
        <div class="loc-link">Visit this store &#8594;</div>
      </a>
      {% endfor %}
    </div>
    <p style="margin-top:20px;">Our goal is to serve every region of Bangalore with the same excellence and hospitality — whether you are in the south, north, east or the heart of the city.</p>
  </div>

</div><!-- /about-wrap -->

<!-- RATINGS STRIP -->
<div class="about-wrap" style="padding-top:0;padding-bottom:0;">
  <div class="ratings-strip">
    <div class="ratings-inner">
      <div class="lbl">Guest Appreciation</div>
      <h2>Highly Rated &amp; <em>Widely Appreciated</em></h2>
      <p>Naturals Salon &amp; Spa is highly rated and widely appreciated by guests across Bangalore. We actively collect guest feedback and online reviews, and carefully analyse every concern to improve our services. Every negative feedback is studied through a structured root cause analysis process so that service gaps are identified and permanently corrected.</p>
      <p><strong style="color:rgba(255,255,255,0.7);">Continuous improvement is part of our culture.</strong></p>
      <div class="ratings-points">
        <div class="rp-cell"><div class="rp-icon">&#9997;</div><div class="rp-label">Professional Stylists</div></div>
        <div class="rp-cell"><div class="rp-icon">&#10024;</div><div class="rp-label">Hygienic Environment</div></div>
        <div class="rp-cell"><div class="rp-icon">&#128203;</div><div class="rp-label">Transparent Pricing</div></div>
        <div class="rp-cell"><div class="rp-icon">&#128155;</div><div class="rp-label">Friendly Service</div></div>
        <div class="rp-cell"><div class="rp-icon">&#127807;</div><div class="rp-label">Quality Products</div></div>
      </div>
    </div>
  </div>
</div>

<div class="about-wrap">

  <!-- FEEDBACK PROCESS -->
  <div class="about-section">
    <div class="lbl">How We Improve</div>
    <h2>Our <em>feedback loop</em> — how we never stop improving</h2>
    <p>Every piece of guest feedback we receive goes through a structured four-step process. We do not just read reviews — we act on them, close every gap, and verify the improvement.</p>
    <div class="process-grid">
      <div class="process-step">
        <div class="ps-num">01</div>
        <div class="ps-title">Collect</div>
        <div class="ps-desc">Gather feedback via Google reviews, WhatsApp &amp; in-salon conversations after every visit.</div>
      </div>
      <div class="process-step">
        <div class="ps-num">02</div>
        <div class="ps-title">Analyse</div>
        <div class="ps-desc">Review every concern — positive and negative — weekly across all {{ stores|length }} locations.</div>
      </div>
      <div class="process-step">
        <div class="ps-num">03</div>
        <div class="ps-title">Root Cause</div>
        <div class="ps-desc">Identify the exact cause of every service gap and assign a clear corrective action.</div>
      </div>
      <div class="process-step">
        <div class="ps-num">04</div>
        <div class="ps-title">Implement</div>
        <div class="ps-desc">Train, upgrade and improve — then verify the fix so the same gap never recurs.</div>
      </div>
    </div>
  </div>

  <!-- TRAINING & INFRASTRUCTURE -->
  <div class="about-section">
    <div class="lbl">Training, Quality &amp; Infrastructure</div>
    <h2>We invest continuously in <em>better</em> — for you</h2>
    <p>To maintain high standards across all {{ stores|length }} locations in Bangalore, we invest consistently in our people, processes and spaces. We love our guests, and we continuously invest in better skills, better systems, and better experiences.</p>
    <div class="training-grid">
      <div class="tg-card">
        <div class="tg-icon">&#127891;</div>
        <div class="tg-title">Regular Stylist Training</div>
        <div class="tg-desc">Every stylist attends structured training programmes — covering the latest techniques, product knowledge, guest communication and trend updates.</div>
      </div>
      <div class="tg-card">
        <div class="tg-icon">&#127968;</div>
        <div class="tg-title">Infrastructure Upgrades</div>
        <div class="tg-desc">We periodically upgrade salon furniture, equipment and ambience across all stores — because your comfort matters as much as your service.</div>
      </div>
      <div class="tg-card">
        <div class="tg-icon">&#128137;</div>
        <div class="tg-title">Strict Hygiene Protocols</div>
        <div class="tg-desc">We follow hospital-grade hygiene and sterilisation standards at every location — clean tools, clean spaces, every single visit.</div>
      </div>
      <div class="tg-card">
        <div class="tg-icon">&#127991;</div>
        <div class="tg-title">Seasonal Offers &amp; Value Packages</div>
        <div class="tg-desc">We regularly introduce seasonal promotions and value packages because premium beauty should be accessible and rewarding for every guest.</div>
      </div>
    </div>
  </div>

  <!-- PROMISE BAND -->
  <div class="promise-band">
    <div class="promise-inner">
      <div class="lbl">Our Promise to You</div>
      <h2>More than a salon visit —<br>an <em>experience</em> built on trust.</h2>
      <p>At Naturals Salon &amp; Spa Bangalore, you can always expect:</p>
      <ul class="promise-checklist">
        <li>Expert consultation before every service</li>
        <li>Skilled women stylists who listen and deliver</li>
        <li>Clean, comfortable and welcoming ambience</li>
        <li>Consistent quality across {% for s in stores %}{{ s.store_display_name }}{% if not loop.last %}, {% endif %}{% endfor %}</li>
        <li>Transparent pricing with no hidden charges</li>
        <li>Premium professional products at every service</li>
      </ul>
      <div class="promise-tagline">"More than a salon visit, we deliver an experience built on trust, respect, and care."</div>
      <div class="promise-btns">
        <button onclick="openStorePicker()" class="btn-primary">Book an Appointment</button>
        <a href="../contact/index.html" class="btn-ghost">Contact Us</a>
      </div>
    </div>
  </div>

</div><!-- /about-wrap -->

{% include 'footer.j2' %}
{{ stores_json(stores, '/') }}
{{ store_picker_modal(stores, base_path) }}
{{ store_picker_js() }}
{{ sticky_mobile_bar('other') }}
{{ theme_toggle() }}
{{ hero_resolver() }}
</body>
</html>
