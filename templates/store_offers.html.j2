{# build/templates/store_offers.html.j2 #}
{% from "macros.j2" import footer_css, wa_svg, fb_svg, ig_svg, theme_vars, theme_toggle, theme_init_script, button_css,
   store_picker_modal, store_picker_js, sticky_mobile_bar, tracking_head, tracking_body, page_hero, hero_resolver, hero_css, google_analytics, favicon_tags %}
{% from "action_buttons.j2" import action_buttons_css, action_buttons_js %}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
{{ favicon_tags() }}

{{ google_analytics() }}

{# Landmark injection for meta description #}
{% set nearby_landmarks = store.nearby_landmarks | default('') %}
{% set landmarks_list = nearby_landmarks.split(',') if nearby_landmarks else [] %}
{% set first_3_landmarks = landmarks_list[:3] | join(', ') %}

{% set store_slug = store.store_display_name | lower | replace(' ', '-') | replace('&', 'and') %}

<link rel="canonical" href="{{ canonical_url | default(website_base_url + '/stores/bangalore/' + store_slug + '/offers/') }}">
<meta name="description" content="{{ meta_description | default('Exclusive beauty offers at Naturals ' + (store.store_display_name | default(store.brand_store_name)) + '. Located near ' + first_3_landmarks | default('Bangalore') + ', we offer premium styling and skin deals for our local community.') }}">
<title>{{ seo_title | default('Exclusive Offers at Naturals ' + (store.store_display_name | default(store.brand_store_name))) }}</title>
<meta property="og:type" content="website">
<meta property="og:title" content="{{ seo_title | default('Exclusive Offers at Naturals ' + (store.store_display_name | default(store.brand_store_name))) }}">
<meta property="og:description" content="{{ meta_description | default('') }}">
<meta property="og:image" content="{{ website_base_url }}{{ og_image | default('/images/og/og-offers.jpg') }}">
<meta property="og:url" content="{{ canonical_url | default(website_base_url + '/stores/bangalore/' + store_slug + '/offers/') }}">
<meta property="og:site_name" content="Naturals Salon & Spa Bangalore">
<meta name="whatsapp-msg" content="{{ whatsapp_msg | default('') }}">
<link rel="preconnect" href="https://fonts.googleapis.com">
{{ tracking_head(gtm_id, pixel_id) }}
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
{{ theme_init_script() }}

{# Comprehensive JSON-LD SpecialAnnouncement Schema #}
{% set store_slug = store.store_display_name | lower | replace(' ', '-') | replace('&', 'and') %}
{% set nearby_landmarks = store.nearby_landmarks | default('') %}
{% set landmarks_list = nearby_landmarks.split(',') if nearby_landmarks else [] %}
{% set first_3_landmarks = landmarks_list[:3] | join(', ') %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "{{ schema_type | default('SpecialAnnouncement') }}",
  "name": "{{ seo_title | default('Exclusive Offers at Naturals ' + store.store_display_name) }}",
  "description": "{{ meta_description | default('Unlock premium beauty and hair care deals at our ' + store.store_display_name + ' location, serving areas near ' + first_3_landmarks + '.') }}",
  "url": "{{ website_base_url }}/stores/bangalore/{{ store_slug }}/offers/",
  "category": "Beauty and Grooming Promotions",
  "datePosted": "{{ current_date }}T09:00:00+05:30",
  "provider": {
    "@type": "HairSalon",
    "name": "Naturals Salon & Spa {{ store.store_display_name }}",
    "url": "{{ website_base_url }}/stores/bangalore/{{ store_slug }}/",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "{{ store.address_full | default(store.address_line_1) | default('') }}",
      "addressLocality": "{{ store.address_city }}",
      "postalCode": "{{ store.address_pincode | default('') }}",
      "addressCountry": "IN"
    },
    "telephone": "+{{ store.phone_mobile | default('') }}"
  },
  "announcementLocation": {
    "@type": "HairSalon",
    "name": "Naturals {{ store.store_display_name }}",
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": {{ store.schema_latitude }},
      "longitude": {{ store.schema_longitude }}
    }
  },
  "areaServed": [
    "{{ store.store_display_name }}"
    {% if store.nearby_landmarks %},{% for area in store.nearby_landmarks.split(',') %}"{{ area.strip() }}"{% if not loop.last %},{% endif %}{% endfor %}{% endif %}
  ],
  "hasPart": [
    {% for campaign in campaigns %}
    {
      "@type": "Offer",
      "name": "{{ campaign.content_title | default(campaign.title) | replace('"', '\\"') }}",
      "description": "{{ campaign.content_body | default(campaign.description) | truncate(150) | replace('"', '\\"') }}",
      "availability": "https://schema.org/InStoreOnly",
      "offeredBy": {
        "@type": "HairSalon",
        "name": "Naturals {{ store.store_display_name }}"
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ],
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "{{ website_base_url }}"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "{{ store.store_display_name }}",
        "item": "{{ website_base_url }}/stores/bangalore/{{ store_slug }}/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "Offers",
        "item": "{{ website_base_url }}/stores/bangalore/{{ store_slug }}/offers/"
      }
    ]
  }
}
</script>

<style>
{{ theme_vars() }}
{{ hero_css() }}
*{margin:0;padding:0;box-sizing:border-box;}html{scroll-behavior:smooth;}
body{font-family:'Jost',sans-serif;background:var(--cream);color:var(--text);}
a{text-decoration:none;color:inherit;}img{display:block;width:100%;object-fit:cover;}

/* ── Filter Bar ── */
.filter-bar{background:var(--filter-bg);padding:15px 60px;position:sticky;top:70px;z-index:100;border-bottom:1px solid rgba(255,255,255,0.06);min-height:60px;}
.filter-row{display:flex;align-items:center;gap:15px;width:100%;flex-wrap:wrap;}
.filter-group.store-group{display:flex;flex-wrap:wrap;gap:8px;flex:1;}
.filter-lbl{font-size:9px;letter-spacing:1.5px;text-transform:uppercase;font-weight:600;color:var(--green-soft);white-space:nowrap;margin-right:3px;}
.f-btn{background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.4);padding:6px 14px;font-size:11px;letter-spacing:1px;text-transform:uppercase;cursor:pointer;transition:all 0.25s;font-family:'Jost',sans-serif;font-weight:500;border-radius:10px;}
.f-btn:hover{border-color:rgba(255,255,255,0.3);color:#fff;}
.f-btn.active{background:var(--gold);border-color:var(--gold);color:var(--dark);font-weight:600;}
[data-theme="naturals"] .f-btn.active{background:var(--green-mid);border-color:var(--green-mid);color:#fff;}

/* ── Results bar ── */
.results-bar{background:var(--cream);padding:14px 60px;border-bottom:1px solid rgba(0,0,0,0.06);font-size:13px;color:var(--text-light);}

/* ── Offers layout ── */
.offers-main{padding:40px 60px;}
.offers-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
@media(max-width:900px){.offers-grid{grid-template-columns:1fr 1fr;}}
@media(max-width:600px){.offers-grid{grid-template-columns:1fr;}}

/* ── Card ── */
.offer-card{background:#fff;overflow:hidden;transition:box-shadow 0.25s,transform 0.25s;border:1px solid rgba(0,0,0,0.06);min-height:360px;display:flex;flex-direction:column;border-radius:14px;}
.offer-card:hover{box-shadow:0 10px 34px rgba(0,0,0,0.10);transform:translateY(-2px);}
.offer-media{height:200px;position:relative;background:linear-gradient(135deg,var(--dark) 0%,var(--green) 100%);overflow:hidden;}
.offer-media img{width:100%;height:100%;object-fit:cover;transition:transform 0.7s ease;cursor:zoom-in;}
.offer-card:hover .offer-media img{transform:scale(1.04);}
.ribbon{position:absolute;top:14px;left:14px;z-index:2;background:rgba(201,168,76,0.92);color:var(--dark);font-size:9px;letter-spacing:2px;text-transform:uppercase;font-weight:800;padding:7px 10px;border-radius:999px;box-shadow:0 8px 18px rgba(0,0,0,0.18);}
.ribbon.urgent{background:rgba(217,48,37,0.92);color:#fff;}
.ribbon.new{background:rgba(26,115,232,0.92);color:#fff;}
.offer-body{padding:18px 18px 16px;display:flex;flex-direction:column;flex:1;}
.offer-badge{font-size:9px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);font-weight:700;margin-bottom:8px;}
.offer-title{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:400;margin-bottom:8px;color:var(--text);line-height:1.2;}
.offer-details{font-size:12px;color:var(--text-mid);line-height:1.7;font-weight:300;margin-bottom:12px;}
.offer-details.clamp{display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden;}
.offer-more{display:inline-flex;gap:6px;align-items:center;font-size:11px;color:var(--green-mid);cursor:pointer;margin-top:-6px;margin-bottom:12px;}
.offer-more:hover{text-decoration:underline;}
.offer-footer{margin-top:auto;display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;padding-top:12px;border-top:1px solid rgba(0,0,0,0.06);}
.offer-valid{font-size:11px;color:var(--green-soft);font-weight:800;white-space:nowrap;}
.offer-ctas{display:flex;gap:8px;align-items:center;flex-wrap:wrap;}
.offer-icon-btn{width:40px;height:40px;border-radius:12px;display:inline-flex;align-items:center;justify-content:center;border:1px solid rgba(0,0,0,0.10);transition:transform 0.2s,box-shadow 0.2s;text-decoration:none;}
.offer-icon-btn:hover{transform:translateY(-1px);box-shadow:0 8px 18px rgba(0,0,0,0.12);}
.offer-icon-book{background:#1A73E8;border-color:rgba(26,115,232,0.45);}
.offer-icon-wa{background:#25D366;border-color:rgba(37,211,102,0.45);}
.offer-icon-call{background:#5F6368;border-color:rgba(95,99,104,0.45);}
.offer-icon-fb{background:#fff;border-color:rgba(24,119,242,0.30);}
.offer-icon-ig{background:#fff;border-color:rgba(225,48,108,0.25);}
.offer-icon-btn svg{width:18px;height:18px;display:block;}
.offer-icon-book svg,.offer-icon-wa svg,.offer-icon-call svg{fill:#fff;}
.offer-icon-fb svg,.offer-icon-ig svg{fill:var(--text);}

/* ── No offers ── */
.no-offers{text-align:center;padding:80px 32px;color:var(--text-light);}
.no-offers h3{font-family:'Cormorant Garamond',serif;font-size:32px;font-weight:300;margin-bottom:10px;}

/* ── Image Modal ── */
#img-modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.75);backdrop-filter:blur(6px);z-index:12000;display:none;}
#img-modal{position:fixed;inset:0;z-index:12001;display:none;align-items:center;justify-content:center;padding:18px;}
#img-modal-inner{position:relative;max-width:min(980px,96vw);max-height:86vh;background:#000;border-radius:14px;overflow:hidden;}
#img-modal-inner img{width:100%;height:100%;max-height:86vh;object-fit:contain;background:#000;}
#img-close{position:absolute;top:10px;right:10px;width:40px;height:40px;border-radius:10px;background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.22);color:#fff;font-size:20px;cursor:pointer;}
#img-prev,#img-next{position:absolute;top:50%;transform:translateY(-50%);width:44px;height:44px;border-radius:12px;background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.22);color:#fff;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;}
#img-prev{left:10px;}#img-next{right:10px;}
#img-prev:hover,#img-next:hover{background:rgba(255,255,255,0.22);}

/* ── Store Local Offers Banner ── */
.store-offers-banner{background:var(--gold);padding:16px 60px;text-align:center;}
.store-offers-banner h1{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:400;color:var(--dark);margin:0;}
.store-offers-banner p{margin:8px 0 0;font-size:13px;color:var(--dark);opacity:0.8;}
.view-main-offers{display:inline-block;margin-top:12px;padding:8px 16px;background:var(--dark);color:var(--gold);font-size:12px;text-decoration:none;border-radius:8px;transition:opacity 0.2s;}
.view-main-offers:hover{opacity:0.9;}

@media(max-width:900px){
  .filter-bar,.results-bar,.offers-main,.store-offers-banner{padding-left:20px;padding-right:20px;}
}
@media(max-width:600px){
  .filter-bar{padding:12px 16px;}
  .offers-main{padding:24px 16px;}
  .store-offers-banner h1{font-size:22px;}
}
</style>
{{ button_css() }}
{{ footer_css() }}
{{ action_buttons_css() }}
</head>
<body>
{{ tracking_body(gtm_id) }}

{% set base_path = '../' %}
{% set active_page = 'offers' %}
{% include "header.j2" %}

{{ page_hero('offers', 'Store Offers', 'Exclusive deals at your local Naturals salon', 'Local Offers', 'https://images.unsplash.com/photo-1560066984-138dadb4c035?w=1800&q=85') }}

<!-- Store Offers Banner -->
<section class="store-offers-banner">
  <h1>{{ h1_heading | default((store.store_display_name | default(store.brand_store_name)) + ' Offers') }}</h1>
  <p>Located near {{ first_3_landmarks | default('Bangalore') }}</p>
  <a href="/offers/" class="view-main-offers">View All Offers</a>
</section>

<!-- RESULTS BAR -->
<div class="results-bar">
  <div id="results-count">{{ campaigns | length }} exclusive offer{{ 's' if campaigns | length != 1 else '' }} at this location</div>
</div>

<!-- OFFERS -->
<main class="offers-main section">
  <div id="offers-grid-all" class="offers-grid">
    {% if campaigns %}
      {% for offer in campaigns %}
      <article class="offer-card" data-store-id="{{ store.Store_ID }}" data-store-name="{{ store.store_display_name | lower }}">
        <div class="offer-media">
          {% if offer.campaign_priority == 'high' %}
          <span class="ribbon urgent">Featured</span>
          {% elif offer.is_expired == 'No' %}
          <span class="ribbon new">New</span>
          {% endif %}
          {% if offer.media_asset_name %}
          <img src="/campaigns/offer/03_published/{{ offer.media_asset_name }}.jpg" alt="{{ offer.content_title }}" loading="lazy" onclick="openModal(this)">
          <div class="img-actions">
            <button class="img-action-btn" onclick="downloadImage(this)" title="Download Image">
              <svg viewBox="0 0 24 24"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg>
            </button>
            <button class="img-action-btn" onclick="shareContent(this)" title="Share Offer">
              <svg viewBox="0 0 24 24"><path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92 1.61 0 2.92-1.31 2.92-2.92s-1.31-2.92-2.92-2.92z"/></svg>
            </button>
          </div>
          {% else %}
          <img src="/images/offers/default-offer.jpg" alt="{{ offer.content_title }}" loading="lazy" onclick="openModal(this)">
          {% endif %}
        </div>
        <div class="offer-body">
          <div class="offer-badge">{{ offer.campaign_type | default('OFFER') }}</div>
          <h3 class="offer-title">{{ offer.content_title }}</h3>
          <p class="offer-details clamp">{{ offer.content_body }}</p>
          <div class="offer-footer">
            <span class="offer-valid">Valid until {{ offer.end_date | default('limited period') }}</span>
            <div class="offer-ctas">
              <a class="offer-icon-btn offer-icon-book" href="{{ store.appointment_url | default(store.website | default('#')) }}" target="_blank" rel="noopener" title="Book Now">
                <svg viewBox="0 0 24 24"><path d="M7 2a1 1 0 0 1 1 1v1h8V3a1 1 0 1 1 2 0v1h1.5A2.5 2.5 0 0 1 22 6.5v14A2.5 2.5 0 0 1 19.5 23h-15A2.5 2.5 0 0 1 2 20.5v-14A2.5 2.5 0 0 1 4.5 4H6V3a1 1 0 0 1 1-1zm13 8H4v10.5c0 .276.224.5.5.5h15a.5.5 0 0 0 .5-.5V10zM6 6H4.5a.5.5 0 0 0-.5.5V8h16V6.5a.5.5 0 0 0-.5-.5H18v1a1 1 0 1 1-2 0V6H8v1a1 1 0 1 1-2 0V6z"/></svg>
              </a>
              {% if store.whatsapp_number %}
              <a class="offer-icon-btn offer-icon-wa" href="https://wa.me/+{{ store.whatsapp_number | replace('+', '') | replace(' ', '') }}" target="_blank" rel="noopener" title="WhatsApp">{{ wa_svg() }}</a>
              {% endif %}
              {% if store.phone_mobile %}
              <a class="offer-icon-btn offer-icon-call" href="tel:+{{ store.phone_mobile }}" title="Call">
                <svg viewBox="0 0 24 24"><path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 0 1 1 1V21a1 1 0 0 1-1 1C10.85 22 2 13.15 2 2a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.46.57 3.58a1 1 0 0 1-.24 1.01l-2.2 2.2z"/></svg>
              </a>
              {% endif %}
              {% if store.facebook_url and store.facebook_url not in ('https://facebook.com/','https://facebook.com','') %}
              <a class="offer-icon-btn offer-icon-fb" href="{{ store.facebook_url }}" target="_blank" rel="noopener" title="Facebook">{{ fb_svg() }}</a>
              {% endif %}
              {% if store.instagram_url and store.instagram_url not in ('https://instagram.com/','https://instagram.com','') %}
              <a class="offer-icon-btn offer-icon-ig" href="{{ store.instagram_url }}" target="_blank" rel="noopener" title="Instagram">{{ ig_svg() }}</a>
              {% endif %}
              <a class="action-btn action-btn-download" onclick="downloadImage(this)" title="Download Image">
                <svg viewBox="0 0 24 24"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg>
              </a>
              <a class="action-btn action-btn-share" onclick="shareContent(this)" title="Share Offer">
                <svg viewBox="0 0 24 24"><path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92 1.61 0 2.92-1.31 2.92-2.92s-1.31-2.92-2.92-2.92z"/></svg>
              </a>
            </div>
          </div>
        </div>
      </article>
      {% endfor %}
    {% else %}
      <div class="no-offers">
        <h3>No active offers</h3>
        <p>Check back soon for exclusive deals at this location!</p>
        <a href="/offers/" class="view-main-offers" style="margin-top:20px;">View All Offers</a>
      </div>
    {% endif %}
  </div>
</main>

<!-- Image Modal -->
<div id="img-modal-overlay" onclick="closeModal()"></div>
<div id="img-modal" onclick="closeModal()">
  <div id="img-modal-inner" onclick="event.stopPropagation()">
    <button id="img-close" onclick="closeModal()">&times;</button>
    <button id="img-prev" onclick="prevImage()">&larr;</button>
    <img id="modal-img" src="" alt="">
    <button id="img-next" onclick="nextImage()">&rarr;</button>
  </div>
</div>

{% include 'footer.j2' %}

<script>
// Image Modal Functions
let currentImageIndex = 0;
let allImages = [];

function openModal(img) {
  const overlay = document.getElementById('img-modal-overlay');
  const modal = document.getElementById('img-modal');
  const modalImg = document.getElementById('modal-img');
  
  // Collect all images
  allImages = Array.from(document.querySelectorAll('.offer-media img'));
  currentImageIndex = allImages.indexOf(img);
  
  modalImg.src = img.src;
  overlay.style.display = 'block';
  modal.style.display = 'flex';
  document.body.style.overflow = 'hidden';
  
  // Push history state for mobile back button handling
  if (!window._modalHistoryPushed) {
    history.pushState({ modalOpen: true }, '');
    window._modalHistoryPushed = true;
  }
}

function closeModal() {
  const overlay = document.getElementById('img-modal-overlay');
  const modal = document.getElementById('img-modal');
  overlay.style.display = 'none';
  modal.style.display = 'none';
  document.body.style.overflow = '';
  
  // Reset history state flag
  window._modalHistoryPushed = false;
}

function prevImage() {
  currentImageIndex = (currentImageIndex - 1 + allImages.length) % allImages.length;
  document.getElementById('modal-img').src = allImages[currentImageIndex].src;
}

function nextImage() {
  currentImageIndex = (currentImageIndex + 1) % allImages.length;
  document.getElementById('modal-img').src = allImages[currentImageIndex].src;
}

// Keyboard navigation
document.addEventListener('keydown', function(e) {
  if (document.getElementById('img-modal').style.display === 'flex') {
    if (e.key === 'Escape') closeModal();
    if (e.key === 'ArrowLeft') prevImage();
    if (e.key === 'ArrowRight') nextImage();
  }
});

// Handle mobile back button - close modal instead of navigating back
window.addEventListener('popstate', function(e) {
  const modal = document.getElementById('img-modal');
  if (modal && modal.style.display === 'flex') {
    window._modalHistoryPushed = false;
    closeModal();
  }
});
</script>

{{ sticky_mobile_bar(active_page, store) }}
{{ store_picker_modal(stores) }}
{{ store_picker_js() }}
{{ action_buttons_js() }}

</body>
</html>
