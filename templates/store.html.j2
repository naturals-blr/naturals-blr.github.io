  global_mobile_css, theme_vars, theme_toggle, theme_init_script,
  button_css, btn_book, btn_wa, btn_call, btn_maps, format_phone,
  store_indicator, store_picker_modal, sticky_mobile_bar, store_picker_js,
  hamburger_nav, tracking_head, tracking_body, stores_json, calendar_svg, call_svg, maps_svg,
  review_card, review_css, google_analytics, favicon_tags
with context %}
{% from "action_buttons.j2" import action_buttons_css, action_buttons_js %}
{% from "macros/seo.j2" import
  seo_meta_tags, open_graph_tags, json_ld_schema, canonical_url
with context %}

{% set s = store %}
{% set base_path = '../' %}
{% set active_page = 'stores' %}
{% set s_page_type = s | default({}) %}
{% set s_page_type = dict(s_page_type, page_type='store') %}
{% set s = s_page_type %}

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

