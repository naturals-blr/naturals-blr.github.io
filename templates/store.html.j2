(function(){
  var now = "{{ now_ist_iso }}" ? new Date("{{ now_ist_iso }}") : new Date();
  function daysBetween(a,b){ return Math.floor((b.getTime()-a.getTime())/86400000); }
  document.querySelectorAll('.offer-card').forEach(function(card){
    var rib=card.querySelector('.ribbon'); if(!rib) return;
    var expIso=card.getAttribute('data-expiry-iso')||'';
    var vfIso=card.getAttribute('data-valid-from-iso')||'';
    var urgentDays=null;
    if(expIso){ urgentDays=daysBetween(now,new Date(expIso)); }
    var isUrgent=(urgentDays!==null && urgentDays>=0 && urgentDays<7);
    var isNew=false;
    if(vfIso){ var age=daysBetween(new Date(vfIso),now); isNew=(age>=0 && age<7); }
    if(isUrgent){ rib.style.display='inline-flex'; rib.className='ribbon urgent'; rib.textContent='Ends in '+urgentDays+' day'+(urgentDays===1?'':'s'); }
    else if(isNew){ rib.style.display='inline-flex'; rib.className='ribbon new'; rib.textContent='NEW'; }
  });
})();
</script>

<script>
var gallerySrcs=[]; var galleryIndex=0;
function rebuildGallerySet(){ gallerySrcs=[]; document.querySelectorAll('img.offer-img').forEach(function(img){ if(img.src) gallerySrcs.push(img.src); }); }
function openImgModal(src){ rebuildGallerySet(); if(!src) return; galleryIndex=Math.max(0,gallerySrcs.indexOf(src)); document.getElementById('img-modal-src').src=src; document.getElementById('img-modal-overlay').style.display='block'; document.getElementById('img-modal').style.display='flex'; document.body.style.overflow='hidden'; if(!window._imgModalHistoryPushed){ history.pushState({ imgModalOpen: true }, ''); window._imgModalHistoryPushed=true; } }
function closeImgModal(){ document.getElementById('img-modal-overlay').style.display='none'; document.getElementById('img-modal').style.display='none'; document.getElementById('img-modal-src').src=''; document.body.style.overflow=''; window._imgModalHistoryPushed=false; }
function nextImg(){ if(!gallerySrcs.length) return; galleryIndex=(galleryIndex+1)%gallerySrcs.length; document.getElementById('img-modal-src').src=gallerySrcs[galleryIndex]; }
function prevImg(){ if(!gallerySrcs.length) return; galleryIndex=(galleryIndex-1+gallerySrcs.length)%gallerySrcs.length; document.getElementById('img-modal-src').src=gallerySrcs[galleryIndex]; }
document.addEventListener('DOMContentLoaded',function(){
  document.querySelectorAll('img.offer-img').forEach(function(img){ img.addEventListener('click',function(){ openImgModal(img.src); }); });
});
document.addEventListener('keydown',function(e){
  if(e.key==='Escape') closeImgModal();
  if(document.getElementById('img-modal').style.display==='flex'){ if(e.key==='ArrowRight') nextImg(); if(e.key==='ArrowLeft') prevImg(); }
});
window.addEventListener('popstate',function(e){
  var modal=document.getElementById('img-modal');
  if(modal && modal.style.display==='flex'){ window._imgModalHistoryPushed=false; closeImgModal(); }
});
var io=new IntersectionObserver(function(entries){ entries.forEach(function(e,i){ if(e.isIntersecting){ setTimeout(function(){ e.target.classList.add('visible'); },i*80); io.unobserve(e.target); } }); },{threshold:0});
document.querySelectorAll('.reveal').forEach(function(el){ io.observe(el); });

// Bulletproof Alias: Ensure both function names work simultaneously
window.openReviewsModal = openModal;
</script>

