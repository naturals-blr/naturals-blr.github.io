<script>
(function(){
  var EXT=['.jpg','.jpeg','.png'];
  function hasExt(path){ return /\.[a-zA-Z0-9]{2,5}(\?.*)?$/.test(path||''); }
  function attach(){
    document.querySelectorAll('img.offer-img').forEach(function(img){
      var base=img.getAttribute('data-img-base')||'';
      if(!base) return;
      if(hasExt(base)){ img.src=base; return; }
      var i=0; img.src=base + EXT[i];
      img.onerror=function(){
        i++;
        if(i<EXT.length) img.src=base + EXT[i];
        else img.style.display='none';
      };
    });
  }
  (document.readyState==='loading') ? document.addEventListener('DOMContentLoaded', attach) : attach();
})();

/* Store Open Status System - Global timezone-aware status tracking */
window.store_open_status = {}; // Global object to store status for all stores

function checkStoreOpenStatus() {
  var now = new Date();
  var day = now.getDay(); // 0 = Sunday, 1 = Monday, ..., 6 = Saturday
  
  // Force comparison using Asia/Kolkata time only (no local time conversion)
  var istTime = new Date(now.toLocaleString("en-US", {timeZone: "Asia/Kolkata"}));
  var istHours = istTime.getHours();
  var istMinutes = istTime.getMinutes();
  var currentTime = istHours * 60 + istMinutes;
  
  // Get store hours for current store
  var storeHours = "{{ s.mon_fri_hours }}"; // Mon-Fri hours
  var satHours = "{{ s.saturday_hours }}";
  var sunHours = "{{ s.sunday_hours }}";
  
  if (day === 6 && satHours) storeHours = satHours; // Saturday
  if (day === 0 && sunHours) storeHours = sunHours; // Sunday
  
  // Parse hours like "10:00 AM – 9:00 PM"
  var timeMatch = storeHours.match(/(\d+):(\d+)\s*(AM|PM)\s*–\s*(\d+):(\d+)\s*(AM|PM)/);
  if (!timeMatch) return;
  
  var openTime = parseTime(timeMatch[1], timeMatch[2], timeMatch[3]);
  var closeTime = parseTime(timeMatch[4], timeMatch[5], timeMatch[6]);
  
  // 24-hour comparison: if current time is after 9 PM, store is closed
  var isOpen = currentTime >= openTime && currentTime < closeTime;
  
  // DEBUG: Log simplified logic
  console.log('=== IST TIME LOGIC ===');
  console.log('Local time:', now.toLocaleTimeString());
  console.log('IST time:', istTime.toLocaleTimeString());
  console.log('Current day:', day, '(0=Sun,1=Mon,2=Tue,3=Wed,4=Thu,5=Fri,6=Sat)');
  console.log('Current IST time (minutes):', currentTime);
  console.log('Store hours:', storeHours);
  console.log('Open time (minutes):', openTime);
  console.log('Close time (minutes):', closeTime);
  console.log('Is open?', isOpen);
  
  // Store status globally
  window.store_open_status["{{ s.Store_ID }}"] = isOpen;
  
  return isOpen;
}

function parseTime(hours, minutes, period) {
  var h = parseInt(hours);
  var m = parseInt(minutes);
  if (period === 'PM' && h !== 12) h += 12;
  if (period === 'AM' && h === 12) h = 0;
  return h * 60 + m;
}

function updateStoreStatusIndicators() {
  Object.keys(window.store_open_status).forEach(function(storeId) {
    var statusEl = document.getElementById('store-status-' + storeId);
    if (statusEl) {
      var isOpen = window.store_open_status[storeId];
      var dot = statusEl.querySelector('.status-dot');
      var text = statusEl.querySelector('.status-text');
      
      if (isOpen) {
        dot.style.background = '#28a745'; // Green
        text.textContent = 'Open Now';
        text.style.color = '#28a745';
        statusEl.className = 'open-status-indicator status-open'; // Add class
      } else {
        dot.style.background = '#dc3545'; // Red
        text.textContent = 'Closed';
        text.style.color = '#dc3545';
        statusEl.className = 'open-status-indicator status-closed'; // Add class
      }
    }
  });
}

