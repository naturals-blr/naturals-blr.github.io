{% from "macros.j2" import full_footer, footer_css, hamburger_nav, google_analytics %}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <!-- Google Analytics -->
    {{ google_analytics() }}
    
    <title>Join Our Team at Naturals Salon & Spa – Career Opportunities</title>
    <meta name="description" content="Join our team at Naturals Salon & Spa across multiple cities. Explore career opportunities for beauty professionals and build your career in the salon industry.">
    <link rel="canonical" href="{{ website_base_url }}/careers/">
    <meta property="og:title" content="Join Our Team at Naturals Salon & Spa">
    <meta property="og:description" content="Join our team of beauty professionals across India. Explore exciting career opportunities in the salon industry.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ website_base_url }}/careers/">
    {{ footer_css() }}
</head>
<body>
    {% include 'header.j2' %}

    <main class="container">
        <h1>Join Our Team at Naturals Salon & Spa</h1>
        
        <p>Join the team at Naturals Salon & Spa and build your career in the beauty industry. We offer exciting opportunities for passionate professionals across multiple locations.</p>

        <section class="cities-overview">
            <h2>Join Our Team Opportunities by City</h2>
            {% if cities %}
                <div class="city-cards">
                    {% for city in cities %}
                    <div class="city-card">
                        <div class="city-header">
                            <h3>{{ city.name }}</h3>
                            <span class="job-count">{{ city.job_count }} opening{% if city.job_count != 1 %}s{% endif %}</span>
                        </div>
                        <div class="city-info">
                            <p>Explore {{ city.job_count }} career opportunities in {{ city.name }}. Join our team of beauty professionals.</p>
                        </div>
                        <div class="city-actions">
                            <a href="{{ website_base_url }}/careers/{{ city.slug }}/" class="btn-primary">View {{ city.name }} Jobs</a>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            {% else %}
                <p>No current openings available. Check back soon for new career opportunities.</p>
            {% endif %}
        </section>

        <section class="why-join-us">
            <h2>Why Join Naturals?</h2>
            <div class="benefits-grid">
                <div class="benefit-card">
                    <h3>🎓 Training & Development</h3>
                    <p>Ongoing education and skill development programs to advance your career.</p>
                </div>
                <div class="benefit-card">
                    <h3>🏢 Career Growth</h3>
                    <p>Clear career progression paths with opportunities for advancement into senior roles.</p>
                </div>
                <div class="benefit-card">
                    <h3>💰 Competitive Compensation</h3>
                    <p>Industry-leading salaries, performance incentives, and comprehensive benefits.</p>
                </div>
                <div class="benefit-card">
                    <h3>🤝 Team Environment</h3>
                    <p>Supportive team culture with experienced mentors and collaborative work environment.</p>
                </div>
            </div>
        </section>

        <section class="application-process">
            <h2>Application Process</h2>
            <div class="process-steps">
                <div class="step">
                    <div class="step-number">1</div>
                    <div class="step-content">
                        <h3>Browse Opportunities</h3>
                        <p>Explore available positions across our locations and find the perfect match for your skills.</p>
                    </div>
                </div>
                <div class="step">
                    <div class="step-number">2</div>
                    <div class="step-content">
                        <h3>Submit Application</h3>
                        <p>Apply directly through our job listings or contact our hiring team via phone or email.</p>
                    </div>
                </div>
                <div class="step">
                    <div class="step-number">3</div>
                    <div class="step-content">
                        <h3>Interview Process</h3>
                        <p>Meet with our team to discuss your experience and how you can contribute to Naturals.</p>
                    </div>
                </div>
                <div class="step">
                    <div class="step-number">4</div>
                    <div class="step-content">
                        <h3>Join Our Team</h3>
                        <p>Start your journey with Naturals and begin building your career in the beauty industry.</p>
                    </div>
                </div>
            </div>
        </section>
    </main>

    {% include 'footer.j2' %}
</body>
</html>
