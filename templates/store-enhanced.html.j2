        {% endif %}
        {% if s.get('facebook_url') and s.facebook_url not in ('', 'https://facebook.com/', 'https://facebook.com') %}
        <a href="{{ s.facebook_url }}" target="_blank" class="bl-soc-link bl-soc-fb">{{ fb_svg(20) }} Facebook</a>
        {% endif %}
      </div>
    </div>

  </div>{# /.main-col #}

  <!-- SIDEBAR -->
  <div class="sidebar-col">
    <div class="sb-inner">
      <div class="sb-sec">Hours</div>
      <div class="h-row"><span class="h-day">Mon &ndash; Fri</span><span>{{ s.Mon_Fri_Hours }}</span></div>
      <div class="h-row"><span class="h-day">Saturday</span><span>{{ s.Saturday_Hours }}</span></div>
      <div class="h-row"><span class="h-day">Sunday</span><span>{{ s.Sunday_Hours }}</span></div>
      <div class="sb-divider"></div>
      {% if s.google_review_link %}
      <a href="{{ s.google_review_link }}" target="_blank" rel="noopener" class="btn-primary" style="width:100%;margin-bottom:4px;">
        <span style="font-size:16px;line-height:1;">&#11088;</span> Rate Us on Google
      </a>
      {% endif %}
    </div>
  </div>

</div>{# /.page-wrap #}

<!-- Wall of Love Modal -->
<div id="reviewsModal" class="modal-overlay">
  <div class="modal-content">
    <div class="modal-header">
      <h3 class="modal-title">Wall of <em>Love</em></h3>
      <button class="modal-close" onclick="closeReviewsModal()" aria-label="Close reviews">
        <svg fill="currentColor" viewBox="0 0 24 24">
          <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
        </svg>
      </button>
    </div>
    <div class="modal-body">
      <div id="modalReviewsContent" class="modal-reviews">
        <!-- Reviews will be loaded here -->
      </div>
    </div>
  </div>
</div>

{% include 'footer.j2' %}

<script>
// Store reviews data
const storeReviews = {{ reviews | tojson }};

// State management
let isModalOpen = false;
let currentReviews = [];
let isLoading = false;

// Open reviews modal
function openReviewsModal() {
  if (isModalOpen || isLoading) return;
  
  isModalOpen = true;
  isLoading = true;
  
  const modal = document.getElementById('reviewsModal');
  const content = document.getElementById('modalReviewsContent');
  
  // Show modal
  modal.classList.add('active');
  document.body.style.overflow = 'hidden';
  
  // Show loading state
  content.innerHTML = '<div class="modal-loading"><div class="modal-loading-spinner"></div><p>Loading amazing reviews...</p></div>';
  
  // Load reviews with lazy loading
  setTimeout(() => {
    loadReviewsInBatches();
  }, 300);
}

// Close reviews modal
function closeReviewsModal() {
  isModalOpen = false;
  const modal = document.getElementById('reviewsModal');
  modal.classList.remove('active');
  document.body.style.overflow = '';
}

// Load reviews in batches for performance
function loadReviewsInBatches() {
  const content = document.getElementById('modalReviewsContent');
  const batchSize = 20; // Load 20 reviews at a time
  let currentIndex = 0;
  
  // Sort reviews by date_posted descending
  const sortedReviews = [...storeReviews].sort((a, b) => {
    const dateA = new Date(a.date_posted);
    const dateB = new Date(b.date_posted);
    return dateB - dateA;
  });
  
  currentReviews = sortedReviews;
  
  function loadBatch() {
    if (currentIndex >= sortedReviews.length) {
      isLoading = false;
      return;
    }
    
    const batch = sortedReviews.slice(currentIndex, currentIndex + batchSize);
    const batchHtml = batch.map(review => createReviewCard(review)).join('');
    
    if (currentIndex === 0) {
      content.innerHTML = batchHtml;
    } else {
      content.innerHTML += batchHtml;
    }
    
    currentIndex += batchSize;
    
    // Load next batch if user scrolls near bottom or if first batch
    if (currentIndex < sortedReviews.length) {
      if (currentIndex === batchSize || content.scrollHeight - content.scrollTop <= content.clientHeight + 200) {
        setTimeout(loadBatch, 100);
      }
    }
  }
  
  // Load first batch immediately
  loadBatch();
  
  // Add scroll listener for lazy loading
  content.addEventListener('scroll', () => {
    if (content.scrollHeight - content.scrollTop <= content.clientHeight + 200) {
      loadBatch();
    }
  });
}

// Create review card HTML
function createReviewCard(review) {
  const stars = '★'.repeat(parseInt(review.stars || 5));
  const initial = review.customer_name ? review.customer_name.charAt(0).toUpperCase() : 'A';
  
  return `
    <div class="rev-card reveal">
      <div class="rev-stars">${stars}</div>
      <div class="rev-text">"${review.review_comments}"</div>
      <div class="rev-user">
        <div class="rev-user-img">${initial}</div>
        <div class="rev-user-info">
          <div class="rev-name">${review.customer_name}</div>
          <div class="rev-store">${review.store_name}</div>
        </div>
      </div>
    </div>
  `;
}

// Close modal on escape key
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape' && isModalOpen) {
    closeReviewsModal();
  }
});

// Close modal on background click
document.getElementById('reviewsModal').addEventListener('click', (e) => {
  if (e.target.id === 'reviewsModal') {
    closeReviewsModal();
  }
});
</script>

{{ review_css() }}
</body>
</html>
