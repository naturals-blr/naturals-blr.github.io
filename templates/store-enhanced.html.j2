{% from "macros.j2" import
  footer_css, wa_svg, fb_svg, ig_svg, social_icons, social_icons_css,
  global_mobile_css, theme_vars, theme_toggle, theme_init_script,
  button_css, btn_book, btn_wa, btn_call, btn_maps, format_phone,
  store_indicator, store_picker_modal, sticky_mobile_bar, store_picker_js,
  hamburger_nav, tracking_head, tracking_body, stores_json, calendar_svg, call_svg, maps_svg,
  review_card, review_css, rating_summary, favicon_tags
with context %}

{% set s = store %}
{% set base_path = '../' %}
{% set active_page = 'stores' %}

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<meta name="description" content="{{ s.meta_description | default('Visit Naturals Salon in ' + s.store_display_name + ' for hair spa, skin care, bridal and beauty services. Book online or call ' + format_phone(s.phone_mobile) + '.') }}" />
<title>{{ s.seo_title | default(s.store_display_name + ' | Salon in ' + s.store_display_name + ' | Book Online') }}</title>
<link rel="canonical" href="https://naturals-blr.github.io/stores/{{ s.address_city|lower|replace(' ', '-') if s.address_city else 'bangalore' }}/{{ s.slug|lower if s.slug else (s.store_display_name|lower|replace(' ', '-')) }}/" />

<!-- Favicon and Touch Icons -->
{{ favicon_tags() }}
<link rel="manifest" href="{{ website_base_url }}/site.webmanifest">
<meta name="apple-mobile-web-app-title" content="Naturals Salon">
<meta name="application-name" content="Naturals Salon">
<meta name="msapplication-TileColor" content="#c9a84c">
<meta name="theme-color" content="#c9a84c">

<meta property="og:title" content="{{ s.store_display_name }} | Naturals Salon &amp; Spa Bangalore" />
<meta property="og:description" content="Visit Naturals Salon in {{ s.store_display_name }} for hair spa, skin care, bridal and beauty services. Book online or call {{ s.Phone_Display }}." />
<meta property="og:type" content="business.business" />
<meta property="og:url" content="https://naturals-blr.github.io/stores/{{ s.address_city|lower|replace(' ', '-') if s.address_city else 'bangalore' }}/{{ s.slug|lower if s.slug else (s.store_display_name|lower|replace(' ', '-')) }}/" />
<meta property="og:image" content="https://naturals-blr.github.io/images/stores/{{ s.slug }}/cover.jpg" />
<meta property="og:image:alt" content="{{ s.store_display_name }} - Naturals Salon &amp; Spa" />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet" />

{{ tracking_head(gtm_id, pixel_id) }}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BeautySalon",
  "name": "Naturals Salon & Spa {{ s.store_display_name }}",
  "image": "https://naturals-blr.github.io/images/stores/{{ s.slug }}/cover.jpg",
  "telephone": "{{ s.Phone_Tel }}",
  "url": "https://naturals-blr.github.io/stores/{{ s.address_city|lower|replace(' ', '-') if s.address_city else 'bangalore' }}/{{ s.slug|lower if s.slug else (s.store_display_name|lower|replace(' ', '-')) }}/",
  "priceRange": "₹₹",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "{{ s.Address_Full }}",
    "addressLocality": "Bangalore",
    "addressRegion": "Karnataka",
    "postalCode": "{{ s.Pincode }}",
    "addressCountry": "IN"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": {{ s.schema_latitude | default('12.971599') }},
    "longitude": {{ s.schema_longitude | default('77.594562') }}
  },
  "hasMap": true,
  "sameAs": "https://naturals-blr.github.io/stores/{{ s.address_city|lower|replace(' ', '-') if s.address_city else 'bangalore' }}/{{ s.slug|lower if s.slug else (s.store_display_name|lower|replace(' ', '-')) }}/",
  "google_place_id": "{{ s.google_place_id | default('') }}"
}
</script>

<style>{{ theme_vars() }}{{ global_mobile_css() }}</style>
{{ button_css() }}
{{ footer_css() }}
{{ social_icons_css() }}

<style>
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Jost',sans-serif;background:var(--cream);color:var(--text);overflow-x:hidden;}
a{text-decoration:none;color:inherit;}
img{display:block;width:100%;object-fit:cover;}

/* ── HERO ── */
.hero{height:70vh;min-height:500px;position:relative;display:flex;align-items:flex-end;overflow:hidden;}
.hero-bg{position:absolute;inset:0;}
.hero-bg img{height:100%;object-fit:cover;width:100%;}
.hero-ov{position:absolute;inset:0;background:linear-gradient(135deg,var(--hero-tint) 0%,var(--hero-tint2) 60%,rgba(0,0,0,0.12) 100%);}
.hero-content{position:relative;z-index:2;padding:60px 60px 48px;width:100%;max-width:100%;}
.hero-badge{font-size:9px;letter-spacing:4px;text-transform:uppercase;color:var(--gold);font-weight:600;margin-bottom:12px;}
.hero-content h1{font-family:'Cormorant Garamond',serif;font-size:clamp(36px,5vw,68px);font-weight:300;color:#fff;line-height:0.95;margin-bottom:12px;}
.hero-content h1 em{font-style:italic;color:var(--gold);}
.hero-sub{font-size:14px;color:rgba(255,255,255,0.7);font-weight:300;line-height:1.8;margin-bottom:28px;}

/* ── ACTION BAR ── */
.hero-cta-wrap{display:flex;flex-direction:column;gap:8px;max-width:520px;}
.hero-cta{display:flex;align-items:center;gap:12px;padding:16px 24px;background:var(--gold);color:#fff;border-radius:50px;font-weight:500;font-size:15px;transition:all 0.3s ease;text-decoration:none;}
.hero-cta:hover{background:var(--gold-dark);transform:translateY(-2px);box-shadow:0 8px 25px rgba(201,161,94,0.3);}
.hero-cta svg{width:20px;height:20px;}
.hero-cta span{flex:1;}
.hero-cta-sub{font-size:12px;color:rgba(255,255,255,0.7);text-align:center;margin-top:8px;}
.hero-cta-sub svg{width:14px;height:14px;opacity:0.7;}

/* ── PAGE LAYOUT ── */
.page-wrap{max-width:1200px;margin:0 auto;padding:0 20px;}
.main-col{flex:1;min-width:0;}
.sidebar-col{width:320px;margin-left:40px;}
@media(max-width:992px){.page-wrap{padding:0 16px;}.main-col,.sidebar-col{width:100%;margin:0;}.sidebar-col{margin-top:40px;}}

/* ── INFO SECTION ── */
.info-section{background:#fff;padding:48px;border-radius:24px;margin-bottom:24px;}
.info-title{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:300;color:var(--text);margin-bottom:24px;}
.info-title em{color:var(--gold);font-style:italic;}
.info-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:32px 24px;margin-bottom:32px;}
@media(max-width:768px){.info-grid{grid-template-columns:1fr;gap:24px;}}
.info-item{display:flex;align-items:start;gap:16px;}
.info-icon{width:48px;height:48px;background:var(--cream);border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.info-icon svg{width:24px;height:24px;color:var(--gold);}
.info-text h3{font-size:16px;font-weight:600;color:var(--text);margin-bottom:4px;}
.info-text p{font-size:14px;color:var(--text-mid);line-height:1.6;}

/* ── SERVICES ── */
.services-section{background:#fff;padding:48px;border-radius:24px;margin-bottom:24px;}
.services-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;}
@media(max-width:768px){.services-grid{grid-template-columns:1fr;}}
.service-card{border:1px solid rgba(0,0,0,0.06);border-radius:16px;padding:24px;transition:all 0.3s ease;}
.service-card:hover{border-color:var(--gold);box-shadow:0 8px 32px rgba(0,0,0,0.08);}
.service-icon{width:48px;height:48px;background:var(--cream);border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:16px;}
.service-icon svg{width:24px;height:24px;color:var(--gold);}
.service-name{font-size:16px;font-weight:600;color:var(--text);margin-bottom:8px;}
.service-desc{font-size:14px;color:var(--text-mid);line-height:1.6;}

/* ── REVIEWS ENHANCED ── */
.reviews-block{
  background:#fff;
  padding:36px;
  margin-bottom:24px;
}
.lbl{font-size:10px;letter-spacing:4px;text-transform:uppercase;color:var(--gold);font-weight:600;margin-bottom:12px;}
.sec-title{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:300;color:var(--text);margin-bottom:24px;}
.sec-title em{color:var(--gold);font-style:italic;}

/* Review Snippets - Only show 4 latest */
.reviews-snippet{margin-bottom:24px;}
.reviews-snippet .rev-grid{grid-template-columns:1fr;gap:16px;}

/* Wall of Love Modal */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.6);display:flex;align-items:center;justify-content:center;z-index:9999;opacity:0;visibility:hidden;transition:all 0.3s ease;padding:20px;}
.modal-overlay.active{opacity:1;visibility:visible;}
.modal-content{background:#fff;border-radius:24px;max-width:800px;width:100%;max-height:85vh;height:100%;display:flex;flex-direction:column;transform:scale(0.9);transition:all 0.3s ease;}
.modal-overlay.active .modal-content{transform:scale(1);}
.modal-header{padding:24px 24px 16px;border-bottom:1px solid rgba(0,0,0,0.06);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.modal-title{font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:300;color:var(--text);}
.modal-title em{color:var(--gold);font-style:italic;}
.modal-close{width:40px;height:40px;background:var(--cream);border:none;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;border:1px solid rgba(0,0,0,0.06);transition:all 0.2s ease;}
.modal-close:hover{background:var(--gold);color:#fff;}
.modal-close svg{width:20px;height:20px;}
.modal-body{flex:1;overflow-y:auto;padding:24px;}
.modal-reviews{display:grid;gap:16px;}
.modal-loading{text-align:center;padding:40px;color:var(--text-mid);}
.modal-loading-spinner{width:40px;height:40px;border:3px solid var(--cream);border-top:3px solid var(--gold);border-radius:50%;animation:spin 1s linear infinite;margin:0 auto 16px;}
@keyframes spin{0%{transform:rotate(0deg);}100%{transform:rotate(360deg);}}

/* Read All Reviews Button */
.read-all-btn{display:flex;align-items:center;justify-content:center;width:100%;padding:16px;background:var(--gold);color:#fff;border-radius:16px;font-weight:500;font-size:15px;transition:all 0.3s ease;text-decoration:none;border:none;cursor:pointer;}
.read-all-btn:hover{background:var(--gold-dark);transform:translateY(-2px);box-shadow:0 8px 25px rgba(201,161,94,0.3);}
.read-all-btn svg{width:20px;height:20px;margin-right:8px;}

/* Mobile Optimizations */
@media(max-width:640px){
  .modal-overlay{padding:16px;}
  .modal-content{max-height:90vh;border-radius:16px;}
  .modal-header{padding:20px 20px 16px;}
  .modal-title{font-size:20px;}
  .modal-body{padding:20px;}
  .modal-close{width:36px;height:36px;}
  .modal-close svg{width:18px;height:18px;}
}
</style>

{{ theme_init_script() }}
</head>
<body>

{{ tracking_body(gtm_id) }}

<!-- PAGE WRAPPER -->
<div class="page-wrap">
  
  <!-- MAIN COLUMN -->
  <div class="main-col">
    
    <!-- HERO -->
    <div class="hero">
      <div class="hero-bg">
        <img src="https://naturals-blr.github.io/images/stores/{{ s.slug }}/cover.jpg" alt="{{ s.store_display_name }}" loading="lazy" />
      </div>
      <div class="hero-ov"></div>
      <div class="hero-content">
        <div class="hero-badge">{{ s.Category | default('Premium Salon') }}</div>
        <h1>{{ s.store_display_name }}<em> by Naturals</em></h1>
        <p class="hero-sub">{{ s.Hero_Tagline | default('Experience luxury beauty services in the heart of ' + s.store_display_name) }}</p>
        
        <div class="hero-cta-wrap">
          {% if s.Book_Online_URL %}
          <a href="{{ s.Book_Online_URL }}" class="hero-cta">
            {{ calendar_svg() }}<span>Book Appointment</span>
          </a>
          {% endif %}
          
          {% if s.Phone_Display %}
          <a href="tel:{{ s.Phone_Tel }}" class="hero-cta">
            {{ call_svg() }}<span>{{ s.Phone_Display }}</span>
          </a>
          {% endif %}
          
          {% if s.Google_Maps_URL %}
          <a href="{{ s.Google_Maps_URL }}" target="_blank" rel="noopener" class="hero-cta">
            {{ maps_svg() }}<span>Get Directions</span>
          </a>
          {% endif %}
        </div>
        
        <div class="hero-cta-sub">
          {% if s.Book_Online_URL %}Open 7 AM - 9 PM{% endif %}
          {% if s.Phone_Display %} • Call for same-day{% endif %}
        </div>
      </div>
    </div>

    <!-- INFO SECTION -->
    <div class="info-section reveal">
      <h2 class="info-title">Why choose <em>{{ s.store_display_name }}</em></h2>
      
      <div class="info-grid">
        <div class="info-item">
          <div class="info-icon">{{ calendar_svg() }}</div>
          <div class="info-text">
            <h3>Since {{ s.Founding_Year | default('2010') }}</h3>
            <p>Years of trusted beauty excellence</p>
          </div>
        </div>
        
        <div class="info-item">
          <div class="info-icon">{{ wa_svg() }}</div>
          <div class="info-text">
            <h3>WhatsApp Support</h3>
            <p>Quick responses for bookings</p>
          </div>
        </div>
        
        <div class="info-item">
          <div class="info-icon">{{ fb_svg() }}</div>
          <div class="info-text">
            <h3>Social Following</h3>
            <p>Join thousands of happy clients</p>
          </div>
        </div>
      </div>
    </div>

    <!-- SERVICES -->
    <div class="services-section reveal">
      <h2 class="info-title">Our <em>Services</em></h2>
      
      <div class="services-grid">
        <div class="service-card">
          <div class="service-icon">{{ calendar_svg() }}</div>
          <div class="service-name">Hair & Beauty</div>
          <div class="service-desc">Complete salon services from styling to treatments</div>
        </div>
        
        <div class="service-card">
          <div class="service-icon">{{ wa_svg() }}</div>
          <div class="service-name">Skin Care</div>
          <div class="service-desc">Professional facials and skincare treatments</div>
        </div>
        
        <div class="service-card">
          <div class="service-icon">{{ fb_svg() }}</div>
          <div class="service-name">Bridal Packages</div>
          <div class="service-desc">Complete wedding beauty solutions</div>
        </div>
      </div>
    </div>

    <!-- REVIEWS SECTION -->
    {% if reviews %}
    <div class="reviews-block reveal">
      <div class="lbl">Client Love</div>
      <h2 class="sec-title">What clients <em>say about us</em></h2>
      
      <!-- Review Snippets: Only show latest 4 reviews -->
      <div class="reviews-snippet">
        <div class="rev-grid" style="grid-template-columns:1fr;gap:16px;margin-bottom:24px;">
          {% for rev in reviews[:4] %}
            {{ review_card(rev) }}
          {% endfor %}
        </div>
      </div>
      
      <!-- Read All Reviews Button -->
      {% if reviews|length > 4 %}
      <button class="read-all-btn" onclick="openReviewsModal()">
        <svg fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2l3.09 6.26L22 9.27l-6.91 1.01L12 22l-3.09-5.72L2 9.27l6.91-1.01L12 2z"/>
