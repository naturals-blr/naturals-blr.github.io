      {% if s.google_review_link %}
      <a href="{{ s.google_review_link }}" target="_blank" rel="noopener" class="btn-primary" style="margin-top:16px;">
        <span style="font-size:16px;line-height:1;">&#11088;</span> Rate Us on Google
