{% from "macros.j2" import theme_vars, theme_init_script, button_css, footer_css, hamburger_nav, store_picker_modal, store_picker_js, filter_engine, google_analytics %}
{% set base_path = '/' %}
{% set active_page = 'intranet' %}
{% set website_base_url = '' %}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <!-- Google Analytics -->
    {{ google_analytics() }}
    
    <title>Naturals Staff Portal - Intranet Clone (Test)</title>
    <meta name="description" content="Test page for intranet clone header and footer">
    <meta name="robots" content="noindex, nofollow">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    {{ theme_init_script() }}
    {{ button_css() }}
    {{ footer_css() }}
    
    <style>
        :root{ --dark:#111714;--green:#1B4332;--green-mid:#2D6A4F;--green-soft:#52B788; --cream:#F8F4EE;--gold:#C9A84C;--gold-pale:#EDD9A3; --text:#1A1A1A;--text-mid:#555;--text-light:#999; --hero-tint:rgba(17,23,20,0.88);--hero-tint2:rgba(17,23,20,0.45); --filter-bg:#111714;--card-hover-border:#C9A84C; --nav-bg:rgba(17,23,20,0.97); } [data-theme="naturals"]{ --dark:#1A0533;--green:#2596BE;--green-mid:#7B2FBE;--green-soft:#B678F0; --cream:#FAF7FF;--gold:#C9A84C;--gold-pale:#EDD9A3; --text:#1A1A1A;--text-mid:#4A4458;--text-light:#8B7FA8; --hero-tint:rgba(26,5,51,0.87);--hero-tint2:rgba(58,10,100,0.45); --filter-bg:#1A0533;--card-hover-border:#7B2FBE; --nav-bg:rgba(26,5,51,0.97); }
        
        /* Final Header & Menu Alignment Fix - Flexbox Solution */
        #site-header {
            position: fixed !important;
            top: 0 !important;
            left: 0 !important;
            width: 100% !important;
            height: 80px !important; /* Standardized height */
            background: #000 !important;
            z-index: 9999 !important;
            display: flex !important;
            align-items: center !important;
        }

        .hdr-inner {
            width: 100% !important;
            max-width: 1200px !important;
            margin: 0 auto !important;
            padding: 0 20px !important;
            position: relative !important; /* Container Lock - keeps menu inside */
            display: flex !important;
            justify-content: space-between !important;
            align-items: center !important; /* Flexbox centering - set it and forget it */
        }

        #hamburger {
            position: relative !important; /* Switch to relative for Flexbox */
            right: auto !important;
            top: auto !important;
            transform: none !important; /* Remove transform - Flexbox handles centering */
            display: flex !important;
            visibility: visible !important;
            z-index: 10000 !important;
            height: 40px !important; /* Better touch target for mobile */
            align-items: center !important;
            justify-content: center !important;
            background: rgba(255,255,255,0.08) !important;
            border: 1px solid rgba(255,255,255,0.16) !important;
            border-radius: 10px !important;
            cursor: pointer !important;
            transition: background 0.25s ease, border-color 0.25s ease, transform 0.2s ease !important;
            padding: 9px 10px !important;
            flex-direction: column !important;
            gap: 6px !important;
        }

        #hamburger:hover {
            background: rgba(255,255,255,0.18) !important;
            border-color: var(--gold) !important;
            transform: translateY(-1px) !important;
        }

        .hb-line {
            display: block !important;
            width: 22px !important;
            height: 2px !important;
            background: #fff !important;
            border-radius: 2px !important;
            transition: 0.25s !important;
        }

        /* Theme-specific hamburger styling */
        [data-theme="naturals"] #hamburger {
            background: rgba(255,255,255,0.08) !important;
            border: 1px solid rgba(255,255,255,0.16) !important;
        }

        [data-theme="naturals"] #hamburger:hover {
            background: rgba(255,255,255,0.18) !important;
            border-color: var(--gold) !important;
        }

        /* Navigation Drawer Theme Sync */
        .mobile-drawer {
            background: var(--dark) !important;
            border-left: 1px solid rgba(255,255,255,0.08) !important;
        }

        [data-theme="naturals"] .mobile-drawer {
            background: var(--dark) !important;
            border-left: 1px solid rgba(255,255,255,0.08) !important;
        }

        .md-close {
            background: rgba(255,255,255,0.08) !important;
            border: 1px solid rgba(255,255,255,0.14) !important;
            color: #fff !important;
        }

        [data-theme="naturals"] .md-close {
            background: rgba(255,255,255,0.08) !important;
            border: 1px solid rgba(255,255,255,0.14) !important;
            color: #fff !important;
        }

        .md-link {
            color: rgba(255,255,255,0.78) !important;
            border: 1px solid rgba(255,255,255,0.06) !important;
            background: rgba(255,255,255,0.03) !important;
        }

        [data-theme="naturals"] .md-link {
            color: rgba(255,255,255,0.78) !important;
            border: 1px solid rgba(255,255,255,0.06) !important;
            background: rgba(255,255,255,0.03) !important;
        }

        .md-link:hover {
            border-color: rgba(201,168,76,0.35) !important;
            color: var(--gold) !important;
        }

        [data-theme="naturals"] .md-link:hover {
            border-color: rgba(201,168,76,0.35) !important;
            color: var(--gold) !important;
        }

        .md-link.is-active {
            border-color: rgba(201,168,76,0.65) !important;
            color: var(--gold) !important;
        }

        [data-theme="naturals"] .md-link.is-active {
            border-color: rgba(201,168,76,0.65) !important;
            color: var(--gold) !important;
        }

        .drawer-store-link {
            color: rgba(255,255,255,0.72) !important;
        }

        [data-theme="naturals"] .drawer-store-link {
            color: rgba(255,255,255,0.72) !important;
        }

        .drawer-store-link:hover {
            color: var(--gold) !important;
        }

        [data-theme="naturals"] .drawer-store-link:hover {
            color: var(--gold) !important;
        }

        .hdr-logo img {
            height: 40px !important; /* Consistent logo size */
            width: auto !important;
            display: block !important;
        }
        
        /* Body spacing for fixed header */
        body {
            background: var(--dark);
            color: #fff;
            font-family: 'Jost', sans-serif;
            margin: 0;
            padding: 0;
            min-height: 100vh;
            padding-top: 80px; /* Fixed header spacing */
        }
        
        [data-theme="naturals"] body {
            background: #0D0120;
        }
        
        .intranet-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 20px;
        }
        
        /* ── Header ── */
        .intranet-header {
            text-align: center;
            margin-bottom: 60px;
        }
        
        .intranet-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(32px, 5vw, 48px);
            font-weight: 300;
            color: #fff;
            margin-bottom: 16px;
        }
        
        .intranet-title em {
            font-style: italic;
            color: var(--gold);
        }
        
        .intranet-subtitle {
            font-size: 16px;
            color: rgba(255,255,255,0.7);
            max-width: 600px;
            margin: 0 auto;
            line-height: 1.6;
        }
        
        /* ── Navigation Grid ── */
        .nav-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            margin-bottom: 60px;
        }
        
        .nav-card {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 16px;
            padding: 40px 30px;
            text-align: center;
            transition: all 0.3s ease;
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }
        
        .nav-card:hover {
            background: rgba(255,255,255,0.08);
            border-color: var(--gold);
            transform: translateY(-4px);
        }
        
        .nav-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: var(--gold);
            transform: scaleX(0);
            transition: transform 0.3s ease;
        }
        
        .nav-card:hover::before {
            transform: scaleX(1);
        }
        
        .nav-icon {
            font-size: 48px;
            margin-bottom: 20px;
            display: block;
        }
        
        .nav-title {
            font-size: 20px;
            font-weight: 600;
            color: #fff;
            margin-bottom: 12px;
        }
        
        .nav-description {
            font-size: 14px;
            color: rgba(255,255,255,0.7);
            line-height: 1.6;
        }
        
        /* ── Test Section ── */
        .test-section {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 12px;
            padding: 30px;
            margin-bottom: 40px;
        }
        
        .test-title {
            font-size: 18px;
            font-weight: 600;
            color: var(--gold);
            margin-bottom: 20px;
        }
        
        .test-info {
            font-size: 14px;
            color: rgba(255,255,255,0.8);
            line-height: 1.6;
        }
        
        .test-info code {
            background: rgba(255,255,255,0.1);
            padding: 2px 6px;
            border-radius: 4px;
            font-family: 'Courier New', monospace;
            font-size: 13px;
        }
        
        /* Filter Group Styles */
        .filter-group {
            margin-bottom: 30px;
        }
        
        .filter-group h4 {
            color: var(--text, #fff);
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 15px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .filter-status {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 12px;
            padding: 20px;
            margin-top: 30px;
        }
        
        .filter-status h4 {
            color: var(--gold, #D4AF37);
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 15px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .filter-status p {
            color: rgba(255,255,255,0.8);
            font-size: 14px;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .filter-status strong {
            color: var(--text, #fff);
            font-weight: 600;
        }
        
        .filter-status span {
            color: var(--gold, #D4AF37);
            font-weight: 500;
        }
        
        /* Mobile Responsive */
        @media (max-width: 768px) {
            .intranet-container {
                padding: 20px 16px;
            }
            
            .nav-grid {
                grid-template-columns: 1fr;
                gap: 20px;
            }
            
            .nav-card {
                padding: 30px 20px;
            }
        }
    </style>
</head>
<body>
    <!-- Header -->
    {% include "header.j2" %}
    
    <!-- Main Content -->
    <div class="intranet-container">
        <header class="intranet-header">
            <h1 class="intranet-title">Staff Portal <em>Clone</em></h1>
            <p class="intranet-subtitle">
                Test page for intranet clone header and footer components. This is a development environment for testing new intranet features and layouts.
            </p>
        </header>

        <div class="test-section">
            <h2 class="test-title">🧪 Header & Footer Test Environment</h2>
            <div class="test-info">
                <p><strong>Purpose:</strong> Test header and footer components for new intranetclone</p>
                <p><strong>Components Tested:</strong></p>
                <ul>
                    <li>Header styling and layout</li>
                    <li>Navigation card components</li>
                    <li>Footer integration</li>
                    <li>Theme switching functionality</li>
                    <li>Responsive design</li>
                </ul>
                <p><strong>Template:</strong> <code>intranetclone/index.html.j2</code></p>
                <p><strong>Status:</strong> Ready for development</p>
            </div>
        </div>

        <div class="test-section">
            <h3>Filter Engine Test</h3>
            <p>Testing modular filter component with pills and dropdown logic.</p>
            
            <!-- Store Filters (Primary - 5 items = Pills) -->
            <div class="filter-group">
                <h4>Store Filters</h4>
                {{ filter_engine('Primary', [
                    {'label': 'JP Nagar', 'value': 'jp-nagar'},
                    {'label': 'Elements Mall', 'value': 'elements-mall'},
                    {'label': 'Devasandra', 'value': 'devasandra'},
                    {'label': 'Frazer Town', 'value': 'frazer-town'},
                    {'label': 'Hennur', 'value': 'hennur'}
                ], filter_id='stores', filter_class='store-filters') }}
            </div>
            
            <!-- Gender Filters (Secondary - 3 items = Pills) -->
            <div class="filter-group">
                <h4>Gender Filters</h4>
                {{ filter_engine('Secondary', [
                    {'label': 'All', 'value': 'all'},
                    {'label': 'Male', 'value': 'male'},
                    {'label': 'Female', 'value': 'female'}
                ], filter_id='gender', filter_class='gender-filters') }}
            </div>
            
            <!-- Test Dropdown (Primary - 6+ items = Dropdown) -->
            <div class="filter-group">
                <h4>Service Category (Dropdown Test)</h4>
                {{ filter_engine('Primary', [
                    {'label': 'Haircuts & Styling', 'value': 'haircuts'},
                    {'label': 'Hair Colour & Highlights', 'value': 'colour'},
                    {'label': 'Hair Spa & Treatments', 'value': 'spa'},
                    {'label': "Men's Grooming", 'value': 'mens'},
                    {'label': 'Bridal Services', 'value': 'bridal'},
                    {'label': 'Special Treatments', 'value': 'special'}
                ], filter_id='services', filter_class='service-filters') }}
            </div>
            
            <div class="filter-status">
                <h4>Filter Status</h4>
                <div id="active-filters">
                    <p><strong>Active Store:</strong> <span id="active-store">None</span></p>
                    <p><strong>Active Gender:</strong> <span id="active-gender">None</span></p>
                    <p><strong>Active Service:</strong> <span id="active-service">None</span></p>
                </div>
            </div>
        </div>

        <div class="nav-grid">
            <div class="nav-card" onclick="window.location.href='../training/'">
                <span class="nav-icon">📚</span>
                <h3 class="nav-title">Training Hub</h3>
                <p class="nav-description">Access training materials, video tutorials, and skill development resources</p>
            </div>
            
            <div class="nav-card" onclick="window.location.href='../intranet/'">
                <span class="nav-icon">🏠</span>
                <h3 class="nav-title">Original Intranet</h3>
                <p class="nav-description">Navigate back to the original staff portal for comparison</p>
            </div>
            
            <div class="nav-card" onclick="alert('QR Code feature coming soon!')">
                <span class="nav-icon">📱</span>
                <h3 class="nav-title">QR Codes</h3>
                <p class="nav-description">Generate and manage QR codes for store locations and services</p>
            </div>
            
            <div class="nav-card" onclick="alert('Staff Directory feature coming soon!')">
                <span class="nav-icon">👥</span>
                <h3 class="nav-title">Staff Directory</h3>
                <p class="nav-description">View contact information and roles for all team members</p>
            </div>
            
            <div class="nav-card" onclick="alert('Documents feature coming soon!')">
                <span class="nav-icon">📄</span>
                <h3 class="nav-title">Documents</h3>
                <p class="nav-description">Access company policies, procedures, and important documents</p>
            </div>
            
            <div class="nav-card" onclick="alert('Schedule feature coming soon!')">
                <span class="nav-icon">📅</span>
                <h3 class="nav-title">Schedule</h3>
                <p class="nav-description">View work schedules, shifts, and time-off requests</p>
            </div>
        </div>

        <div class="test-section">
            <h2 class="test-title">🔧 Development Notes</h2>
            <div class="test-info">
                <p><strong>Next Steps:</strong></p>
                <ol>
                    <li>Test header responsiveness across devices</li>
                    <li>Verify footer integration and styling</li>
                    <li>Test theme switching (luxury/naturals)</li>
                    <li>Add navigation functionality</li>
                    <li>Implement feature-specific pages</li>
                </ol>
                <p><strong>Known Issues:</strong> None at this time</p>
                <p><strong>Last Updated:</strong> 2026-03-25 05:50 IST</p>
            </div>
        </div>
    </div>

    <!-- Footer -->
    {% include 'footer.j2' %}
</body>
</html>
