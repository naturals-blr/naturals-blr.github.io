<script>
// Featured reviews data
const featuredReviews = {{ featured_reviews | tojson }};

// State management
let isModalOpen = false;
let currentReviews = [];
let isLoading = false;

// Open reviews modal
function openModal() {
  console.log('Checking Data:', typeof featuredReviews, featuredReviews?.length);
  
  // Add history state for back button handling
  history.pushState({modalOpen: true}, "", "#reviews-modal");
  
  // Fix 3: The One-Time Guard - Prevent multiple executions
  if (window.isModalOpening) return;
  window.isModalOpening = true;
  
  // Clear previous content
  let modalContent = document.getElementById('modalReviewsContent');
  if (!modalContent) {
    // Fallback: Try alternative target
    modalContent = document.getElementById('modal-content') || document.getElementById('reviewsModal').querySelector('.modal-body');
    console.log("Using fallback modal content element for clearing");
  }
  
  if (modalContent) {
    modalContent.innerHTML = '';
  }
  
  isModalOpen = true;
  isLoading = true;
  
  const modal = document.getElementById('reviewsModal');
  
  // Fallback: Find content element for loading state
  let content = document.getElementById('modalReviewsContent');
  if (!content) {
    content = document.getElementById('modal-content') || document.getElementById('reviewsModal').querySelector('.modal-body');
  }
  
  // Show modal
  modal.classList.add('active');
  document.body.style.overflow = 'hidden';
  
  // Bulletproof Change 1: Add loading state with delay
  setTimeout(() => {
    if (content && isLoading) {
      content.innerHTML = '<div class="loading-spinner"></div>';
    }
    loadReviewsInBatches();
    window.isModalOpening = false; // Reset guard after loading starts
  }, 100); // Bulletproof Change 1: 100ms delay
}
  let content = document.getElementById('modalReviewsContent');
  if (!content) {
    content = document.getElementById('modal-content') || document.getElementById('reviewsModal').querySelector('.modal-body');
  }
  
  // Show modal
  modal.classList.add('active');
  document.body.style.overflow = 'hidden';
  
  // Bulletproof Change 1: Add loading state with delay
  setTimeout(() => {
    if (content && isLoading) {
      content.innerHTML = '<div class="loading-spinner"></div>';
    }
      loadReviewsInBatches();
      window.isModalOpening = false; // Reset guard after loading starts
    }, 300);
  }, 100); // Bulletproof Change 1: 100ms delay
}

// Close reviews modal
function closeReviewsModal() {
  isModalOpen = false;
  isLoading = false;
  window.isModalOpening = false; // Reset guard when modal is closed
  
  // Remove modal history state
  if (history.state && history.state.modalOpen) {
    history.back();
  }
  
  const modal = document.getElementById('reviewsModal');
  modal.classList.remove('active');
  document.body.style.overflow = '';
}

// Load reviews in batches for performance
function loadReviewsInBatches() {
  // Fix 2: Manual HTML Injection - Force injection directly into modal body
  const modalBody = document.querySelector('.modal-body') || document.getElementById('modalReviewsContent');
  if (modalBody && featuredReviews && featuredReviews.length > 0) {
    console.log("Manual HTML Injection: Rendering all reviews at once");
    modalBody.innerHTML = featuredReviews.map((r, index) => createReviewCard(r, index)).join('');
    console.log("Manual injection completed - reviews should be visible now");
    window.isModalOpening = false; // Reset guard
    return; // Skip batch loading
  }
  
  // Fallback: Try alternative target if main target not found
  let content = document.getElementById('modalReviewsContent');
  if (!content) {
    content = document.getElementById('modal-content') || document.getElementById('reviewsModal').querySelector('.modal-body');
    console.log("Using fallback modal content element");
  }
  
  if (!content) {
    console.error("Could not find modal content element!");
    window.isModalOpening = false; // Reset guard
    return;
  }
  
  const batchSize = 20; // Load 20 reviews at a time
  let currentIndex = 0;
  
  // Debug: Check if featuredReviews data exists
  console.log("Featured reviews data:", featuredReviews);
  console.log("Featured reviews count:", featuredReviews.length);
  console.log("Target content element found:", !!content);
  
  // Sort reviews by date_posted descending
  const sortedReviews = [...featuredReviews].sort((a, b) => {
    // Handle empty or invalid dates
    const dateA = a.date_posted ? new Date(a.date_posted) : new Date(0);
    const dateB = b.date_posted ? new Date(b.date_posted) : new Date(0);
    return dateB - dateA;
  });
  
  console.log("Sorted reviews count:", sortedReviews.length);
  currentReviews = sortedReviews;
  
  function loadBatch() {
    if (currentIndex >= sortedReviews.length) {
      isLoading = false;
      return;
    }
    
    const batch = sortedReviews.slice(currentIndex, currentIndex + batchSize);
    
    // Hard Reset 3: Manual Trigger
    console.log("Rendering " + batch.length + " cards now...");
    
    const batchHtml = batch.map((review, index) => {
      const globalIndex = currentIndex + index;
      console.log("Rendering card " + (globalIndex + 1) + ": " + review.customer_name);
      return createReviewCard(review, globalIndex);
    }).join('');
    
    content.innerHTML += batchHtml;
    currentIndex += batchSize;
    
    // Continue loading if more reviews
    if (currentIndex < sortedReviews.length) {
      setTimeout(loadBatch, 100);
    } else {
      isLoading = false;
      console.log("All reviews loaded successfully!");
    }
  }
  
  // Load first batch immediately
  loadBatch();
  
  // Add scroll listener for lazy loading
  content?.addEventListener('scroll', () => {
    if (content.scrollHeight - content.scrollTop <= content.clientHeight + 200) {
      loadBatch();
    }
  });
  
  // Load first batch immediately
  loadBatch();
}

// Close modal on escape key
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape' && isModalOpen) {
    closeReviewsModal();
  }
});

// ── Handle browser back button for reviews modal ──
window.addEventListener('popstate', function(event) {
  // If reviews modal is open and back button is pressed, close modal
  const modal = document.getElementById('reviewsModal');
  if (modal && modal.classList.contains('active')) {
    closeReviewsModal();
  }
});

// Create review card HTML
function createReviewCard(review, index) {
  // Safety check: Skip if review is missing basic info
  if (!review || !review.customer_name) {
    console.warn("Skipping invalid review:", review);
    return '';
  }
  
  // Handle stars field - it might be string or number
  const starsCount = parseInt(review.stars || review.Stars || 5);
  const stars = '★'.repeat(starsCount);
  const initial = review.customer_name ? review.customer_name.charAt(0).toUpperCase() : 'A';
  const comments = review.review_comments || review.comments || 'Great experience!';
  
  return `
<div class="rev-card">
    <div class="rev-header-row" style="display: block; width: 100%; clear: both;">
        <div class="rev-header" style="display: flex; align-items: center; justify-content: space-between;">
            <div class="rev-header-left" style="display: flex; align-items: center; gap: 10px;">
                <div class="rev-avatar">${initial}</div>
                <div class="rev-name-stars">
                    <span class="rev-name">${review.customer_name}</span>
                    <div class="rev-stars">${stars}</div>
                </div>
            </div>
            <div class="google-icon"><img src="/images/icons/google.png" width="16"></div>
        </div>
    </div><div class="rev-content-row" style="display: block; width: 100%; margin-top: 0px;">
        <div class="rev-content">
            "${comments}"
        </div>
    </div>
</div>`;
}

// Close modal on escape key
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape' && isModalOpen) {
    closeReviewsModal();
  }
});

// Close modal on background click
document.getElementById('reviewsModal').addEventListener('click', (e) => {
  if (e.target.id === 'reviewsModal') {
    closeReviewsModal();
  }
});
</script>

