<script>
/* reveal */
var io=new IntersectionObserver(function(entries){
  entries.forEach(function(e,i){
    if(e.isIntersecting){
      setTimeout(function(){e.target.classList.add('visible');},i*80);
      io.unobserve(e.target);
    }
  });
},{threshold:0});
document.querySelectorAll('.reveal').forEach(function(el){io.observe(el);});
</script>

<script>
/* Offer image resolver (.jpg → .jpeg → .png) */
(function(){
  var EXT=['.jpg','.jpeg','.png'];
  function hasExt(p){ return /\.[a-zA-Z0-9]{2,5}(\?.*)?$/.test(p||''); }

  document.querySelectorAll('img.home-offer-img').forEach(function(img){
    var base=img.getAttribute('data-img-base')||'';
    if(!base) return;

    if(hasExt(base)){
      img.src=base;
      return;
    }
    var i=0;
    img.src=base + EXT[i];
    img.onerror=function(){
      i++;
      if(i<EXT.length){ img.src=base + EXT[i]; }
      else { img.style.display='none'; }
    };
  });
})();
</script>

<script>
/* Image-only gallery for featured offers (3 items) */
var homeOfferSrcs = [];
var homeOfferIndex = 0;

function collectHomeOfferImages(){
  homeOfferSrcs = [];
  document.querySelectorAll('img.home-offer-img').forEach(function(img){
    if(img.src) homeOfferSrcs.push(img.src);
  });
}
function openHomeOfferModalAt(idx){
  collectHomeOfferImages();
  if(!homeOfferSrcs.length) return;
  homeOfferIndex = Math.max(0, Math.min(idx, homeOfferSrcs.length-1));
  document.getElementById('ho-img-src').src = homeOfferSrcs[homeOfferIndex];
  document.getElementById('ho-img-overlay').style.display='block';
  document.getElementById('ho-img-modal').style.display='flex';
  document.body.style.overflow='hidden';
  if(!window._hoImgModalHistoryPushed){
    history.pushState({ hoImgModalOpen: true }, '');
    window._hoImgModalHistoryPushed = true;
  }
}
function closeHomeOfferModal(){
  document.getElementById('ho-img-overlay').style.display='none';
  document.getElementById('ho-img-modal').style.display='none';
  document.getElementById('ho-img-src').src='';
  document.body.style.overflow='';
  window._hoImgModalHistoryPushed = false;
}
function nextHomeOffer(){
  if(!homeOfferSrcs.length) return;
  homeOfferIndex = (homeOfferIndex + 1) % homeOfferSrcs.length;
  document.getElementById('ho-img-src').src = homeOfferSrcs[homeOfferIndex];
}
function prevHomeOffer(){
  if(!homeOfferSrcs.length) return;
  homeOfferIndex = (homeOfferIndex - 1 + homeOfferSrcs.length) % homeOfferSrcs.length;
  document.getElementById('ho-img-src').src = homeOfferSrcs[homeOfferIndex];
}

/* click handlers */
document.addEventListener('DOMContentLoaded', function(){
  var imgs = Array.from(document.querySelectorAll('img.home-offer-img'));
  imgs.forEach(function(img, idx){
    img.addEventListener('click', function(){ openHomeOfferModalAt(idx); });
  });

  // swipe support (mobile)
  var startX = null;
  var modal = document.getElementById('ho-img-inner');
  if(modal){
    modal.addEventListener('touchstart', function(e){ startX = e.touches[0].clientX; }, {passive:true});
    modal.addEventListener('touchend', function(e){
      if(startX === null) return;
      var endX = e.changedTouches[0].clientX;
      var dx = endX - startX;
      startX = null;
      if(Math.abs(dx) < 40) return;
      if(dx < 0) nextHomeOffer(); else prevHomeOffer();
    }, {passive:true});
  }
});

/* Open Now Status Checker */
window.store_open_status = {}; // Global object to store status for all stores

function checkOpenNowStatus() {
  var now = new Date();
  var day = now.getDay(); // 0 = Sunday, 1 = Monday, ..., 6 = Saturday
  
  // Force comparison using Asia/Kolkata time only (no local time conversion)
  var istTime = new Date(now.toLocaleString("en-US", {timeZone: "Asia/Kolkata"}));
  var istHours = istTime.getHours();
  var istMinutes = istTime.getMinutes();
  var currentTime = istHours * 60 + istMinutes;
  
  document.querySelectorAll('.st-open-now').forEach(function(el) {
    var storeId = el.getAttribute('data-store-id');
    var hours = el.getAttribute('data-hours');
    var satHours = el.getAttribute('data-sat-hours');
    var sunHours = el.getAttribute('data-sun-hours');
    var dot = el.querySelector('.status-dot');
    var text = el.querySelector('.status-text');
    
    if (!hours || !dot || !text) return;
    
    var todayHours = hours;
    if (day === 6 && satHours) todayHours = satHours; // Saturday
    if (day === 0 && sunHours) todayHours = sunHours; // Sunday
    
    // Parse hours like "10:00 AM – 9:00 PM"
    var timeMatch = todayHours.match(/(\d+):(\d+)\s*(AM|PM)\s*–\s*(\d+):(\d+)\s*(AM|PM)/);
    if (!timeMatch) return;
    
    var openTime = parseTime(timeMatch[1], timeMatch[2], timeMatch[3]);
    var closeTime = parseTime(timeMatch[4], timeMatch[5], timeMatch[6]);
    
    // 24-hour comparison: if current time is after 9 PM, store is closed
    var isOpen = currentTime >= openTime && currentTime < closeTime;
    
    // Store status globally
    window.store_open_status[storeId] = isOpen;
    
    if (isOpen) {
      dot.style.background = '#28a745'; // Green
      text.textContent = 'Open Now';
      text.style.color = '#28a745';
      el.className = 'st-open-now status-open'; // Add class
    } else {
      dot.style.background = '#dc3545'; // Red
      text.textContent = 'Closed';
      text.style.color = '#dc3545';
      el.className = 'st-open-now status-closed'; // Add class
    }
  });
}

function parseTime(hours, minutes, period) {
  var h = parseInt(hours);
  var m = parseInt(minutes);
  if (period === 'PM' && h !== 12) h += 12;
  if (period === 'AM' && h === 12) h = 0;
  return h * 60 + m;
}

// Check status on page load and every minute
document.addEventListener('DOMContentLoaded', function(){
  checkOpenNowStatus();
  setInterval(checkOpenNowStatus, 60000); // Update every minute
});

document.addEventListener('keydown', function(e){
  if(e.key === 'Escape') closeHomeOfferModal();
  if(document.getElementById('ho-img-modal').style.display === 'flex'){
    if(e.key === 'ArrowRight') nextHomeOffer();
    if(e.key === 'ArrowLeft') prevHomeOffer();
  }
});

// Handle mobile back button - close home offer image modal instead of navigating back
window.addEventListener('popstate', function(e){
  var modal = document.getElementById('ho-img-modal');
  if(modal && modal.style.display === 'flex'){
    window._hoImgModalHistoryPushed = false;
    closeHomeOfferModal();
  }
});

// Bulletproof Alias: Ensure both function names work simultaneously
window.openReviewsModal = openModal;
