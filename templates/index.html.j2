{% from "macros.j2" import full_footer, footer_css, wa_svg, fb_svg, ig_svg, theme_vars, theme_toggle,
  theme_init_script, button_css, store_picker_modal, sticky_mobile_bar, store_picker_js,
  hamburger_nav, tracking_head, tracking_body, stores_json, calendar_svg, call_svg, maps_svg, review_card, review_css, google_analytics, favicon_tags, format_phone %}
{% from "action_buttons.j2" import action_buttons_css, action_buttons_js %}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="{{ meta_description | default('Experience 5-star hair styling, coloring, and skin care at Naturals Elite Bangalore. Visit our premium studios in JP Nagar, Hennur, Frazer Town, Elements Mall, and our new Devasandra luxury location. Book your elite transformation today!') }}">
<title>{{ seo_title | default('Naturals Elite Bangalore') }}</title>
<meta name="google-site-verification" content="uYue97BBVQGUWI7yG8VmsZSIY_9-Pp2f8JFJbQ--7Rg" />
<link rel="canonical" href="{{ canonical_url | default(site_url + '/') }}">
<meta property="og:type" content="website">
<meta property="og:title" content="{{ seo_title | default('Naturals Elite Bangalore') }}">
<meta property="og:description" content="{{ meta_description | default('') }}">
<meta property="og:image" content="{{ website_base_url }}{{ og_image | default('/images/og/og-home.jpg') }}">
<meta property="og:url" content="{{ canonical_url | default(website_base_url + '/') }}">
<meta property="og:site_name" content="Naturals Salon &amp; Spa Bangalore">
<meta name="whatsapp-msg" content="{{ whatsapp_msg | default('') }}">
{{ favicon_tags() }}
<link rel="manifest" href="{{ website_base_url }}/site.webmanifest">
<meta name="apple-mobile-web-app-title" content="Naturals Salon">
<meta name="application-name" content="Naturals Salon">
<meta name="msapplication-TileColor" content="#c9a84c">
<meta name="theme-color" content="#c9a84c">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
{{ theme_init_script() }}
{{ tracking_head(gtm_id, pixel_id) }}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "{{ schema_type | default('Organization') }}",
  "name": "{{ seo_title | default('Naturals Elite') }}",
  "url": "{{ website_base_url }}",
  "logo": "{{ website_base_url }}{{ og_image | default('/images/og/og-default.jpg') }}",
  "description": "{{ meta_description | default('Bangalore\'s premier destination for luxury beauty and styling with 5 iconic locations.') }}",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "{{ stores[0].address_city | default('Bangalore') }}",
    "addressRegion": "{{ stores[0].address_state | default('Karnataka') }}",
    "addressCountry": "IN"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+{{ stores[0].phone_mobile | default('918792642299') }}",
    "contactType": "customer service"
  },
  "sameAs": [
    "https://www.facebook.com/NaturalsSalon/",
    "https://www.instagram.com/naturalssalon/"
  ],
  "subOrganization": [
    {% for store in stores %}
    {
      "@type": "HairSalon",
      "name": "Naturals Salon & Spa {{ store.store_display_name }}",
      "url": "{{ website_base_url }}/stores/{{ (store.address_city|default('bangalore'))|lower|replace(' ', '-') }}/{{ store.slug|default(store.store_display_name)|lower|replace(' ', '-') }}/",
      "image": "{{ website_base_url }}/images/stores/{{ store.slug|default(store.store_display_name)|lower|replace(' ', '-') }}/cover.jpg",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "{{ store.address_full }}",
        "addressLocality": "{{ store.address_city|default('Bangalore') }}",
        "addressRegion": "{{ store.address_state|default('Karnataka') }}",
        "postalCode": "{{ store.address_pincode }}",
        "addressCountry": "IN"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": {{ store.schema_latitude | default('12.971599') }},
        "longitude": {{ store.schema_longitude | default('77.594562') }}
      },
      "telephone": "+{{ store.phone_mobile }}",
      "areaServed": {{ store.nearby_landmarks.split(',') | map('trim') | list | tojson if store.nearby_landmarks else [] }},
      "google_place_id": "{{ store.google_place_id | default('') }}"
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>

<style>
{{ theme_vars() }}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Jost',sans-serif;background:var(--cream);color:var(--text);overflow-x:hidden;}
img{display:block;width:100%;object-fit:cover;}
a{text-decoration:none;color:inherit;}

/* HERO */
.hero{height:100vh;min-height:700px;position:relative;display:flex;align-items:center;justify-content:center;overflow:hidden;}
.hero-bg{position:absolute;inset:0;}
.hero-bg img{height:100%;object-fit:cover;}
.hero-ov{position:absolute;inset:0;background:linear-gradient(135deg,var(--hero-tint) 0%,var(--hero-tint2) 60%,rgba(0,0,0,0.1) 100%);}
.hero-inner{position:relative;z-index:2;text-align:center;padding:0 24px;max-width:800px;}
.hero-tag{display:inline-flex;align-items:center;gap:12px;font-size:9px;letter-spacing:5px;text-transform:uppercase;color:var(--gold);font-weight:600;margin-bottom:24px;}
.hero-tag::before,.hero-tag::after{content:'';width:24px;height:1px;background:var(--gold);}
.hero h1{font-family:'Cormorant Garamond',serif;font-size:clamp(36px,5vw,68px);font-weight:300;color:#fff;line-height:0.95;margin-bottom:16px;}
.hero h1 em{font-style:italic;color:var(--gold);}
.hero-sub{font-size:14px;color:rgba(255,255,255,0.7);font-weight:300;line-height:1.8;max-width:650px;margin:0 auto 40px;}
.hero-btns{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;}
.hero .btn-secondary{background:transparent;color:#fff;border-color:rgba(255,255,255,0.4);}
.hero .btn-secondary:hover{border-color:#fff;background:rgba(255,255,255,0.1);}

.lbl{font-size:9px;letter-spacing:5px;text-transform:uppercase;color:var(--gold);font-weight:600;margin-bottom:16px;display:flex;align-items:center;gap:12px;}
.lbl::before{content:'';width:18px;height:1px;background:var(--gold);}
.sec-hdr{text-align:center;max-width:600px;margin:0 auto 52px;}
.sec-hdr .lbl{justify-content:center;}
.sec-hdr .lbl::before{display:none;}
.sec-hdr h2{font-family:'Cormorant Garamond',serif;font-size:clamp(36px,5vw,60px);font-weight:300;line-height:1;margin-bottom:16px;}
.sec-hdr h2 em{font-style:italic;color:var(--green-mid);}
.sec-hdr p{font-size:14px;color:var(--text-mid);font-weight:300;line-height:1.8;}
.reveal{opacity:0;transform:translateY(24px);transition:opacity 0.7s ease,transform 0.7s ease;}
.reveal.visible{opacity:1;transform:translateY(0);}

/* STORES */
.stores-sec{background:var(--dark);}
.stores-sec .sec-hdr h2{color:#fff;}
.stores-sec .sec-hdr h2 em{color:var(--green-soft);}
.stores-sec .sec-hdr p{color:rgba(255,255,255,0.4);}
.st-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;max-width:1100px;margin:0 auto;}
.st-card{background:#fff;overflow:hidden;transition:transform 0.3s,box-shadow 0.3s;display:flex;flex-direction:column;border:1px solid rgba(0,0,0,0.08);border-radius:14px;box-shadow:0 2px 12px rgba(0,0,0,0.07);min-height:300px;}
.st-card:hover{transform:translateY(-4px);box-shadow:0 12px 48px rgba(0,0,0,0.3);}
.st-card-head{
  background:var(--dark);padding:20px 22px;border-bottom:2px solid var(--green);border-radius:14px 14px 0 0;
  display:block;text-decoration:none;transition:background 0.2s;
}
.st-card-head:hover{background:#1e2b24;}
[data-theme="naturals"] .st-card-head{border-bottom-color:var(--green-mid);}
.st-card-num{font-family:'Cormorant Garamond',serif;font-size:13px;color:rgba(255,255,255,0.2);letter-spacing:3px;margin-bottom:4px;}
.st-card-name{font-family:'Cormorant Garamond',serif;font-size:20px;color:#fff;font-weight:400;line-height:1.1;}
.st-card-area{font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);margin-top:3px;}
.st-card-body{padding:16px 22px 20px;flex:1;display:flex;flex-direction:column;}
.st-card-addr{font-size:11px;color:var(--text-light);line-height:1.5;flex:1;margin-bottom:14px;}
.st-card-actions{display:flex;flex-direction:column;gap:8px;}
.st-icon-row{display:flex;gap:10px;justify-content:center;margin-bottom:10px;}
.st-btn{
  width:40px;height:40px;border-radius:12px;
  display:inline-flex;align-items:center;justify-content:center;
  border:1px solid rgba(0,0,0,0.10);
  transition:transform 0.2s, box-shadow 0.2s, opacity 0.2s;
  text-decoration:none;color:#fff;font-size:18px;
}
.st-btn:hover{transform:translateY(-1px);box-shadow:0 8px 18px rgba(0,0,0,0.12);}

.st-btn-book{background:#1A73E8;border-color:rgba(26,115,232,0.45);}
.st-btn-wa{background:#25D366;border-color:rgba(37,211,102,0.45);}
.st-btn-call{background:#5F6368;border-color:rgba(95,99,104,0.45);}
.st-btn-maps{background:#A82424;border-color:rgba(168,36,36,0.45);}
.st-btn-ig{background:#fff;border-color:rgba(225,48,108,0.25);}
.st-btn-fb{background:#fff;border-color:rgba(24,119,242,0.30);}
.st-btn svg{width:18px;height:18px;display:block;}
.st-btn-book svg{fill:#fff;}
.st-btn-wa svg{fill:#fff;}
.st-btn-call svg{fill:#fff;}
.st-btn-maps svg{fill:#fff;}
.st-btn-ph{background:transparent;border:none;pointer-events:none;visibility:hidden;}
.st-info-row{display:flex;justify-content:center;}
.st-view-btn{
  border:1px solid rgba(0,0,0,0.14);color:var(--text-mid);
  padding:9px 28px;font-size:10px;min-height:36px;
  letter-spacing:1.5px;text-transform:uppercase;font-weight:700;
  display:inline-flex;align-items:center;gap:6px;
  transition:all 0.2s;border-radius:10px;background:#fff;text-decoration:none;
}
.st-view-btn:hover{border-color:var(--gold);color:var(--gold);}

/* SERVICES (unchanged structure) */
.services-sec{background:var(--cream);}
.svc-cats-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:48px;}
.svc-cat-card{background:#fff;overflow:hidden;border-radius:14px;border:1px solid rgba(0,0,0,0.07);transition:all 0.3s;cursor:pointer;display:flex;flex-direction:column;}
.svc-cat-card:hover{transform:translateY(-4px);box-shadow:0 12px 36px rgba(0,0,0,0.1);border-color:var(--gold);}
.svc-cat-img{height:180px;overflow:hidden;flex-shrink:0;}
.svc-cat-img img{width:100%;height:100%;object-fit:cover;transition:transform 0.6s ease;}
.svc-cat-card:hover .svc-cat-img img{transform:scale(1.05);}
.svc-cat-body{padding:20px 22px 24px;display:flex;flex-direction:column;flex:1;}
.svc-cat-icon{font-size:22px;margin-bottom:8px;display:block;}
.svc-cat-name{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:400;color:var(--text);margin-bottom:6px;line-height:1.1;}
.svc-cat-desc{font-size:12px;color:var(--text-mid);line-height:1.7;font-weight:300;flex:1;}
.svc-cat-price{margin-top:12px;font-size:13px;font-weight:700;color:var(--green-mid);}

/* OFFERS (homepage) */
.offers-sec{background:var(--dark);}
.offers-sec .sec-hdr h2{color:#fff;}
.offers-sec .sec-hdr h2 em{color:var(--gold);}
.offers-sec .sec-hdr p{color:rgba(255,255,255,0.4);}
.offers-sec .btn-secondary{background:transparent;color:#fff;border-color:rgba(255,255,255,0.4);}
.offers-sec .btn-secondary:hover{border-color:#fff;background:rgba(255,255,255,0.1);}
.home-offers-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:32px;}
.hoc{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:14px;overflow:hidden;transition:all 0.25s;display:flex;flex-direction:column;}
.hoc:hover{background:rgba(255,255,255,0.07);border-color:var(--gold);transform:translateY(-2px);}
.hoc-media{height:180px;background:linear-gradient(135deg,var(--dark) 0%,var(--green) 100%);position:relative;overflow:hidden;}
.hoc-media img{width:100%;height:100%;object-fit:cover;cursor:zoom-in;transition:transform 0.7s ease;}
.hoc:hover .hoc-media img{transform:scale(1.04);}
.hoc-body{padding:18px 18px 16px;display:flex;flex-direction:column;flex:1;}
.hoc-badge{font-size:9px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);font-weight:700;margin-bottom:10px;}
.hoc-title{font-family:'Cormorant Garamond',serif;font-size:22px;color:#fff;font-weight:300;margin-bottom:8px;line-height:1.2;}
.hoc-details{font-size:12px;color:rgba(255,255,255,0.42);line-height:1.7;font-weight:300;margin-bottom:12px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
.hoc-meta{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;padding-top:12px;border-top:1px solid rgba(255,255,255,0.08);}
.hoc-store{font-size:10px;color:rgba(255,255,255,0.35);letter-spacing:1px;text-transform:uppercase;}
.hoc-store a{color:inherit;text-decoration:none;}
.hoc-store a:hover{color:var(--gold);}
.hoc-valid{font-size:11px;color:var(--green-soft);font-weight:700;}

.offer-more{display:inline-flex;gap:6px;align-items:center;font-size:11px;color:var(--green-soft);cursor:pointer;margin-top:-6px;margin-bottom:12px;font-weight:600;}
.offer-more:hover{text-decoration:underline;}

.offers-view-all{text-align:center;}

/* IMAGE-ONLY MODAL (gallery for featured offers) */
#ho-img-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.75);backdrop-filter:blur(6px);z-index:15000;display:none;}
#ho-img-modal{position:fixed;inset:0;z-index:15001;display:none;align-items:center;justify-content:center;padding:18px;}
#ho-img-inner{position:relative;max-width:min(980px,96vw);max-height:86vh;background:#000;border-radius:14px;overflow:hidden;box-shadow:0 24px 90px rgba(0,0,0,0.55);}
#ho-img-inner img{width:100%;height:100%;max-height:86vh;object-fit:contain;background:#000;}
.ho-x{position:absolute;top:10px;right:10px;width:40px;height:40px;border-radius:10px;background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.22);color:#fff;font-size:20px;cursor:pointer;}
.ho-x:hover{background:rgba(255,255,255,0.22);}
.ho-nav{
  position:absolute;top:50%;transform:translateY(-50%);
  width:44px;height:44px;border-radius:12px;
  background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.22);
  color:#fff;font-size:18px;cursor:pointer;
  display:flex;align-items:center;justify-content:center;
}
.ho-prev{left:10px;} .ho-next{right:10px;}
.ho-nav:hover{background:rgba(255,255,255,0.22);}

</style>
{{ button_css() }}
{{ action_buttons_css() }}
{{ footer_css() }}
{{ review_css() }}
<style>

@media(max-width:992px){
  .st-grid{grid-template-columns:1fr 1fr;}
  .svc-cats-grid{grid-template-columns:1fr 1fr;}
  .home-offers-grid{grid-template-columns:1fr;}
  .rev-grid{grid-template-columns:repeat(auto-fill, minmax(300px, 1fr));gap:15px;}
  .stores-sec,.services-sec,.offers-sec,.reviews-sec{padding:60px 20px;}
}
@media(max-width:600px){
  .hero h1{font-size:clamp(32px,8vw,48px);}
  .hero-btns{flex-direction:column;align-items:center;}
  .st-grid{grid-template-columns:1fr;}
  .svc-cats-grid{grid-template-columns:1fr;}
  .rev-grid{grid-template-columns:1fr;}
}

/* Open Now Badge */
.st-open-now{position:absolute;top:12px;right:12px;z-index:2;}
.st-open-now .status-dot{width:6px;height:6px;border-radius:50%;background:var(--text-light);display:inline-block;margin-right:4px;}
.st-open-now .status-text{font-size:10px;font-weight:600;color:var(--text-mid);display:inline-block;}
.st-open-now.status-open .status-dot{background:#28a745;}
.st-open-now.status-open .status-text{color:#28a745;}
.st-open-now.status-closed .status-dot{background:#dc3545;}
.st-open-now.status-closed .status-text{color:#dc3545;}
</style>
</head>
<body>
{{ tracking_body(gtm_id) }}

{% set base_path = '' %}
{% set active_page = 'home' %}
{% include "header.j2" %}

<section class="hero" aria-label="Hero">
  <div class="hero-bg">
    <img src="/images/heroes/home.jpg" alt="Naturals Salon & Spa Bangalore — premium beauty services"
         width="1800" height="1200"
         onerror="this.src='https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=1800&q=85'"
         loading="eager"
         fetchpriority="high">
  </div>
  <div class="hero-ov" aria-hidden="true"></div>
  <div class="hero-inner">
    <div class="hero-tag">5 Iconic Locations. 1 Elite Standard of Excellence.</div>
    <h1>{{ h1_heading | default("Bangalore's Premier Destination for Luxury Beauty &amp;<em>Styling</em>") }}</h1>
    <p class="hero-sub">{{ stores|length }} locations &middot; Expert stylists &middot; World-class services</p>
    <div class="hero-btns">
      <button onclick="openStorePicker()" class="btn-primary">{{ calendar_svg(18) }} Book Now</button>
      <button onclick="openStorePicker()" class="btn-secondary">{{ maps_svg(18) }} Choose Your Store</button>
    </div>
  </div>
</section>

<section class="stores-sec section" id="our-stores" aria-label="Our store locations">
  <div class="sec-hdr reveal">
    <div class="lbl">Our Locations</div>
    <h2>{{ stores|length }} stores.<br><em>One city.</em></h2>
    <p>Walk in or book online — premium beauty services across Bangalore.</p>
  </div>

  <div class="st-grid">
  {% for store in stores %}
    <div class="st-card reveal">
      <a href="/stores/{{ store.address_city|lower|replace(' ', '-') if store.address_city else 'bangalore' }}/{{ store.slug|lower if store.slug else (store.store_display_name|lower|replace(' ', '-')) }}/" class="st-card-head" aria-label="View {{ store.store_display_name }}">
        <div class="st-card-num">0{{ loop.index }}</div>
        <div class="st-card-name">{{ store.store_display_name }}</div>
        <div class="st-card-area">{{ store.store_display_name }} &middot; {{ store.Pincode }}</div>
        {% if store.mon_fri_hours %}
          <div class="st-open-now" data-store-id="{{ store.Store_ID }}" data-hours="{{ store.mon_fri_hours }}" data-sat-hours="{{ store.saturday_hours }}" data-sun-hours="{{ store.sunday_hours }}">
            <span class="status-dot"></span>
            <span class="status-text">Checking...</span>
          </div>
        {% endif %}
      </a>

      <div class="st-card-body">
        <div class="st-card-addr">{{ maps_svg(14, 'var(--gold)') }} {{ store.Address_Full }}</div>

        <div class="st-card-actions">
          <div class="st-icon-row">
            <a class="st-btn st-btn-book" href="{{ store.appointment_url }}" target="_blank" rel="noopener" aria-label="Book at {{ store.store_display_name }}">{{ calendar_svg(18) }}</a>
            <a class="st-btn st-btn-wa" href="https://wa.me/+{{ store.phone_whatsapp }}" target="_blank" rel="noopener" aria-label="WhatsApp {{ store.store_display_name }}">{{ wa_svg(18) }}</a>
            <a class="st-btn st-btn-call" href="tel:+{{ store.phone_mobile }}" aria-label="Call {{ store.store_display_name }}">{{ call_svg(18) }}</a>
          </div>
          <div class="st-icon-row">
            {% if store.get('instagram_url') and store.instagram_url not in ('','https://instagram.com/','https://instagram.com') %}
            <a class="st-btn st-btn-ig" href="{{ store.instagram_url }}" target="_blank" rel="noopener" aria-label="{{ store.store_display_name }} on Instagram">{{ ig_svg(18) }}</a>
            {% else %}
            <div class="st-btn st-btn-ph"></div>
            {% endif %}
            {% if store.get('facebook_url') and store.facebook_url not in ('','https://facebook.com/','https://facebook.com') %}
            <a class="st-btn st-btn-fb" href="{{ store.facebook_url }}" target="_blank" rel="noopener" aria-label="{{ store.store_display_name }} on Facebook">{{ fb_svg(18) }}</a>
            {% else %}
            <div class="st-btn st-btn-ph"></div>
            {% endif %}
            <a class="st-btn st-btn-maps" href="{{ store.Google_Maps_URL }}" target="_blank" rel="noopener" aria-label="Directions to {{ store.store_display_name }}">{{ maps_svg(18) }}</a>
          </div>
          <div class="st-info-row">
            <a class="st-view-btn" href="/stores/{{ store.address_city|lower|replace(' ', '-') if store.address_city else 'bangalore' }}/{{ store.slug|lower if store.slug else (store.store_display_name|lower|replace(' ', '-')) }}/" aria-label="View {{ store.store_display_name }}">Info &#8594;</a>
          </div>
        </div>
      </div>
    </div>
  {% endfor %}
  </div>
</section>

<section class="services-sec" id="services" aria-label="Our services">
  <div class="sec-hdr reveal">
    <div class="lbl">What We Offer</div>
    <h2>Services crafted<br>for <em>every you.</em></h2>
    <p>From precision cuts to bridal transformations — world-class beauty at every visit.</p>
  </div>

  {%- set svc_data = service_categories if service_categories else [
    {'name': 'Haircuts & Styling', 'icon_name': 'service_default.jpg', 'href': 'services/'},
    {'name': 'Hair Colour & Highlights', 'icon_name': 'service_default.jpg', 'href': 'services/'},
    {'name': 'Hair Spa & Treatments', 'icon_name': 'service_default.jpg', 'href': 'services/'},
    {'name': 'Skin Care & Facials', 'icon_name': 'service_default.jpg', 'href': 'services/'},
